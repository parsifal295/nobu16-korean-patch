# Complete game resources and binary patch payloads must never enter Git
*.bin
*.g1n
*.g1t
*.bak
*.orig
*.rep
*.gpr
*.reg
*.7z
*.zip
*.tar
*.tar.gz

# Generated font files are ignored except the pinned OFL build inputs
*.ttf
!/vendor/noto/*.ttf

