  },
  "entries": [
    {
      "block_id": 6,
      "ko": "성주와 잘 지낼 자신이",
      "literal_id": 2,
      "record_id": 4482,
      "source_sc_utf16le_sha256": "E1A31CDA450C33EF4D02AA1F8E4C34CF4F81EEA73CF9CC26AF1195983E42F460"
    },
    {
      "block_id": 6,
      "ko": "전선이라 가슴이 뛰는군요.\n부디 저를 영주로 임명해 주십시오.",
      "literal_id": 0,
      "record_id": 4485,
      "source_sc_utf16le_sha256": "BBF306DB7E6B54BA9D5AB66127E8923EFEFD3A27FFABC070AF2AF7E22F7C6158"
    },
    {
      "block_id": 6,
      "ko": "적령과 가까운 전선이니,\n바로",
      "literal_id": 0,
      "record_id": 4487,
      "source_sc_utf16le_sha256": "6ADFEE7CDCFFAAC6D2AA9C9EC06E5B9EBC1CFEF35E2F4B9EACBC2CE8344B6047"
    },
    {
      "block_id": 6,
      "ko": "\n그곳에서는 솜씨를 마음껏 발휘하기 어렵겠군요……",
      "literal_id": 1,
      "record_id": 4488,
      "source_sc_utf16le_sha256": "0AFF0F7B31F47FF7C10FA752BB714B7D0E43C6A453370EB0B10732250D912762"
    },
    {
      "block_id": 6,
      "ko": "당가의 손길이\n거의 닿지 않은 땅이군요……\n힘쓸 보람이 있겠습니다.",
      "literal_id": 0,
      "record_id": 4492,
      "source_sc_utf16le_sha256": "350636A691FE04F189D56042A2082B5B3F21164C0C8E8C8C0CC7540828ABAB14"
    },
    {
      "block_id": 6,
      "ko": "……할 일이 많아 보이는 땅이군요.\n영주의 수완을 시험하기에 제격입니다.",
      "literal_id": 0,
      "record_id": 4493,
      "source_sc_utf16le_sha256": "D97C0B61BBAA349529702CC97565EDB196D6794EB2AA3E15CFE35FD13C88F867"
    },
    {
      "block_id": 6,
      "ko": "참으로 안정된 땅이군요.\n안심하고 부임할 수 있겠습니다.",
      "literal_id": 0,
      "record_id": 4494,
      "source_sc_utf16le_sha256": "98444CF88C0C62E12031CFB192C37AA9463551051F360F608F8ADC3F83E295FB"
    },
    {
      "block_id": 6,
      "ko": "그곳에 배속된다면,\n할 일을 찾아야겠군요.\n참으로 잘 정비된 땅입니다.",
      "literal_id": 0,
      "record_id": 4495,
      "source_sc_utf16le_sha256": "26CD54CA551232222D32375F6CF69DEB0B02BC9591C3ACACE745110D8D3DE9F9"
    },
    {
      "block_id": 6,
      "ko": "머, 멀군요……\n아니, 명만 내리시면\n즉시 길 떠날 채비를 하겠습니다.",
      "literal_id": 0,
      "record_id": 4500,
      "source_sc_utf16le_sha256": "7C348FFA27158C2562845C34BEA49EC6ED9450CC85809B615EA7421570C36BF5"
    },
    {
      "block_id": 6,
      "ko": "특별한 뜻은 없습니다만,\n배속하실 분이",
      "literal_id": 0,
      "record_id": 4501,
      "source_sc_utf16le_sha256": "A5B71B3C16291ED69FFC31A0FC16354280FC54F78E8B476819744DCCF83C5979"
    },
    {
      "block_id": 6,
      "ko": "라면,\n거리가 멀어 부임에 시간이 걸리겠습니다……",
      "literal_id": 1,
      "record_id": 4501,
      "source_sc_utf16le_sha256": "7EB53C92A01460F58F7A8045C7748EC97A470FB300E73F7FBC62532CE0C3DBE6"
    },
    {
      "block_id": 6,
      "ko": "\n관계가 좋지도 나쁘지도 않으니,\n문제없이 일할 수 있을 듯합니다.",
      "literal_id": 1,
      "record_id": 4504,
      "source_sc_utf16le_sha256": "648A16E392301F7DB17EECCCAFEB40CD5BC1DA2F2FDAC1071A4810497E7FF9EF"
    },
    {
      "block_id": 6,
      "ko": "아직 여력이 있으니,\n성주인",
      "literal_id": 0,
      "record_id": 4507,
      "source_sc_utf16le_sha256": "0704F65A07EFF1130879451BFBCBC06C6220B1835C2A86E5CE7561701C5F3F61"
    },
    {
      "block_id": 6,
      "ko": "도 겸임할 수 있습니다.",
      "literal_id": 1,
      "record_id": 4507,
      "source_sc_utf16le_sha256": "0FCF6675AE7368C3105C4974B9B95E94EDF42A2A7EF83C3F43DF262D2CFD7EEE"
    },
    {
      "block_id": 6,
      "ko": "아직 더 할 수 있습니다.\n해임하지 말아 주십시오.",
      "literal_id": 0,
      "record_id": 4509,
      "source_sc_utf16le_sha256": "0E9999820FF70D74B6ACDAE7F226BF2334A71EA4BAB8AEB4BCB8A1D629B9315B"
    },
    {
      "block_id": 6,
      "ko": "설마 해임을 생각하고 계십니까?\n부디 다시 생각해 주십시오……",
      "literal_id": 0,
      "record_id": 4510,
      "source_sc_utf16le_sha256": "6BCA06B7B2BD957C5F415D064B340A4C6DC7EA84B57E6EEA3BC360449994A533"
    },
    {
      "block_id": 6,
      "ko": "도움을 준",
      "literal_id": 0,
      "record_id": 4517,
      "source_sc_utf16le_sha256": "AF80FDB6CBD7DCDAD37F6165BA163C3F0D3D58F680A0D2C54BAA38D739E4DC23"
    },
    {
      "block_id": 6,
      "ko": "은(는) 큰 불만을 품고 있어,\n언제 출분해도 이상하지 않습니다.\n부디",
      "literal_id": 1,
      "record_id": 4551,
      "source_sc_utf16le_sha256": "4CD6BDF06184A13167CC3086DADBD369C2A13E3C8D1FAF7EB395A8675E3FEE65"
    },
    {
      "block_id": 6,
      "ko": "등용이 순조롭지 않습니다.\n하지만 이 사람은 명성이 높은 인재이니, 부디",
      "literal_id": 1,
      "record_id": 4553,
      "source_sc_utf16le_sha256": "068BD9F90552F2C8537AD1A297D91D892BC726A95BDE2F9CDC0AE22FC723E4DF"
    },
    {
      "block_id": 6,
      "ko": "이(가) 우리에게 항복하겠다고 합니다.\n더 나은 조건을 얻도록 교섭하시겠습니까?",
      "literal_id": 3,
      "record_id": 4562,
      "source_sc_utf16le_sha256": "310004FA6FC28398A96A0E2A08E463295AD742DF9DA29510C7B93A592A808FF8"
    },
    {
      "block_id": 6,
      "ko": "이(가) 우리에게 항복하겠다고 합니다.\n더 나은 조건을 얻도록 교섭하시겠습니까?",
      "literal_id": 3,
      "record_id": 4563,
      "source_sc_utf16le_sha256": "310004FA6FC28398A96A0E2A08E463295AD742DF9DA29510C7B93A592A808FF8"
    },
    {
      "block_id": 6,
      "ko": "빼내기가 순조롭게 진행되어,\n성째로 배반할 뜻도 있는 듯합니다.\n자세한 사정은",
      "literal_id": 1,
      "record_id": 4564,
      "source_sc_utf16le_sha256": "52C6E462EB6EE2494A84147F278DF8811FDF2BD266A363679201BE46769E9279"
    },
    {
      "block_id": 6,
      "ko": "\n빼내기에 응해 성째로 배반할 뜻도 있다 합니다.\n자세한 사정은",
      "literal_id": 2,
      "record_id": 4566,
      "source_sc_utf16le_sha256": "62C1E560815408CE9D33F301F074E670E74407519FAF010B3CD0996475677C51"
    },
    {
      "block_id": 6,
      "ko": "\n빼내기에 응해 성째로 배반할 뜻도 있다 합니다.\n자세한 사정은",
      "literal_id": 2,
      "record_id": 4567,
      "source_sc_utf16le_sha256": "62C1E560815408CE9D33F301F074E670E74407519FAF010B3CD0996475677C51"
    },
    {
      "block_id": 6,
      "ko": "그렇습니까, 어쩔 수 없군요.\n붙잡는 일은 포기하겠습니다.",
      "literal_id": 0,
      "record_id": 4577,
      "source_sc_utf16le_sha256": "FC343591F8ADDD2A29145233563E8FC66F9A5CE0CAD1DC404B0B3257BEFFBF4A"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다, 참으로 아쉽군요.\n하지만",
      "literal_id": 0,
      "record_id": 4579,
      "source_sc_utf16le_sha256": "DBC7F66B6AFA163F2EF84852215632C06BED242D95F30E7BAC7BBEDEA3ECED5A"
    },
    {
      "block_id": 6,
      "ko": "그렇다면 성째로 배반시키는 것은 포기하고,\n대신",
      "literal_id": 0,
      "record_id": 4582,
      "source_sc_utf16le_sha256": "CDD868A9B2BF31B834ED9BBC6FD80B8805249E2862B8E8F4BDD62F21130A8E77"
    },
    {
      "block_id": 6,
      "ko": "!\n설마",
      "literal_id": 0,
      "record_id": 4590,
      "source_sc_utf16le_sha256": "2B54B8118E28931242C95292420B83832C676697DA510345EB60430C6038B750"
    },
    {
      "block_id": 6,
      "ko": "직접 찾아오실 줄이야……\n그만큼 중요한 일이라는 뜻이군요.",
      "literal_id": 0,
      "record_id": 4591,
      "source_sc_utf16le_sha256": "7D5CF7477AE324D1AC4F5776CC1B52A7EDB64AD80FB922479E5268531A8125DE"
    },
    {
      "block_id": 6,
      "ko": "께서 직접 오시다니,\n그토록",
      "literal_id": 1,
      "record_id": 4594,
      "source_sc_utf16le_sha256": "2A5AB625A3614F94AE8D6FE5EE80A1812C0DCC85F1D7D2386D6ED5F608138DA5"
    },
    {
      "block_id": 6,
      "ko": "입니까?\n소인은",
      "literal_id": 1,
      "record_id": 4599,
      "source_sc_utf16le_sha256": "553D43EDE03A1B8341FC3F865B817B94041152BC5AC146DC760FD7BD46A589F3"
    },
    {
      "block_id": 6,
      "ko": "입니다.\n원하는 것이 있다면 말씀하십시오.",
      "literal_id": 2,
      "record_id": 4624,
      "source_sc_utf16le_sha256": "011CD776964DE58A6193D502A64208894158E0AAC87E0C2926271F704DC45C36"
    },
    {
      "block_id": 6,
      "ko": "은(는) 보기 드문 인재입니다.\n사람의 마음은 작은 일에도 바뀌는 법이지요.\n가령 바람을 이루어 드린다면……?",
      "literal_id": 1,
      "record_id": 4636,
      "source_sc_utf16le_sha256": "011B57E7BB2A20743BC9C4CD1A915AE032A9F350BF7FDAADB9E75B1518914FF5"
    },
    {
      "block_id": 6,
      "ko": "더는 싸우고 싶지 않지만,\n상대가",
      "literal_id": 0,
      "record_id": 4675,
      "source_sc_utf16le_sha256": "39BB46F885144F07C016C84B9CCBE7FEE309DF1844103F38078E46FAD85D1CDF"
    },
    {
      "block_id": 6,
      "ko": "그렇군요, 어쩔 수 없습니다.\n끝내 뜻을 함께하지 못하는군요……",
      "literal_id": 0,
      "record_id": 4707,
      "source_sc_utf16le_sha256": "0FD1AF2B0F08681886A0FB0AF82682BA0F30D469F0C99FE367AE74BF7917A1CA"
    },
    {
      "block_id": 6,
      "ko": "그렇군요……참으로 아쉽습니다.\n어디서부터 어긋난 것일까요……",
      "literal_id": 0,
      "record_id": 4709,
      "source_sc_utf16le_sha256": "CE3B9427C9B0717B7413EE84ACB00ACE65066DCC4F5B2C5FC0CED0CD6843EBA5"
    },
    {
      "block_id": 6,
      "ko": "그렇군요……참으로 아쉽습니다.\n다음에 만날 때는,\n전장에서 적으로 만나지 않기를 바랍니다.",
      "literal_id": 0,
      "record_id": 4712,
      "source_sc_utf16le_sha256": "504C72D61D389F387E9E51F6C6ADC70A0544FC55AEE41009BA95F693DD597421"
    },
    {
      "block_id": 6,
      "ko": "그렇군요……\n받아들이지 않으니 아쉽지만,\n어쩔 수 없습니다.",
      "literal_id": 0,
      "record_id": 4716,
      "source_sc_utf16le_sha256": "678B8BF5E4A9F5DDB6F1E71EB61A05B972AC5C34C56F448812643EB4D336CAE7"
    },
    {
      "block_id": 6,
      "ko": "의 마음은 잘 받았습니다.\n언제든 다시 찾아오십시오.",
      "literal_id": 1,
      "record_id": 4756,
      "source_sc_utf16le_sha256": "CB3249B68AF41D98876628700833735B23E7788531A45E42D4885AED5D32A4D2"
    },
    {
      "block_id": 6,
      "ko": "만약",
      "literal_id": 0,
      "record_id": 4761,
      "source_sc_utf16le_sha256": "FF4965917B8085F608DCE20C69EB97C26DA516A44CF257C620EE94EEE2838A0B"
    },
    {
      "block_id": 6,
      "ko": "등용을 포기할 대상은",
      "literal_id": 0,
      "record_id": 4762,
      "source_sc_utf16le_sha256": "D56969B2DF7C7A718BCEC2CCE23078C170BE3E83605D47BD355B3C6B43ECBF00"
    },
    {
      "block_id": 6,
      "ko": "등용을 포기할 대상은",
      "literal_id": 0,
      "record_id": 4763,
      "source_sc_utf16le_sha256": "D56969B2DF7C7A718BCEC2CCE23078C170BE3E83605D47BD355B3C6B43ECBF00"
    },
    {
      "block_id": 6,
      "ko": "제안을 거절할 상대는",
      "literal_id": 0,
      "record_id": 4766,
      "source_sc_utf16le_sha256": "0F3FE3FE22F520051616F1970FA55826B6FF3E7E5D97F0229A6F590BDA64AD88"
    },
    {
      "block_id": 6,
      "ko": "빼내기를 포기할 대상은",
      "literal_id": 0,
      "record_id": 4767,
      "source_sc_utf16le_sha256": "B5618FF212E6E0E5ED5ED897B428F14D1F273F19DF99AA31CADDFFF7D5A8F1CB"
    },
    {
      "block_id": 6,
      "ko": "정전 교섭을 중지할 상대는",
      "literal_id": 0,
      "record_id": 4768,
      "source_sc_utf16le_sha256": "30768F76E26363DE82BBFCA80081697D04986331CA52359EE21B22BDE1C5118A"
    },
    {
      "block_id": 6,
      "ko": "양여를 중지할 상대는",
      "literal_id": 0,
      "record_id": 4769,
      "source_sc_utf16le_sha256": "C4EE559064C343FB0A02BADBA4D0BDC6D8ABC06896290C2CB5B5FF65152E9080"
    },
    {
      "block_id": 6,
      "ko": "이 있는 성의 영지를\n관리할 인물은",
      "literal_id": 1,
      "record_id": 4783,
      "source_sc_utf16le_sha256": "D0ECED8FF5FE0D3609E76FB96422058A59A50DED65C1039BFFE1B7E6909E1306"
    },
    {
      "block_id": 6,
      "ko": "로 임명한다는 약속,\n잊지 마십시오.",
      "literal_id": 2,
      "record_id": 4809,
      "source_sc_utf16le_sha256": "F27B227D44EB83DA7E9376BA1B2CE70622FCA110B1D644021CCE8596CBC9403C"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n즉시 준비하겠습니다.",
      "literal_id": 0,
      "record_id": 4840,
      "source_sc_utf16le_sha256": "6B0ADBCF51F4329D0813FF5E2587DDA60C0D899CAEE5394B756D1DF78D407A26"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n즉시 준비하겠습니다.",
      "literal_id": 0,
      "record_id": 4841,
      "source_sc_utf16le_sha256": "6B0ADBCF51F4329D0813FF5E2587DDA60C0D899CAEE5394B756D1DF78D407A26"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n즉시 준비하겠습니다.",
      "literal_id": 0,
      "record_id": 4842,
      "source_sc_utf16le_sha256": "6B0ADBCF51F4329D0813FF5E2587DDA60C0D899CAEE5394B756D1DF78D407A26"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n즉시 준비하겠습니다.",
      "literal_id": 0,
      "record_id": 4846,
      "source_sc_utf16le_sha256": "6B0ADBCF51F4329D0813FF5E2587DDA60C0D899CAEE5394B756D1DF78D407A26"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n이 성은 목숨을 걸고 지키겠습니다.",
      "literal_id": 0,
      "record_id": 4855,
      "source_sc_utf16le_sha256": "086B1CC69F69B8B0DFF1324E44C68A2192182BE46D50CD1E57F3259C32E5162B"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n이 성은 목숨을 걸고 지키겠습니다.",
      "literal_id": 0,
      "record_id": 4856,
      "source_sc_utf16le_sha256": "086B1CC69F69B8B0DFF1324E44C68A2192182BE46D50CD1E57F3259C32E5162B"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n이 성은 목숨을 걸고 지키겠습니다.",
      "literal_id": 0,
      "record_id": 4857,
      "source_sc_utf16le_sha256": "086B1CC69F69B8B0DFF1324E44C68A2192182BE46D50CD1E57F3259C32E5162B"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n이 성은 목숨을 걸고 지키겠습니다.",
      "literal_id": 0,
      "record_id": 4861,
      "source_sc_utf16le_sha256": "086B1CC69F69B8B0DFF1324E44C68A2192182BE46D50CD1E57F3259C32E5162B"
    },
    {
      "block_id": 6,
      "ko": ".\n지금은 교섭할 일이 없지만,\n이번 친선이 의미를 갖는 때가 올 것입니다.",
      "literal_id": 1,
      "record_id": 4907,
      "source_sc_utf16le_sha256": "FCCECD0748E223693265C83E0C242BE1BE0DA28EFCCBCCA4A6F04BC53352C73E"
    },
    {
      "block_id": 6,
      "ko": ",\n약속대로",
      "literal_id": 1,
      "record_id": 4915,
      "source_sc_utf16le_sha256": "8C669145DBDF6A0FCFEEC4D7744582673C18C17E1363EA57EEF6900A56B3C309"
    },
    {
      "block_id": 7,
      "ko": "적장을 포박했습니다.\n붙잡힌 무장의 처우를 결정해 주십시오.",
      "literal_id": 0,
      "record_id": 221,
      "source_sc_utf16le_sha256": "0E817D67C4B244FAE39CCAD6064DBD664059016197ED0A023C335B636E88A4A5"
    },
    {
      "block_id": 7,
      "ko": "……이렇게 된 이상 어쩔 수 없군요.\n이제부터 귀가를 섬기겠습니다.",
      "literal_id": 0,
      "record_id": 264,
      "source_sc_utf16le_sha256": "646D9F0FED89312353F591A84DA5AF8C86C7803BAEFF5BFD7F517EF76C99332F"
    },
    {
      "block_id": 7,
      "ko": "도량에 감사드립니다.\n이제부터 충성을 다하겠습니다.",
      "literal_id": 1,
      "record_id": 265,
      "source_sc_utf16le_sha256": "88E6FD3B6CA77156736BBE4D50BBE5633EF6C9836C8DD59F5979F3E7684E4163"
    },
    {
      "block_id": 7,
      "ko": "권유에 감사드립니다.\n포로가 되었던 오명은 공으로 씻고,\n충성을 다하겠습니다.",
      "literal_id": 0,
      "record_id": 266,
      "source_sc_utf16le_sha256": "837DB8F2D5065E3958DA5A49CFD5C792131FE202E2463672457AF473A10B016E"
    },
    {
      "block_id": 7,
      "ko": "을 위해 일하라니,\n어쩔 수 없군요.\n기꺼이 힘을 다하겠습니다.",
      "literal_id": 1,
      "record_id": 267,
      "source_sc_utf16le_sha256": "9A2F9D5FCB629E66D3FDA18C1F079F308B4C114A37830EBA7BD0730B8254425B"
    },
    {
      "block_id": 7,
      "ko": "의 휘하에서 일하는 데,\n아무런 이의가 없습니다.",
      "literal_id": 1,
      "record_id": 268,
      "source_sc_utf16le_sha256": "D00A74B54BD92DFAC94372D2A4551F844A24328A5681D814388057CD7BFE0C3A"
    },
    {
      "block_id": 7,
      "ko": "귀가의 부름, 감사히 받겠습니다.\n특히",
      "literal_id": 0,
      "record_id": 269,
      "source_sc_utf16le_sha256": "81535430B54483FDC2ECE1831EC31AD8910E0142CD3835109D17B2C13C530F79"
    },
    {
      "block_id": 7,
      "ko": "……옛 주군을 잊기는 어렵지만,\n이 또한 난세의 이치겠지요.\n앞으로 잘 부탁드립니다.",
      "literal_id": 0,
      "record_id": 272,
      "source_sc_utf16le_sha256": "BB57C803C9D70F648182563572CDA759CF4644B96401588D695DAF2EA3D579E8"
    },
    {
      "block_id": 7,
      "ko": "당가가 천하를 다스릴 길은 끊겼습니다……\n이제부터",
      "literal_id": 0,
      "record_id": 273,
      "source_sc_utf16le_sha256": "EE3DC4FDC65FD138677715A0A40DE96C8BBFA87987031472BB1D6561650B4EDD"
    },
    {
      "block_id": 7,
      "ko": "……목숨을 구해 주신 은혜를 갚고자,\n이제",
      "literal_id": 0,
      "record_id": 276,
      "source_sc_utf16le_sha256": "6830AA101F434A31E59B21D7C3A39ABD99063742DB98EAB4ED8BC3000EBDFDE1"
    },
    {
      "block_id": 7,
      "ko": "을 섬기겠습니다.\n이 또한 인연이겠지요……",
      "literal_id": 1,
      "record_id": 276,
      "source_sc_utf16le_sha256": "7E484582A90BC38630E0404BC77F2B3E8A58357693E38A28541F5BD4DCFDF285"
    },
    {
      "block_id": 7,
      "ko": "은(는) 저를 놓아준 은인이십니다.\n다시 불러 주신 이상,\n따르는 수밖에 없습니다.",
      "literal_id": 0,
      "record_id": 277,
      "source_sc_utf16le_sha256": "211CC4E1808E196260BC18DB096090D9689FE6ED82A2B45EE1378F5FCE4C06E4"
    },
    {
      "block_id": 7,
      "ko": "사로잡힌 저를 풀어 주신 은혜,\n결코 잊지 않겠습니다.\n분골쇄신하여",
      "literal_id": 0,
      "record_id": 278,
      "source_sc_utf16le_sha256": "F99E8AE070A9D05B7A09B146756FCEDCDBB26E50942EADB62AC0C67152D3F288"
    },
    {
      "block_id": 7,
      "ko": "명이 사로잡혀,\n이제",
      "literal_id": 1,
      "record_id": 284,
      "source_sc_utf16le_sha256": "1C618B94153F40008F5D66403C6D375D85B6064672CF0658504D124678F41755"
    },
    {
      "block_id": 7,
      "ko": "을 섬길 수는 없다!",
      "literal_id": 2,
      "record_id": 325,
      "source_sc_utf16le_sha256": "8BD7C04E2E17F42EBB3B8001273C9CE28218C208E6CB7751E78263AB9F3227E8"
    },
    {
      "block_id": 7,
      "ko": "웃기지도 않는 농담이군.\n내 마음속 증오의 불길은\n그리 쉽게 꺼지지 않는다.",
      "literal_id": 0,
      "record_id": 326,
      "source_sc_utf16le_sha256": "0FB53D614EFB6866124ADAC601C66C0D6B6297E3EF97E557E160A727D9D279C1"
    },
    {
      "block_id": 7,
      "ko": "거절한다.\n네가 저지른 악행부터 돌아보아라.",
      "literal_id": 0,
      "record_id": 327,
      "source_sc_utf16le_sha256": "2D4865552F1940427E7B04778977DC64FF715C3986EC1ED290AD1BA1E8ED5FA7"
    },
    {
      "block_id": 7,
      "ko": "에게도 긍지가 있습니다.\n조금 전까지 적이었던 자를 주군으로 섬길 수는 없습니다.",
      "literal_id": 0,
      "record_id": 332,
      "source_sc_utf16le_sha256": "BC11A2D465676568DD24230E50223558831D84CE2BB7B4B7CA3FFB21BCACCBBE"
    },
    {
      "block_id": 7,
      "ko": "은(는) 나의 대망을 꺾은 원수입니다.\n쉽게 항복할 수는 없습니다.",
      "literal_id": 1,
      "record_id": 333,
      "source_sc_utf16le_sha256": "923DB4252B683BB3FAD03B63E534E591A69D01B4D6EEE0E83FEB7B8DEF2883F8"
    },
    {
      "block_id": 7,
      "ko": "……온정은 감사하오나,\n이번에는 거절하겠습니다.\n아직 그럴 마음은 들지 않습니다……",
      "literal_id": 0,
      "record_id": 334,
      "source_sc_utf16le_sha256": "70DD57E932F18F9109E4BCEBC32F10E0F93E2108B50EC8C204150BBF7BC546A1"
    },
    {
      "block_id": 7,
      "ko": "권유에는 감사드립니다.\n하지만 당장 결단할 수는 없습니다……",
      "literal_id": 0,
      "record_id": 335,
      "source_sc_utf16le_sha256": "BD97A36C95E86F9E8FB2B22306EE38723588DB6FB61AAA68858C4E7EC96D9FB6"
    },
    {
      "block_id": 7,
      "ko": "송구합니다.\n주가를 잃은 지 얼마 되지 않아,\n아직 마음을 추스르지 못했습니다.",
      "literal_id": 0,
      "record_id": 336,
      "source_sc_utf16le_sha256": "1F975789452E447800EDA1694884127CE0468502A71E474D46D8A087D4CD65CD"
    },
    {
      "block_id": 7,
      "ko": "이제 여기까지다……\n결별할 상대는",
      "literal_id": 0,
      "record_id": 570,
      "source_sc_utf16le_sha256": "E507B9A43DB5C54F4EB6337DDA1C8DF4345905068692AB6FD101DE6A25375729"
    },
    {
      "block_id": 7,
      "ko": "아무래도 함께할 수 있는 것은 여기까지인 듯하군.\n싸울 수 없는 상대는",
      "literal_id": 0,
      "record_id": 578,
      "source_sc_utf16le_sha256": "442ED4309899B750A381AE3176410888D3133FF297E096DDB972D059C0CD2D14"
    },
    {
      "block_id": 7,
      "ko": "이제 여기까지다……\n싸울 수 없는 상대는",
      "literal_id": 0,
      "record_id": 579,
      "source_sc_utf16le_sha256": "03683089EE192D9A86862A73915F93D894258A24DBAB7D2E24FC0A25C3CABC78"
    },
    {
      "block_id": 7,
      "ko": "교전 상대는",
      "literal_id": 0,
      "record_id": 587,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 7,
      "ko": "이번 교전 상대는",
      "literal_id": 0,
      "record_id": 588,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 7,
      "ko": "（내 영지를 지키지 못하다니……\n　당가의 힘도 알 만하군……）",
      "literal_id": 0,
      "record_id": 800,
      "source_sc_utf16le_sha256": "A138D03A2CD10BF63E70C049B66B52BEEBB2EFEBC1ABFE91D10CDEDED4E913CF"
    },
    {
      "block_id": 7,
      "ko": "은(는) 본거지에서 멀리 떨어져 있습니다.\n휘하 군단에 통치를 맡기는 것이 좋습니다.",
      "literal_id": 0,
      "record_id": 803,
      "source_sc_utf16le_sha256": "2737024F5D2D98F07A4F04372C11DBF50D39C555A299817E6B14E4BDD3725A9E"
    },
    {
      "block_id": 7,
      "ko": "새 본거지를 결정해 주십시오.\n",
      "literal_id": 0,
      "record_id": 805,
      "source_sc_utf16le_sha256": "4F12ECE7CE2476F8D640C51C3CBBDF6731D2EB57A9E05ECCAE76269BEC146173"
    },
    {
      "block_id": 7,
      "ko": "새 본거지를 결정해 주십시오.\n",
      "literal_id": 0,
      "record_id": 806,
      "source_sc_utf16le_sha256": "4F12ECE7CE2476F8D640C51C3CBBDF6731D2EB57A9E05ECCAE76269BEC146173"
    },
    {
      "block_id": 7,
      "ko": "본거 이전에 따라,\n지휘 범위 밖이 된",
      "literal_id": 0,
      "record_id": 807,
      "source_sc_utf16le_sha256": "57FCEA6BED4E91393D9806390A62B56E3C02D5611B30F0B866E3014E598C900D"
    },
    {
      "block_id": 7,
      "ko": "\n다이묘 군단 소속이 됩니다.",
      "literal_id": 1,
      "record_id": 807,
      "source_sc_utf16le_sha256": "FCF6B5E076B14F17C34D4D51A5194296167F7B02DDD89C2207A2F59CA422531A"
    },
    {
      "block_id": 7,
      "ko": "본거 이전에 따라,\n",
      "literal_id": 0,
      "record_id": 808,
      "source_sc_utf16le_sha256": "8098F9E794B7F20703257CFF06430F5041286637529071F9D752657739EAE951"
    },
    {
      "block_id": 7,
      "ko": "\n원군 요청을 받았으므로,\n",
      "literal_id": 1,
      "record_id": 816,
      "source_sc_utf16le_sha256": "2493BB3434573152EDAB9065894B66F2A0C2AA580EA1AEC635C0B04CC2EC33A1"
    },
    {
      "block_id": 7,
      "ko": "이(가) 이토록 쇠퇴할 줄이야……\n이대로 섬겨도 미래는 없습니다.\n충성을 다하는 것도 여기까지입니다.",
      "literal_id": 0,
      "record_id": 828,
      "source_sc_utf16le_sha256": "94B1BB227C76A713602C3BD8F95734DD7A0D5920C436AB969BFB824D950348FA"
    },
    {
      "block_id": 7,
      "ko": "싸우게 될 상대가",
      "literal_id": 0,
      "record_id": 831,
      "source_sc_utf16le_sha256": "6D096842615F36636B73FF658AE6E3EA6B7FC5718FBD97AB79B839741FEA2203"
    },
    {
      "block_id": 7,
      "ko": "방금 원군을 보낸 곳은",
      "literal_id": 0,
      "record_id": 835,
      "source_sc_utf16le_sha256": "BB456F11191497CE12E854093E84A50AA6C0209293827943C7B7486641EEEC13"
    },
    {
      "block_id": 7,
      "ko": "저자가 건방지게 구는군.\n직접 나설 사람은",
      "literal_id": 0,
      "record_id": 864,
      "source_sc_utf16le_sha256": "4F39DE4484F1A438F30F3078BB72780655521A182EEFB32089C83F4730CA1ABF"
    },
    {
      "block_id": 7,
      "ko": "까지 나서다니……!\n이제",
      "literal_id": 1,
      "record_id": 876,
      "source_sc_utf16le_sha256": "0CA130030BAF0321D408427961006A11480B00F5B14CD3EB75E39047007B64F5"
    },
    {
      "block_id": 7,
      "ko": "의 무용을 시험할 때입니다.",
      "literal_id": 2,
      "record_id": 876,
      "source_sc_utf16le_sha256": "19A97CE181BCE2063F5703248E812E4BDA6D070CB153D7A4972B73CDAF14CDE4"
    },
    {
      "block_id": 7,
      "ko": "놈이 나타났는가?\n정예 미카와 병사를 이끈다고 한다.\n모두 방심하지 마라.",
      "literal_id": 0,
      "record_id": 878,
      "source_sc_utf16le_sha256": "1EB1147F77F203497D03B4EB74F8DFA8F894AC18C2DE4374AAB9CA0B04B98416"
    },
    {
      "block_id": 7,
      "ko": "마침내 야심을 드러냈는가.\n천하의 안녕을 위해,\n더는",
      "literal_id": 0,
      "record_id": 882,
      "source_sc_utf16le_sha256": "E1F8CA6A17E9802FAAF9FAD70BEF07D3D2F7062F5CE35A2A29CCC5D3FDC2C943"
    },
    {
      "block_id": 7,
      "ko": "두고 볼 수 없다!",
      "literal_id": 1,
      "record_id": 882,
      "source_sc_utf16le_sha256": "CC34921B4D5608D0D58C5DF986E3AC1ECE992179C680A897D45878DADB95EF49"
    },
    {
      "block_id": 7,
      "ko": "가증스러운",
      "literal_id": 0,
      "record_id": 885,
      "source_sc_utf16le_sha256": "A46FA69721422A8E160A28754953154F65800D795C535E4E685350D69C0A086B"
    },
    {
      "block_id": 7,
      "ko": "가증스러운",
      "literal_id": 0,
      "record_id": 889,
      "source_sc_utf16le_sha256": "A46FA69721422A8E160A28754953154F65800D795C535E4E685350D69C0A086B"
    },
    {
      "block_id": 7,
      "ko": "이런 곳까지 오다니!\n목숨을 두려워하지 않는 사나운 무사들을 어찌 막는단 말인가……",
      "literal_id": 0,
      "record_id": 890,
      "source_sc_utf16le_sha256": "00CBD31FFF6AA33E5C5B939EE5EFEB226D4F40840485038E92C6EFCC94584250"
    },
    {
      "block_id": 7,
      "ko": "!?\n……이렇게 된다면\n거리 둘 상대는",
      "literal_id": 1,
      "record_id": 951,
      "source_sc_utf16le_sha256": "6A3953CE62CE451B59E2F1E551EFD7B5F083011838F7DA665E05503A884BC81C"
    },
    {
      "block_id": 7,
      "ko": "힘없는 의는 무와 다름없다.\n패배한 상대는",
      "literal_id": 0,
      "record_id": 955,
      "source_sc_utf16le_sha256": "90B8CDEB957B788ABB3060EBDA50E4E8ABFF85D31560582C86911980ECC0BE08"
    },
    {
      "block_id": 7,
      "ko": ",\n거리를 둘 상대는",
      "literal_id": 1,
      "record_id": 955,
      "source_sc_utf16le_sha256": "E51DABB45CC8785FF443829BDFC4FFF28914C447E407DFE12CA44D6488E89BE5"
    },
    {
      "block_id": 7,
      "ko": "패배한 상대는",
      "literal_id": 0,
      "record_id": 956,
      "source_sc_utf16le_sha256": "23BE9D5CE0D5AD890EDE3C8F47948C45D47EA695B11DF2237C9F4ECE3E202622"
    },
    {
      "block_id": 7,
      "ko": ", 불운이든 실력이든,\n",
      "literal_id": 1,
      "record_id": 956,
      "source_sc_utf16le_sha256": "B61EB1AD2954B07311FAF809E8CAEF2DC6F0C6AFB6695908595369BAD57C797E"
    },
    {
      "block_id": 7,
      "ko": "까지 염두에 두어야겠군.",
      "literal_id": 2,
      "record_id": 957,
      "source_sc_utf16le_sha256": "8566533E41CF089CEE81EE1605B7027003270733AAEC1E484EBC087C5569C224"
    },
    {
      "block_id": 7,
      "ko": "따위에게……\n",
      "literal_id": 1,
      "record_id": 961,
      "source_sc_utf16le_sha256": "5522B7562ADFB160D6FB0AAC4613C545051672FFC42E608D326D1E7539B1EE6C"
    },
    {
      "block_id": 7,
      "ko": "에게 패하다니……\n",
      "literal_id": 1,
      "record_id": 962,
      "source_sc_utf16le_sha256": "77BBEA9D0B1203834E512366DA44CD5AE8EA53794242199E554304202A6D7921"
    },
    {
      "block_id": 7,
      "ko": "에게 패하다니……유약하구나,",
      "literal_id": 0,
      "record_id": 963,
      "source_sc_utf16le_sha256": "DE6A783485480F124AA2F03FCED68A17678E7EB7140C4EB11EA6357B578E8EE3"
    },
    {
      "block_id": 7,
      "ko": "……\n그토록 유약하다니,\n",
      "literal_id": 1,
      "record_id": 963,
      "source_sc_utf16le_sha256": "6839C45B60CE02DFDA76E02976410CC5E5DAD223DA148F11E401069CA5B30376"
    },
    {
      "block_id": 7,
      "ko": "에게 패했습니까……\n",
      "literal_id": 1,
      "record_id": 967,
      "source_sc_utf16le_sha256": "6A7159B2E494BA5DBC955EF4C715F889BFEC6353B30FD2F287C7AD05D5EE896D"
    },
    {
      "block_id": 7,
      "ko": "에게 이겼구나!\n내가 얕본 세력은",
      "literal_id": 1,
      "record_id": 973,
      "source_sc_utf16le_sha256": "2E51B0EAC3D92F7AD2751FB5E54319FEDDC0CF8CBB9D0BFF6EF034F3AA28B4C2"
    },
    {
      "block_id": 7,
      "ko": "도 당대의 패자인가……\n",
      "literal_id": 1,
