    "contains_complete_game_resource": false
  },
  "entries": [
    {
      "block_id": 6,
      "ko": "출진 전까지 영내를 발전시키겠습니다.",
      "literal_id": 2,
      "record_id": 4196,
      "source_sc_utf16le_sha256": "51244F862DF1C54D86253F7077EC65D35CA0AC5C5BC2956C21125530B28BE2EB"
    },
    {
      "block_id": 6,
      "ko": "주명을 받들어 가중의 의견을 모았습니다.\n실행할 만한 제안이 있는 듯하니,\n확인 후 결정해 주십시오.",
      "literal_id": 0,
      "record_id": 4199,
      "source_sc_utf16le_sha256": "1C9D6FA7799A1C3AF8B8DF63345D5A1CE885FDEC0DC05185B3CD892EE711209B"
    },
    {
      "block_id": 6,
      "ko": "주명을 가중에 알렸더니,\n방침에 맞는 제안이 나온 듯합니다.\n승인 여부를 확인해 주십시오.",
      "literal_id": 0,
      "record_id": 4200,
      "source_sc_utf16le_sha256": "F630F8BB2A9EBF7BABAA97160E5AD7A151D9C997B9B8727191850CE776058844"
    },
    {
      "block_id": 6,
      "ko": "주명을 받들어 가중의 의견을 모았으나,\n실행할 만한 제안이 없는 듯합니다.\n힘이 미치지 못해 면목이 없습니다…",
      "literal_id": 0,
      "record_id": 4202,
      "source_sc_utf16le_sha256": "884A57D1DF394B2A987A7E7C41A4650733361184C2ED7F608A1C1484A0F27286"
    },
    {
      "block_id": 6,
      "ko": "명을 받들겠습니다.\n반드시 주명에 걸맞은 성과를\n당가에 가져오겠습니다.",
      "literal_id": 0,
      "record_id": 4205,
      "source_sc_utf16le_sha256": "0B93F81184596C741A85B28783A13E94A22474C158C47844BE6CC3D672E14AD9"
    },
    {
      "block_id": 6,
      "ko": "예, 명을 받들어,\n당가를 위해 주명 완수에 전력을 다하겠습니다.",
      "literal_id": 0,
      "record_id": 4206,
      "source_sc_utf16le_sha256": "44A0B8F5985C63D7DF1BA8ED2572FC957F9B7CDCFEBA0BAEE1B99A592D515352"
    },
    {
      "block_id": 6,
      "ko": "겠습니다.\n공을 세운 자에게는 큰 포상을 내리니,\n모두 힘써 주십시오.",
      "literal_id": 1,
      "record_id": 4207,
      "source_sc_utf16le_sha256": "08929920E9DC4139951CFC3B52B1D5859CE9A803D39FEE47B7F741DA1DE1FE3F"
    },
    {
      "block_id": 6,
      "ko": "적성 조략의 뜻을 각 성주에게 전하자,\n다음 성에 관한 구체안이 나왔습니다.\n어느 성주의 책략을 실행할지 지시해 주십시오.",
      "literal_id": 0,
      "record_id": 4208,
      "source_sc_utf16le_sha256": "E4D1CF4B5991A2F74D6FC9A9A7AC4814E2C8BBCBC2D9310E87A05B1287695598"
    },
    {
      "block_id": 6,
      "ko": "영내 여러 책략의 뜻을 각 성주에게 전하자,\n다음 성에 관한 구체안이 나왔습니다.\n어느 성을 강화할지 지시해 주십시오.",
      "literal_id": 0,
      "record_id": 4209,
      "source_sc_utf16le_sha256": "895F97AB6A987208205E49558F1D2ED338A417986855903A270171C7E58F495E"
    },
    {
      "block_id": 6,
      "ko": "대상 성에 내린 명령을 취소하시겠습니까?",
      "literal_id": 0,
      "record_id": 4211,
      "source_sc_utf16le_sha256": "2D22A1A8EC162B567B464FB1682036FB88D68374A00D3BBDF89011A583504E03"
    },
    {
      "block_id": 6,
      "ko": "조정과 교섭 중인 무장을 해임하시겠습니까?",
      "literal_id": 0,
      "record_id": 4249,
      "source_sc_utf16le_sha256": "195266B5089B7380ABFCBC04FC3FB50195D3DA27A2E29B6956D6740ADF522390"
    },
    {
      "block_id": 6,
      "ko": "조정과의 교섭을 중단했습니다.",
      "literal_id": 0,
      "record_id": 4251,
      "source_sc_utf16le_sha256": "AC3D4A840072C06054E91A1B2B0B65824B6ED92A4D19CCE439F797E9DDF2EBDC"
    },
    {
      "block_id": 6,
      "ko": "의 영주로 임명합니다.\n성 능력: 통",
      "literal_id": 2,
      "record_id": 4257,
      "source_sc_utf16le_sha256": "F4CCCE1335C6C48D01102460FBE8EE4D3A098F6EC08137271F980EFD44346F01"
    },
    {
      "block_id": 6,
      "ko": "바람처럼 전장을 내달리자!\n이제",
      "literal_id": 0,
      "record_id": 4323,
      "source_sc_utf16le_sha256": "FDB4B92887B731568D34C9DE6309D5C3731AD7E96A909356674DFCCB108CAE0C"
    },
    {
      "block_id": 6,
      "ko": "발령 준비에 착수하겠습니다.",
      "literal_id": 1,
      "record_id": 4384,
      "source_sc_utf16le_sha256": "E7A23AA04A36EEBEA127032C946223664EFF42BD4C28874D81C09FFE796E114C"
    },
    {
      "block_id": 6,
      "ko": "명을 받들겠습니다.\n즉시",
      "literal_id": 0,
      "record_id": 4387,
      "source_sc_utf16le_sha256": "B2DF580365EAF8390A1E654B0213EA23D7A2C472094BC331B50AE6A1BFC48AF1"
    },
    {
      "block_id": 6,
      "ko": "의 발령을 이루겠습니다.",
      "literal_id": 1,
      "record_id": 4388,
      "source_sc_utf16le_sha256": "B23F214413E23FBE85F486FC6330E46840A866118B1F4C7BE2FD6EB1E00E540B"
    },
    {
      "block_id": 6,
      "ko": "의 발령은 훌륭한 방안입니다.\n즉시 준비에 착수합시다.",
      "literal_id": 0,
      "record_id": 4389,
      "source_sc_utf16le_sha256": "1ED891F46BAC5FE1B3ABEB2CD9C0F3FADA6FC2FF14B92B8E5AA3FF190EB245B9"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n다른 가문보다 앞서기 위해,\n서둘러",
      "literal_id": 0,
      "record_id": 4395,
      "source_sc_utf16le_sha256": "4CC2D2B1502EDF11DF75020DFBAF8FD872CC8AE6BE28C5D247DA4E91B2A1EFE9"
    },
    {
      "block_id": 6,
      "ko": "의 개량에 착수하겠습니다.",
      "literal_id": 1,
      "record_id": 4395,
      "source_sc_utf16le_sha256": "2107703C7CA36CB8FF60DC3F21887EC6C19DE9A6887E1CF63ED4C852578CF837"
    },
    {
      "block_id": 6,
      "ko": "동맹을 맺은 당가를 경계하여,\n상대",
      "literal_id": 0,
      "record_id": 4402,
      "source_sc_utf16le_sha256": "6C8CDF1CF549FCF90444087D892360AC752199C661933B2DBEBA6A982E87931E"
    },
    {
      "block_id": 6,
      "ko": "동맹을 맺은 당가를 경계하여,\n관련",
      "literal_id": 0,
      "record_id": 4403,
      "source_sc_utf16le_sha256": "6C8CDF1CF549FCF90444087D892360AC752199C661933B2DBEBA6A982E87931E"
    },
    {
      "block_id": 6,
      "ko": "동맹을 맺은 당가를 경계하여,\n상대",
      "literal_id": 0,
      "record_id": 4404,
      "source_sc_utf16le_sha256": "6C8CDF1CF549FCF90444087D892360AC752199C661933B2DBEBA6A982E87931E"
    },
    {
      "block_id": 6,
      "ko": "동맹을 맺은 당가를 경계하여,\n관련",
      "literal_id": 0,
      "record_id": 4405,
      "source_sc_utf16le_sha256": "6C8CDF1CF549FCF90444087D892360AC752199C661933B2DBEBA6A982E87931E"
    },
    {
      "block_id": 6,
      "ko": "님께 더 많은 영지를 내리면,\n그 영지가 더욱 번영할 것입니다.",
      "literal_id": 1,
      "record_id": 4409,
      "source_sc_utf16le_sha256": "631376B720A23E487FF7403102583FE571FF6D340D0F9DCC016E0577A1D988E2"
    },
    {
      "block_id": 6,
      "ko": "개의 맡길 수 있는 군이 있습니다.\n이를",
      "literal_id": 3,
      "record_id": 4411,
      "source_sc_utf16le_sha256": "0E2C087ED6B26A75B9BD93070A88AB7022F034A7188CF7D130C6289731F39406"
    },
    {
      "block_id": 6,
      "ko": "승진한 성주에게 영지를 더 내리면,\n그 땅도 더욱 번영할 것입니다.\n군다이가 다스리는 영지를 맡겨 보시겠습니까?",
      "literal_id": 0,
      "record_id": 4412,
      "source_sc_utf16le_sha256": "B89300FA1CDBEB4898DB17C1B204C8A4C1B9D6B59F34F426732D395701A9256A"
    },
    {
      "block_id": 6,
      "ko": "명을 받들겠습니다. 필요하다면,\n“지행”에서 다시 명령해 주십시오.",
      "literal_id": 0,
      "record_id": 4418,
      "source_sc_utf16le_sha256": "44D099D4FDEC0868D8FFF044CB53DA9EBD37C8F4F1A2207A9BB49B3281C67310"
    },
    {
      "block_id": 6,
      "ko": "이 당가에서 독립했습니다.\n이후",
      "literal_id": 1,
      "record_id": 4419,
      "source_sc_utf16le_sha256": "E7831E8687B7B94D95AF79041A23A0C9A2B4E39523A5D223F76907944F5FFCB1"
    },
    {
      "block_id": 6,
      "ko": "에서 독립했습니다.\n이후",
      "literal_id": 1,
      "record_id": 4420,
      "source_sc_utf16le_sha256": "9B46EBE27FC57791EB88E89B214E08DE5E9774AA2DEB5B4024A5C4CFEBD5C405"
    },
    {
      "block_id": 6,
      "ko": "판단을 내리기 어렵습니다.\n방침을 지시해 주신다면,\n정책 “",
      "literal_id": 0,
      "record_id": 4424,
      "source_sc_utf16le_sha256": "5115153132A682B0FC1BE56C7390B9C3ABADD26A0FA9573C314136627E9A5540"
    },
    {
      "block_id": 6,
      "ko": "”을 재검토하겠습니다…",
      "literal_id": 1,
      "record_id": 4424,
      "source_sc_utf16le_sha256": "44EEE611DB57C521CC257EFE9B52FC715046ECD1D26448C43F61C54CA8C67953"
    },
    {
      "block_id": 6,
      "ko": "의 성하에는,\n그 방침에 능한 장수가 없습니다.\n인원 배치를 다시 검토해 주십시오.",
      "literal_id": 0,
      "record_id": 4425,
      "source_sc_utf16le_sha256": "68A9A3BCF2B1B648C4C6939B2006742FCCDFEFB0A1E1440D590BBFBEC5F4C5B7"
    },
    {
      "block_id": 6,
      "ko": "현재 인원이 부족하여,\n진행하기 어려울 듯합니다.",
      "literal_id": 0,
      "record_id": 4427,
      "source_sc_utf16le_sha256": "C9796021933D8113C71C49BCB4D735E7F092C1CCC9611B22EE2A43FB72B2B25C"
    },
    {
      "block_id": 6,
      "ko": "좋은 제안이라고 생각합니다.\n현재",
      "literal_id": 0,
      "record_id": 4428,
      "source_sc_utf16le_sha256": "89A0A2223F5926F7211E258A0711AC5EB4D3484C847FDCA8516F32303C0342D6"
    },
    {
      "block_id": 6,
      "ko": "를 보여 줄 때입니다.\n성과를 기대해 주십시오.",
      "literal_id": 1,
      "record_id": 4430,
      "source_sc_utf16le_sha256": "1E27CD34DB47BD60AEC40DA5F2E9A384182ED3B102FBF610F5903A2F8666F3AF"
    },
    {
      "block_id": 6,
      "ko": "있으니,\n문제없이 완수할 수 있습니다.",
      "literal_id": 1,
      "record_id": 4431,
      "source_sc_utf16le_sha256": "338ABDC8CA63B080BFE8CA7C81C3A75BCD9E493988C4B171FC006EDC33B4078D"
    },
    {
      "block_id": 6,
      "ko": "우리 성에는 건설에 능한 자가 있어,\n정책 「",
      "literal_id": 0,
      "record_id": 4433,
      "source_sc_utf16le_sha256": "673FC6C63B2186B02D26A8E379837706631F543165C5353499375E23C8A595B8"
    },
    {
      "block_id": 6,
      "ko": "」 발령 뒤,\n다음",
      "literal_id": 1,
      "record_id": 4433,
      "source_sc_utf16le_sha256": "7B4CAFE2AE93BE051CDE78204A1716590FA5842DEA342ECFD74D3699CDD4972C"
    },
    {
      "block_id": 6,
      "ko": "성하의 석고를 늘리면,\n다음",
      "literal_id": 0,
      "record_id": 4436,
      "source_sc_utf16le_sha256": "CCD47C78F37B05764B97E5996388FB8FA64FF22F8ACA948EC1FCF3793F77C490"
    },
    {
      "block_id": 6,
      "ko": "도 세울 수 있습니다.",
      "literal_id": 1,
      "record_id": 4436,
      "source_sc_utf16le_sha256": "8566533E41CF089CEE81EE1605B7027003270733AAEC1E484EBC087C5569C224"
    },
    {
      "block_id": 6,
      "ko": "제게 맡겨 주십시오.\n훌륭한 성하를 만들겠습니다.",
      "literal_id": 0,
      "record_id": 4438,
      "source_sc_utf16le_sha256": "EBD98E2C1F95CB54E38A16791D8EFDF1406C56803E97E29D21FA4C96F1E03268"
    },
    {
      "block_id": 6,
      "ko": "\n모두 전력을 다하겠습니다.",
      "literal_id": 1,
      "record_id": 4439,
      "source_sc_utf16le_sha256": "CEFFE0DF1FD1245B03295EE0B91557ED794ABA5C5271DF89ED7C8A3F0C0B8274"
    },
    {
      "block_id": 6,
      "ko": "방침을 받들었습니다.\n이제 실현하기만 하면 됩니다.",
      "literal_id": 0,
      "record_id": 4440,
      "source_sc_utf16le_sha256": "43292B117B9BDDD7950BAD2BB7340E06AB897BA49C6F04E446F1B4A3A3C6F8FA"
    },
    {
      "block_id": 6,
      "ko": "명을 받들겠습니다.\n임무와 전투가 끝나는 대로,\n착수하겠습니다.",
      "literal_id": 0,
      "record_id": 4442,
      "source_sc_utf16le_sha256": "5D027D420ABFD5C54EBB1D7F0F7A2E7AA07E6A5945188ACC680B33B5CE434BF8"
    },
    {
      "block_id": 6,
      "ko": "명을 받들겠습니다.\n전투에서 돌아오는 대로,\n착수하겠습니다.",
      "literal_id": 0,
      "record_id": 4443,
      "source_sc_utf16le_sha256": "3AD5736569ADEA768298690B57494F009851167F08433D5A0B11856BEEBC0FFA"
    },
    {
      "block_id": 6,
      "ko": "명을 받들겠습니다.\n임무가 끝나는 대로,\n착수하겠습니다.",
      "literal_id": 0,
      "record_id": 4444,
      "source_sc_utf16le_sha256": "74C62BEC5558FF43308426381CD2BBB20E4F7A4993DD7C15D5CE1C92E343DD71"
    },
    {
      "block_id": 6,
      "ko": "님이\n다스리는",
      "literal_id": 1,
      "record_id": 4445,
      "source_sc_utf16le_sha256": "74D17BFA0E26FC9BA971EFA521B9D2799788BBAD60BBB66DB1B488C32C18312A"
    },
    {
      "block_id": 6,
      "ko": "주십시오.\n적의 어떤 조략도\n막아 보이겠습니다.",
      "literal_id": 1,
      "record_id": 4450,
      "source_sc_utf16le_sha256": "A1A29EB946E94864BB95606753F463A33BF0D6FE24029F20EBEA71AAF6AC1899"
    },
    {
      "block_id": 6,
      "ko": "방비를 강화해야 할 땅이니,\n아무래도",
      "literal_id": 0,
      "record_id": 4451,
      "source_sc_utf16le_sha256": "9E8CF57E68CB8181765A9833B7F3E4A46B63E6559D7CDE830AD30E5FDA806B15"
    },
    {
      "block_id": 6,
      "ko": "전선이라니, 솜씨를 보일 기회로군요.\n저를",
      "literal_id": 0,
      "record_id": 4453,
      "source_sc_utf16le_sha256": "FAA69AAC9166A4765895527E0329760D1F1C47B753302D4291E9C2057F02C6B9"
    },
    {
      "block_id": 6,
      "ko": "배속한다면,\n부대 방비 강화에 공헌하겠습니다.",
      "literal_id": 1,
      "record_id": 4453,
      "source_sc_utf16le_sha256": "2DDD3ECCEF50960255B5405C033B2CDF9AAA66D340AC51AFD1AA454A08F4C651"
    },
    {
      "block_id": 6,
      "ko": "과연, 제 창 솜씨를 눈여겨보셨군요.\n하지만… 인선은 다시 검토해 주십시오.",
      "literal_id": 0,
      "record_id": 4454,
      "source_sc_utf16le_sha256": "FC4DAB8F98DBB290167B59431E0E90995DBE4D651AB009372BCDBEE010004732"
    },
    {
      "block_id": 6,
      "ko": "설마,",
      "literal_id": 0,
      "record_id": 4455,
      "source_sc_utf16le_sha256": "EA8F8E33538911C3A2F79A7A53485944896DD4275B90CF993B83542C5322DB75"
    },
    {
      "block_id": 6,
      "ko": "라니, 바라던 바입니다!\n부디 제게 맡겨,\n무공을 세우게 해 주십시오!",
      "literal_id": 1,
      "record_id": 4455,
      "source_sc_utf16le_sha256": "D0106F6CA2028F48C2105EA1C47826161227D7983C2E37EE495E3D474583F406"
    },
    {
      "block_id": 6,
      "ko": "을 맡겨 주십시오.\n포위전으로 성을 공격한다면,\n",
      "literal_id": 1,
      "record_id": 4458,
      "source_sc_utf16le_sha256": "3A0E40B2847F7507F4CA92D3F36AB4B2BDDB9FC004B03E900A3AB1AC255A719C"
    },
    {
      "block_id": 6,
      "ko": "을 배속해 주십시오.",
      "literal_id": 1,
      "record_id": 4461,
      "source_sc_utf16le_sha256": "885C3E10EEEC4675FC40EE6CEE342389975BF67F756A2CD3DA15DEDF7FC1D8B8"
    },
    {
      "block_id": 6,
      "ko": "부디 배속을 명해 주십시오.\n그 성에는,",
      "literal_id": 0,
      "record_id": 4464,
      "source_sc_utf16le_sha256": "A2762365F86F4F66DEC3CD2C511DCF66097EE749AE730BEF9146B736C2874952"
    },
    {
      "block_id": 6,
      "ko": "에는\n아마,",
      "literal_id": 1,
      "record_id": 4465,
      "source_sc_utf16le_sha256": "61357268BE9A1DA5A0D2E88E4B6EDC2BD0A2EC6D5DA7C3A1E5666D716F8DE1ED"
    },
    {
      "block_id": 6,
      "ko": "나와 같은 특성을 지닌 동료가\n성 안에 있는 듯합니다.\n제 강점을 발휘할 수 있겠습니다.",
      "literal_id": 0,
      "record_id": 4466,
      "source_sc_utf16le_sha256": "14D5ECDA712D497B22F27970F4DC328412CA9688D620DB97305D9EC053930C29"
    },
    {
      "block_id": 6,
      "ko": "제 특성은 전선에서 빛을 발합니다…\n그렇지만 가능하다면,\n부디,",
      "literal_id": 0,
      "record_id": 4467,
      "source_sc_utf16le_sha256": "02A437F3072A3F43A310A286DB0B08EA98239DC3FD0780CB285CA5D09E3E35AF"
    },
    {
      "block_id": 6,
      "ko": "에게 맡겨 주십시오!\n",
      "literal_id": 1,
      "record_id": 4472,
      "source_sc_utf16le_sha256": "1234D1D3D0B17033D3EC1A67D4665C8D99C68C3FEE5D8AD89E2E44AEC4B90BFB"
    },
    {
      "block_id": 6,
      "ko": "적지에 접한 땅이라면,\n제 조략 솜씨를 보일 기회가 있을지도 모릅니다.",
      "literal_id": 0,
      "record_id": 4473,
      "source_sc_utf16le_sha256": "52AA851F3CCAE3C2ACC53BB2646424ADCF18AB555D6C3DE410F56EACB34B64EF"
    },
    {
      "block_id": 6,
      "ko": "취락 장악 진척이 더디군요.\n확실히,",
      "literal_id": 0,
      "record_id": 4474,
      "source_sc_utf16le_sha256": "D29A798E818320C8A3D505977BB96072B158067FB96EFF838C990A5C063F0E63"
    },
    {
      "block_id": 6,
      "ko": "은 장악에 능하지만,\n다른 인선을 찾아 주시기를 바랍니다…",
      "literal_id": 1,
      "record_id": 4474,
      "source_sc_utf16le_sha256": "0234BFC910B5BCA8E0697A53DD24D46174FF0F0DC216BFD7DCE43FE5DB54FEFC"
    },
    {
      "block_id": 6,
      "ko": "성민의 사기를 높이는 일은,\n분명 제 장기입니다만…\n다만,",
      "literal_id": 0,
      "record_id": 4478,
      "source_sc_utf16le_sha256": "4A16280F1DFB13925EA73CE23762AF29E663A26F6DE5E7B58BD1ADB05982E0DA"
    },
    {
      "block_id": 6,
      "ko": "에게 맡겨 주십시오.\n성민의 사기를 높여,\n전력을 크게 끌어올리겠습니다.",
      "literal_id": 1,
      "record_id": 4479,
      "source_sc_utf16le_sha256": "439012240F36298A82D647B4A8395EFB1C73258120121232DF360B5701D4B4B3"
    },
    {
      "block_id": 6,
      "ko": "\n와는 분명 마음이 잘 맞습니다만…",
      "literal_id": 1,
      "record_id": 4481,
      "source_sc_utf16le_sha256": "5FA0D1F0730EF23978CA0E3217B8F97FD358C82EAA0881C865705A17CE741F54"
    }
  ],
