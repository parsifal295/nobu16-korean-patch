  "entries": [
    {
      "block_id": 6,
      "ko": "신용을 소모해 동맹·원군 교섭을 진행합니다.",
      "literal_id": 0,
      "record_id": 4057,
      "source_sc_utf16le_sha256": "32D0C6F14AFBC9942BF87E3CE727BFEBCFAD69A1A59D7AC2DE4998B599DADE3A"
    },
    {
      "block_id": 6,
      "ko": "상대 세력과 정전을 교섭합니다.",
      "literal_id": 0,
      "record_id": 4813,
      "source_sc_utf16le_sha256": "DE54FA69C807ACA2965A7CDC39C6C127065829539363AEE9DAC1B8E2C1496450"
    },
    {
      "block_id": 6,
      "ko": "가보 등을 건네 외교 자세를 개선합니다.",
      "literal_id": 0,
      "record_id": 4814,
      "source_sc_utf16le_sha256": "2D1BD834B62A71407EF5EC410A9BA7B0670D286B8320DA54824BFE747D2FD9A6"
    },
    {
      "block_id": 6,
      "ko": "정전할 상대가 없습니다.",
      "literal_id": 0,
      "record_id": 4815,
      "source_sc_utf16le_sha256": "CB79E42236B7E8003A4CB01E4456FC0DC91E856A7A6F0A37B8A31001B1BFE566"
    },
    {
      "block_id": 6,
      "ko": "이전 정전 교섭 후 얼마 지나지 않아 상대가 응하지 않습니다.",
      "literal_id": 0,
      "record_id": 4816,
      "source_sc_utf16le_sha256": "CA19B5F728B345401F91C1117D7C69C4ACD06CFEFECC3B740CB8AC901098B39A"
    },
    {
      "block_id": 6,
      "ko": "정전 제안을 무시당하고 있습니다.",
      "literal_id": 0,
      "record_id": 4817,
      "source_sc_utf16le_sha256": "3044FC6FF2195A49DF71E3097507828F91AE7CAC6AB1ECDFC72BAA22502B29FA"
    },
    {
      "block_id": 6,
      "ko": "정전 교섭을 해도 성공하기 어려울 것입니다.",
      "literal_id": 0,
      "record_id": 4818,
      "source_sc_utf16le_sha256": "17BF28B4166769716AA57523F284C04CD7BD6998FDBE27DC855ACDD4FAFA3B71"
    },
    {
      "block_id": 6,
      "ko": "종속 세력 외에는 공물을 줄 수 없습니다.",
      "literal_id": 0,
      "record_id": 4819,
      "source_sc_utf16le_sha256": "B0FD8DD2BE339366833197E14F44C0D8336343652077A61D8E3B84C1C1DA4FA5"
    },
    {
      "block_id": 6,
      "ko": "다른 가문에 종속된 세력에는 공물을 줄 수 없습니다.",
      "literal_id": 0,
      "record_id": 4820,
      "source_sc_utf16le_sha256": "176B996CA89A2160391BDB5DB1A9DF725EFBF68590402754AEBB8F3F0A99B748"
    },
    {
      "block_id": 6,
      "ko": "쇼군 가문 이외의 먼 세력에는 공물을 줄 수 없습니다.",
      "literal_id": 0,
      "record_id": 4821,
      "source_sc_utf16le_sha256": "94A043262AFCD80D9326117F4E93BADF7D815D461237B9B216C8C4D2D8C5325D"
    },
    {
      "block_id": 6,
      "ko": "교전 중인 세력에는 공물을 줄 수 없습니다.",
      "literal_id": 0,
      "record_id": 4822,
      "source_sc_utf16le_sha256": "09BC39986BC3F2A0E753D62EFA861FA750B5A1C99E2261EA878C62B37EF6F717"
    },
    {
      "block_id": 6,
      "ko": "최근 공물을 바친 지 얼마 되지 않아 효과가 없을 것입니다.",
      "literal_id": 0,
      "record_id": 4824,
      "source_sc_utf16le_sha256": "9A4181EA99DBBAD12D892563D64E982C1600438497FC0CD837DD3862D6588467"
    },
    {
      "block_id": 6,
      "ko": "상대의 외교 자세는 더 이상 개선되지 않습니다.",
      "literal_id": 0,
      "record_id": 4825,
      "source_sc_utf16le_sha256": "C942ADC6FAAB34AEB134684E743AF8FF4CF8E8EA4F93FC088F3C90BD54C4961C"
    },
    {
      "block_id": 6,
      "ko": "외교 자세를 바꿀 만큼 줄 공물이 없습니다.",
      "literal_id": 0,
      "record_id": 4826,
      "source_sc_utf16le_sha256": "3EBA592471874B72A73E54680BC467A427570156EF178008B11B4B24FFC42DF9"
    },
    {
      "block_id": 6,
      "ko": "적의 침공에 대비해\n성의 방어를 강화하는 것도 방법입니다.",
      "literal_id": 0,
      "record_id": 4831,
      "source_sc_utf16le_sha256": "C6CEF653F953071B9AA13068B66DDF7A78D7331AACB2DEEF2BA428C3B9246FFF"
    },
    {
      "block_id": 6,
      "ko": "부대에 휴대 군량을 보급할 성을 선택하십시오.",
      "literal_id": 0,
      "record_id": 4834,
      "source_sc_utf16le_sha256": "FD9FD8926323754BB002AD744C2A1A14846C1893B14CE1E215F418DE200E163F"
    },
    {
      "block_id": 6,
      "ko": "방어를 강화할 성을 선택하십시오.",
      "literal_id": 0,
      "record_id": 4849,
      "source_sc_utf16le_sha256": "70983EF8E501CFEDEE1F2CBB067C59F0B2454067F64B316D57B3A59692A301E6"
    },
    {
      "block_id": 6,
      "ko": "칭찬할 공적을 선택하십시오.",
      "literal_id": 0,
      "record_id": 4869,
      "source_sc_utf16le_sha256": "34B86CD090AF1EA2EBBB943F03A05B8EC66FF03F60E14A8874FC84BBBFB26631"
    },
    {
      "block_id": 6,
      "ko": "필요한 공적이 부족합니다.",
      "literal_id": 0,
      "record_id": 4870,
      "source_sc_utf16le_sha256": "EE4C09177A42013DF625F438F5EAA7C719379867376575EA6A83BDF356904B6A"
    },
    {
      "block_id": 6,
      "ko": "감장이 없습니다.",
      "literal_id": 0,
      "record_id": 4871,
      "source_sc_utf16le_sha256": "25B923AC017B80CBE9DC61F17367EE66A5BF8A8190E9877405A0D36535115206"
    },
    {
      "block_id": 6,
      "ko": "현재 별호와 다른 공적은 선택할 수 없습니다.",
      "literal_id": 0,
      "record_id": 4872,
      "source_sc_utf16le_sha256": "1E9768302C561F033C0CA22CAA198E330FD26E5A7E5F0C6B14FCED615F6B7A2E"
    },
    {
      "block_id": 6,
      "ko": "별호를 정하면 다른 공적의\n별호를 사용할 수 없습니다.\n계속하시겠습니까?",
      "literal_id": 0,
      "record_id": 4873,
      "source_sc_utf16le_sha256": "993F81D4D394C1594EB29A5E433CF4B5478EF43B02975B8177B771C5F6C0EA7E"
    },
    {
      "block_id": 6,
      "ko": "별호를 더 사용할 수 없습니다.",
      "literal_id": 0,
      "record_id": 4874,
      "source_sc_utf16le_sha256": "DF01E27E51061B53F2FBFAAB1B68AEEDBAF6538B8E001758FE6E2A1B04D737A8"
    },
    {
      "block_id": 6,
      "ko": "인정할 공적과 수여할 감장을 선택하십시오.\n※이후에는 선택한 공적의 별호만 사용할 수 있습니다.",
      "literal_id": 0,
      "record_id": 4875,
      "source_sc_utf16le_sha256": "B10C941E17DBF44EEB9F62F0F302734DE5B14A81D236E5607F30FE92737E9DB2"
    },
    {
      "block_id": 6,
      "ko": "감장을 줄 수 있는 무장이 없습니다.",
      "literal_id": 0,
      "record_id": 4877,
      "source_sc_utf16le_sha256": "1795142730871B1C1A1CFA88D1D8BC2331F2CBCC4E49C427EA4C0AB9DEB42A6A"
    },
    {
      "block_id": 6,
      "ko": "별호가 있는 무장에게 감장을 일괄 수여합니다.",
      "literal_id": 0,
      "record_id": 4878,
      "source_sc_utf16le_sha256": "D1870A46373A0ED4161274913718748BCE5356B4751030AC42282AC7E97133A1"
    },
    {
      "block_id": 6,
      "ko": "별호 보유 무장에게 감장을 일괄 수여 가능합니다.",
      "literal_id": 0,
      "record_id": 4879,
      "source_sc_utf16le_sha256": "E5FACDFD15B251D5361D1C0402F335D215C6D5FE0203BF592A531C7901044B1D"
    },
    {
      "block_id": 6,
      "ko": "이 정책을 발령하면 상업이 감소합니다.\n계속하시겠습니까?",
      "literal_id": 0,
      "record_id": 4905,
      "source_sc_utf16le_sha256": "8386144313DFC041886C25EC1F11B730C947AB19CEC3C1FAD0721D1B41082960"
    },
    {
      "block_id": 6,
      "ko": "신용이 이미 최대치에 도달했습니다.",
      "literal_id": 0,
      "record_id": 4906,
      "source_sc_utf16le_sha256": "DA2047AF6C49948483B118E9680BE23FADEFCE587AFEC00A02905907E61BAA6F"
    },
    {
      "block_id": 6,
      "ko": "원군 교섭에 필요한 신용입니다.",
      "literal_id": 0,
      "record_id": 4909,
      "source_sc_utf16le_sha256": "12A7EB64BC0FB9CD94917EB354BBB1AD3859F8A253BD81A45D89F72009D63F73"
    },
    {
      "block_id": 6,
      "ko": "혼인 동맹·중개 교섭에 필요한 신용입니다.",
      "literal_id": 0,
      "record_id": 4910,
      "source_sc_utf16le_sha256": "1967622EF31D98294130AF856D4685535BBAD1D5866461BC83EEED1B730F8F14"
    },
    {
      "block_id": 6,
      "ko": "혼인 동맹·중개·직책 교섭에 필요한 신용입니다.",
      "literal_id": 0,
      "record_id": 4911,
      "source_sc_utf16le_sha256": "0644837CA4401374616DD2961BD1B5AB603FE28DBE9AFF1A70FDAF16716F3D5C"
    },
    {
      "block_id": 6,
      "ko": "외교 자세가 변하지 않으므로 줄 수 없습니다.",
      "literal_id": 0,
      "record_id": 4919,
      "source_sc_utf16le_sha256": "2A5A172CBA4E9782E3377D7E8C8CE61D4AE1B99A919FF7A1CFFC940A43A19BFA"
    },
    {
      "block_id": 7,
      "ko": "방위 거점은 적의 요격을 준비 중이어서\n출진 병력을 충분히 낼 수 없습니다.\n출진할 때 주의하십시오.",
      "literal_id": 0,
      "record_id": 2453,
      "source_sc_utf16le_sha256": "ACC35D99698C22AB1362A156CB2B82DBD017F5D26E4A4FA7153232167D4BD492"
    },
    {
      "block_id": 7,
      "ko": "목표로 새로 출진할 수 있는 부대가 없습니다.",
      "literal_id": 0,
      "record_id": 2486,
      "source_sc_utf16le_sha256": "9836A53BAB84BD8418894C8FA56CF9714314FB3FD41EEC8C4E1870BD20EAFC8C"
    },
    {
      "block_id": 9,
      "ko": "설비 발동 실패",
      "literal_id": 0,
      "record_id": 458,
      "source_sc_utf16le_sha256": "3B3858F8371BDDDF60B1C156288CAFB3B3AB8208A57F67A8A28EDD816D0EF38A"
    },
    {
      "block_id": 9,
      "ko": "적군 설비 발동 실패",
      "literal_id": 0,
      "record_id": 476,
      "source_sc_utf16le_sha256": "A95449A382483E48678AE17B89ABE92393792CD13AFAAF3935BDC235CCE44E9B"
    },
    {
      "block_id": 9,
      "ko": "설비를 제압해 아군 총사기가 상승",
      "literal_id": 0,
      "record_id": 495,
      "source_sc_utf16le_sha256": "744D189D373FBAC1F7F8D15ED03339DD86F624C39715BDC4AA71E4496888E5DC"
    },
    {
      "block_id": 9,
      "ko": "설비가 제압되어 아군 총사기가 하락",
      "literal_id": 0,
      "record_id": 497,
      "source_sc_utf16le_sha256": "C442932AB3F0B4D0BEA6AB77D1E1F2FDBF5309B003345ED0AE6909FD4F51FB0A"
    },
    {
      "block_id": 9,
      "ko": "본성을 파괴해 아군 총사기가 상승",
      "literal_id": 0,
      "record_id": 499,
      "source_sc_utf16le_sha256": "7E4806753069AAA08FF54D40DE5DCAC5ECB33A6B75F8E6912E5D33E453922257"
    },
    {
      "block_id": 9,
      "ko": "본성이 파괴되어 아군 총사기가 하락",
      "literal_id": 0,
      "record_id": 501,
      "source_sc_utf16le_sha256": "636FD1B472FECF23B6B2348A0F18A1943678B591157582C058823FA03C41377B"
    },
    {
      "block_id": 9,
      "ko": "아군 부대를 잃지 않고 모든 목표 달성",
      "literal_id": 0,
      "record_id": 4120,
      "source_sc_utf16le_sha256": "61EA4DEFAFD7B7098F1F0DA6A95D18222806461AEA7EF39AD553221DA297A7CF"
    },
    {
      "block_id": 12,
      "ko": "지방 통일 엔딩으로 게임을 종료합니다.\n다른 다이묘 가문과 지방으로 다시 즐겨 주십시오.",
      "literal_id": 0,
      "record_id": 44,
      "source_sc_utf16le_sha256": "0B66794300E3F45C8F48A0F8879A1950F7A40B3F46AB30748CE90FE9CAECA058"
    },
    {
      "block_id": 15,
      "ko": "주제넘은 말이었습니다.\n화면 아래 바로가기 버튼에서 공략 방침을\n언제든 설정할 수 있습니다.",
      "literal_id": 0,
      "record_id": 2378,
      "source_sc_utf16le_sha256": "F2A2EDC0B3F09271E4B7B3B3BE36403BE086B197FE741CC2A14378ADED853F1D"
    },
    {
      "block_id": 16,
      "ko": "성 수리는\n영내 제책에서 실행합니다.",
      "literal_id": 0,
      "record_id": 48,
      "source_sc_utf16le_sha256": "9EA29B54581A72ADB5FE82C25A4602A1A2C89564B6898CAE276C199573CA2075"
    },
    {
      "block_id": 17,
      "ko": "목표 2개 달성",
      "literal_id": 0,
      "record_id": 299,
      "source_sc_utf16le_sha256": "3E66FDC3F0B5C9F28543A838F6EE189AA9AF265B7CC5AB643CA659EC01A162AF"
    },
    {
      "block_id": 17,
      "ko": "아군 부대를 잃지 않고 목표 3개 달성",
      "literal_id": 0,
      "record_id": 466,
      "source_sc_utf16le_sha256": "CA72B465C2DC5853E4A3EC7B4839210C7860CAADA3ADB3B885D3106D2437BAB6"
    },
    {
      "block_id": 17,
      "ko": "기습 전에 모든 수비대와 교전",
      "literal_id": 0,
      "record_id": 561,
      "source_sc_utf16le_sha256": "C12D41A884C6B8E65085FA0C7DCDA7C5A0D4BD43AA0B2E5919B3649E3166F867"
    },
    {
      "block_id": 17,
      "ko": "적 선봉 부대 격퇴",
      "literal_id": 0,
      "record_id": 789,
      "source_sc_utf16le_sha256": "34A44171183E061DE25140F8DBF643AEDACE72F1B9E1F314A307EB94A802866D"
    },
    {
      "block_id": 17,
      "ko": "성문 제압 전에 적 부대 1개 격파",
      "literal_id": 0,
      "record_id": 1027,
      "source_sc_utf16le_sha256": "8E1F61D06331DF7634FCD88F884A480481AFB51A3BB683AC74C2A7495F497D53"
    },
    {
      "block_id": 17,
      "ko": "요충지 앞으로 나가지 않고 적 부대 6개 격파",
      "literal_id": 0,
      "record_id": 1092,
      "source_sc_utf16le_sha256": "2C34B5465848162F0E881626D4014A9DD75E98FC2A71A69C681556469BD2FE32"
    },
    {
      "block_id": 17,
      "ko": "요충지 사수",
      "literal_id": 0,
      "record_id": 1096,
      "source_sc_utf16le_sha256": "49A378C85E91DA18A44EEE2DC73D38D32E087C89E416B080DD82595C21DCB782"
    },
    {
      "block_id": 17,
      "ko": "적 부대 6개 격파",
