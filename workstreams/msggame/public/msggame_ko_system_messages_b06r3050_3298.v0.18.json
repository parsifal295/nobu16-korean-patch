      "literal_id": 0,
      "record_id": 3238,
      "source_sc_utf16le_sha256": "EACB89ABB6DDD64B6AD5749F7A8D7B60F76A421F00ACDFA4041BCF7C95A2D4C2"
    },
    {
      "block_id": 6,
      "ko": "이제 우리는 친척입니다\n함께 난세를 살아남읍시다",
      "literal_id": 0,
      "record_id": 3242,
      "source_sc_utf16le_sha256": "4F228F462DBE5467F6CB208D2FFCA50E99731F13E2F3400095057442938EE831"
    },
    {
      "block_id": 6,
      "ko": "믿을 수 없군…… 우리와 단교하다니 어리석다",
      "literal_id": 0,
      "record_id": 3248,
      "source_sc_utf16le_sha256": "16D9274F16093D66D05430D9985352E84256B5CC262D9DE882594C0A65DD702E"
    },
    {
      "block_id": 6,
      "ko": "그럴 수가!\n우리와 단교하겠다고!",
      "literal_id": 0,
      "record_id": 3249,
      "source_sc_utf16le_sha256": "C05982004A8C5A8457B3EE92885DB38E9A95F323A6E2BA6ECE96D59A5187D8AD"
    },
    {
      "block_id": 6,
      "ko": "뭐라고…… 우리와 단교하겠다는 건가?",
      "literal_id": 0,
      "record_id": 3250,
      "source_sc_utf16le_sha256": "AC46BD8B57F0CF90C71CE6449B9645D600FEE6F30E4A38D6A6C5970A7F4B03CD"
    },
    {
      "block_id": 6,
      "ko": "갑자기 단교하다니……",
      "literal_id": 0,
      "record_id": 3254,
      "source_sc_utf16le_sha256": "2DF028E0933749BF17C5961DE772BE95A4084B50C42AF82847DF42BA2BDD7966"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다\n공략 대상:",
      "literal_id": 0,
      "record_id": 3260,
      "source_sc_utf16le_sha256": "A502D0BE445F3A74BBCDCDD13F3A1B41F95BCE4E5F7B374F82FA2FED9A08E546"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다\n공략할 대상:",
      "literal_id": 0,
      "record_id": 3261,
      "source_sc_utf16le_sha256": "3A4CE66AEC10651E8C34462083527C42D6CE64D96BD5B7187AA750879389AFAB"
    },
    {
      "block_id": 6,
      "ko": ". 공격하겠습니다",
      "literal_id": 1,
      "record_id": 3261,
      "source_sc_utf16le_sha256": "79B1EC8F7B2C148A55C2223CD561BF75AEEE56A0B037DCF894D23C9D88C9BEE8"
    },
    {
      "block_id": 6,
      "ko": "알겠다\n함락할 대상:",
      "literal_id": 0,
      "record_id": 3262,
      "source_sc_utf16le_sha256": "3216F5F9A1227DFDFD693ABB813F7B2A6467C116231C8C8CF4E8CFE3F46F0F5D"
    },
    {
      "block_id": 6,
      "ko": ". 함락시키겠다",
      "literal_id": 1,
      "record_id": 3262,
      "source_sc_utf16le_sha256": "79B1EC8F7B2C148A55C2223CD561BF75AEEE56A0B037DCF894D23C9D88C9BEE8"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다\n공략할 대상:",
      "literal_id": 0,
      "record_id": 3266,
      "source_sc_utf16le_sha256": "DCD02033A17B281C9029E54F4D4BEEF1E8FD463058E1F226F03B3FB9C3F91A82"
    },
    {
      "block_id": 6,
      "ko": ". 이 정도는 손쉽습니다",
      "literal_id": 1,
      "record_id": 3266,
      "source_sc_utf16le_sha256": "360BCDE3A4EAFE7E96D28D0F36795FEDCF5AD88879A1816095F7F60AFA05FDFD"
    },
    {
      "block_id": 6,
      "ko": "알겠다\n전력을 다해 지킬 곳:",
      "literal_id": 0,
      "record_id": 3272,
      "source_sc_utf16le_sha256": "D70B12640C11FAC3B3C98011BF27D45A23FE5C9C41147DB7529BF7EDBD873B24"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다\n본가의 병력으로 지킬 곳:",
      "literal_id": 0,
      "record_id": 3273,
      "source_sc_utf16le_sha256": "780B858B9A4D4F6BE57D2655DF82AD3BDC5C97B38B362A1DBF0ADFCB594F4D6F"
    },
    {
      "block_id": 6,
      "ko": ". 방어하겠습니다",
      "literal_id": 1,
      "record_id": 3273,
      "source_sc_utf16le_sha256": "79B1EC8F7B2C148A55C2223CD561BF75AEEE56A0B037DCF894D23C9D88C9BEE8"
    },
    {
      "block_id": 6,
      "ko": "알겠다\n",
      "literal_id": 0,
      "record_id": 3274,
      "source_sc_utf16le_sha256": "22258DD33120127B6A54BEBD6F9DC8C55FCF35C40F2369A19E4F483512960A76"
    },
    {
      "block_id": 6,
      "ko": ": 우리가 지키겠다",
      "literal_id": 1,
      "record_id": 3274,
      "source_sc_utf16le_sha256": "F8086AFD8845D1136036287003B0356834C7EC8244D4A75B211810C56344D3FF"
    },
    {
      "block_id": 6,
      "ko": "어려울 때일수록 서로 도와야 합니다……\n방어할 곳:",
      "literal_id": 0,
      "record_id": 3278,
      "source_sc_utf16le_sha256": "D4D90FAE664F6A496C4FD56A474CA72CB40D13A5FCAD3D6D03C90AAF281A0719"
    },
    {
      "block_id": 6,
      "ko": ". 방어에 나서겠습니다",
      "literal_id": 1,
      "record_id": 3278,
      "source_sc_utf16le_sha256": "3EDCC4977F50F6013DFA60859F505C842F628956955AC9D0B98C8F34B2D1CF8B"
    },
    {
      "block_id": 6,
      "ko": "무용으로 이름난 귀가라면\n공략할 곳:",
      "literal_id": 0,
      "record_id": 3284,
      "source_sc_utf16le_sha256": "14A5B9DC6F3662E2A689B742055787ABE96CD7CA62B79A8F2BCC2D2A73062867"
    },
    {
      "block_id": 6,
      "ko": ". 어렵지 않을 것입니다",
      "literal_id": 1,
      "record_id": 3284,
      "source_sc_utf16le_sha256": "CA1C0EEF8D0E3DC9132ABC0F1394607881B3E2290E5189B0A1BD57E9DC692C4B"
    },
    {
      "block_id": 6,
      "ko": ": 공략을\n반드시 성공시켜 주십시오",
      "literal_id": 0,
      "record_id": 3285,
      "source_sc_utf16le_sha256": "28D5A6F5C21850A72DA6D7537FC7FAC17720FD35D74E4F41B61B75CEEF362744"
    },
    {
      "block_id": 6,
      "ko": ": 공략을\n부탁드립니다",
      "literal_id": 0,
      "record_id": 3286,
      "source_sc_utf16le_sha256": "185A4A70A6DF4484849D4696431C32B481A30589C199EC8201A0F23E22106556"
    },
    {
      "block_id": 6,
      "ko": "혼내 줄 상대:",
      "literal_id": 0,
      "record_id": 3290,
      "source_sc_utf16le_sha256": "F84D089770613C07522241A6E9624BE6018A2154F01D378EBEDC2A18A2707C7F"
    },
    {
      "block_id": 6,
      "ko": ".\n본때를 보여 주십시오",
      "literal_id": 1,
      "record_id": 3290,
      "source_sc_utf16le_sha256": "208CAD726A7C4992275ECDB082F7BE6673816349C70718AAA6662EFB4BF2910C"
    },
    {
      "block_id": 6,
      "ko": ": 우리의 요충지입니다\n반드시 지켜 주십시오",
      "literal_id": 0,
      "record_id": 3296,
      "source_sc_utf16le_sha256": "8E9C6102B4C2251383ED6D7ED6E1FE08702F66CD5716CD177932094151802332"
    },
    {
      "block_id": 6,
      "ko": ": 방어를\n반드시 완수해 주십시오",
      "literal_id": 0,
      "record_id": 3297,
      "source_sc_utf16le_sha256": "F04AE7EFA756D533476EC9A0BE62B4E6242B356B1B9F958A486ECBF3C0108212"
    },
    {
      "block_id": 6,
      "ko": ": 요지입니다\n반드시 지켜 주십시오",
      "literal_id": 0,
      "record_id": 3298,
      "source_sc_utf16le_sha256": "A7650DEA124A32338C36419302982B08C863260B61EA5FB96C58BBCC4134B430"
