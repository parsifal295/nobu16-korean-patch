      "record_id": 208,
      "source_sc_utf16le_sha256": "8B1B95F1FE69EF6A502EA174A2771F8C9FC953394378939CF2BC841C6F937ED5"
    },
    {
      "block_id": 2,
      "ko": "」에 취임했습니다. ",
      "literal_id": 1,
      "record_id": 208,
      "source_sc_utf16le_sha256": "C11111DD17290B6969B334CAAF304CEBB7A2E9E86B1EFC6EF2246A3B3500959D"
    },
    {
      "block_id": 2,
      "ko": "+",
      "literal_id": 2,
      "record_id": 208,
      "source_sc_utf16le_sha256": "206014A4266C2082B9433011FB2991059F972D570A8B3C976E5B2B8DFCFBFC8D"
    },
    {
      "block_id": 2,
      "ko": "의 건설 가능 칸이 늘었습니다.",
      "literal_id": 0,
      "record_id": 209,
      "source_sc_utf16le_sha256": "AEC63E925B628A5088B7305F49DBDCA663C2FEC7A2895CEC6F214C38449F1C36"
    },
    {
      "block_id": 2,
      "ko": "의 건설 가능 칸이 줄었습니다.",
      "literal_id": 0,
      "record_id": 210,
      "source_sc_utf16le_sha256": "3A16B0B204ED4AB3FC374CC4045B10F9AD3BE740D21FC949F3A6C48701CD2283"
    },
    {
      "block_id": 2,
      "ko": "내 힘을 똑똑히 보아라!",
      "literal_id": 0,
      "record_id": 211,
      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "백성을 다스리는 비결은 진심뿐이다.\n이 군은 내가 장악하겠다!",
      "literal_id": 0,
      "record_id": 212,
      "source_sc_utf16le_sha256": "70188FD1CD4823626A5AC65950BBD93A0C1B60D6EE4B8CF2F666E7F89371C6FD"
    },
    {
      "block_id": 2,
      "ko": "때가 왔다:",
      "literal_id": 0,
      "record_id": 213,
      "source_sc_utf16le_sha256": "93EF89A5B9CAC696E91A5656DB5D24D5863C187A724EE8FFDE0FFE3E6DFFDE02"
    },
    {
      "block_id": 2,
      "ko": "이(가) 쌓아 온 인맥을\n본가에 보탤 때가 온 모양이군.",
      "literal_id": 1,
      "record_id": 213,
      "source_sc_utf16le_sha256": "EDA0C558A8B60E8637B26C81B75DCB40FBAED8E9C031615E02D7A600CDCC853B"
    },
    {
      "block_id": 2,
      "ko": "인맥의 힘:",
      "literal_id": 0,
      "record_id": 214,
      "source_sc_utf16le_sha256": "1C360F406433BE6DCED2CCDDD1ADD18A88851A4B70063AF0ADED941D1AEBDA94"
    },
    {
      "block_id": 2,
      "ko": "이(가) 쌓아 온 인맥으로,\n보좌할 대상:",
      "literal_id": 1,
      "record_id": 214,
      "source_sc_utf16le_sha256": "809D48E4745E036BF5511318C27847DACD3A63627D032BC0370EDB2434312378"
    },
    {
      "block_id": 2,
      "ko": "의 움직임을 도와,\n본가에 새바람을 일으키자.",
      "literal_id": 2,
      "record_id": 214,
      "source_sc_utf16le_sha256": "216816DFA5CDE00FB89E76A2E8B81E864624A1BB136DE7A0DC8AC5F4538FEDC7"
    },
    {
      "block_id": 2,
      "ko": "사람을 쓰는 일에는 제법 자신이 있지……\n부하 지휘는 내게 맡겨라.",
      "literal_id": 0,
      "record_id": 215,
      "source_sc_utf16le_sha256": "48FC776555674DD0C23432A2EBEF9FFF2B01E07BCC83B1C17E8219FC09A6D82B"
    },
    {
      "block_id": 2,
      "ko": "말솜씨 하나는 자신 있다.\n내 언변으로 신뢰를 얻어 내지!",
      "literal_id": 0,
      "record_id": 216,
      "source_sc_utf16le_sha256": "BECE67D8B5E9245E427D6BA118D21F7856AD164A2C81E0576E134FE3C1826EDC"
    },
    {
      "block_id": 2,
      "ko": "언변으로 보좌할 대상:",
      "literal_id": 0,
      "record_id": 217,
      "source_sc_utf16le_sha256": "BEEC70C69FFA1F6D180615E54444E33AE1262AFF9C62035A11C3A5E0973DAB3E"
    },
    {
      "block_id": 2,
      "ko": ".\n반드시 신뢰를 얻어 내겠다!",
      "literal_id": 1,
      "record_id": 217,
      "source_sc_utf16le_sha256": "0C6B83F8F76D94142E5EAD4241022B3CCF4ADB364E6DA08DC9618FAAC1D7E189"
    }
  ],
