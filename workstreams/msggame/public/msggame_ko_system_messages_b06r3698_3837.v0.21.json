      "source_sc_utf16le_sha256": "08BC0FE16880833BF10C176F54BE5B6F9E371F0D252E04BF32BE063C9105AAFB"
    },
    {
      "block_id": 6,
      "ko": "의",
      "literal_id": 1,
      "record_id": 3800,
      "source_sc_utf16le_sha256": "26F49E51C62FA11E4FD7D754851317555EF7091B2925FC9517397FEE5871CC3D"
    },
    {
      "block_id": 6,
      "ko": "일은 제가 맡겠습니다.",
      "literal_id": 2,
      "record_id": 3800,
      "source_sc_utf16le_sha256": "4A7A2007FA3E6BA33FD3CC65BEA9147CD62BEBD90CA28A7402F21E3C3DD04F00"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다.\n",
      "literal_id": 0,
      "record_id": 3801,
      "source_sc_utf16le_sha256": "08BC0FE16880833BF10C176F54BE5B6F9E371F0D252E04BF32BE063C9105AAFB"
    },
    {
      "block_id": 6,
      "ko": "의",
      "literal_id": 1,
      "record_id": 3801,
      "source_sc_utf16le_sha256": "26F49E51C62FA11E4FD7D754851317555EF7091B2925FC9517397FEE5871CC3D"
    },
    {
      "block_id": 6,
      "ko": "일은 제가 맡겠습니다.",
      "literal_id": 2,
      "record_id": 3801,
      "source_sc_utf16le_sha256": "4A7A2007FA3E6BA33FD3CC65BEA9147CD62BEBD90CA28A7402F21E3C3DD04F00"
    },
    {
      "block_id": 6,
      "ko": "자세한 사정은 알겠습니다.\n상대",
      "literal_id": 0,
      "record_id": 3802,
      "source_sc_utf16le_sha256": "2C1225FA8509E22B8B9F41BBB766550A2C39CE2B974F28FC70D502B34A89985C"
    },
    {
      "block_id": 6,
      "ko": "와 본가의 정전에 관해,\n본가가 중재 역할을 맡겠습니다.",
      "literal_id": 1,
      "record_id": 3802,
      "source_sc_utf16le_sha256": "8D3947514824985D83923B7F3F9A562DDFC78090FE991317B0B226894D938B76"
    },
    {
      "block_id": 6,
      "ko": "혼인 제안을 받아들이겠소.\n두 가문이 오래도록 화목하게 지냅시다.",
      "literal_id": 0,
      "record_id": 3805,
      "source_sc_utf16le_sha256": "B3B761BC4558DC557E6EFB2823FF7FDCF3C4BC318913CAAEC100ED80CC4072C1"
    },
    {
      "block_id": 6,
      "ko": "혼인 제안을 받아들이겠소.\n이제부터는 친척이니,\n두 가문이 화목하게 난세를 헤쳐 나갑시다.",
      "literal_id": 0,
      "record_id": 3806,
      "source_sc_utf16le_sha256": "CDA92F3BEE5A82BBCD05CB154ACB311AA65170B7FF89CE55F3CDF0BBF1A3A769"
    },
    {
      "block_id": 6,
      "ko": "혼인 제안을 기쁘게 받아들이겠소.\n이 인연이 두 가문을 오래도록 이어 주기를.",
      "literal_id": 0,
      "record_id": 3807,
      "source_sc_utf16le_sha256": "5F4DE74D9124449F85972C7FFCE841443285D34693430E2E5A3C51B6BDF68314"
    },
    {
      "block_id": 6,
      "ko": "혼인 제안을 받아들이겠습니다.\n이제 우리는 한 가족입니다.\n무슨 일이 있으면 서로 도우며 살아갑시다.",
      "literal_id": 0,
      "record_id": 3811,
      "source_sc_utf16le_sha256": "F721EE0B7A8F8165725530B2460F3AB2C1832931106C19100132D746C7658DFD"
    },
    {
      "block_id": 6,
      "ko": "가문을 지키기 위한 결단이오.\n부끄러워할 일은 없소……",
      "literal_id": 0,
      "record_id": 3817,
      "source_sc_utf16le_sha256": "46FD82D3FEE1502048CCA9974533240DE714509163F7640071FEB5B9D4CBADF4"
    },
    {
      "block_id": 6,
      "ko": "이 또한 가문을 지키기 위한 일……\n부디 잘 부탁드리오……",
      "literal_id": 0,
      "record_id": 3818,
      "source_sc_utf16le_sha256": "FDCF10499E63D7097D7E30928264572774EC14A019EE493557A323ACB39E45B0"
    },
    {
      "block_id": 6,
      "ko": "이 또한 가문을 지키기 위한 일이오……\n부디 잘 부탁드리오.",
      "literal_id": 0,
      "record_id": 3819,
      "source_sc_utf16le_sha256": "A69987ABF2EAE3FF8E8F10223EB9D4D9355D087A2BF9B4512359E28E9DC08CC4"
    },
    {
      "block_id": 6,
      "ko": "이 또한 가문을 지키기 위한 일입니다……\n부디 잘 부탁드립니다……",
      "literal_id": 0,
      "record_id": 3823,
      "source_sc_utf16le_sha256": "64266FD841D6EEC94EFD9008FC8673FC7CEBC9FD395513B64CEBAC2F9426524C"
    },
    {
      "block_id": 6,
      "ko": "본가의 뜻을 따르라는 말씀,\n의뢰인은 어떻게든 물리치겠습니다.",
      "literal_id": 0,
      "record_id": 3827,
      "source_sc_utf16le_sha256": "FDEC2205E94CDFCC8AF30F2509FB5B8F7B040F2221B011B69A5C604CEB5B5AA8"
    },
    {
      "block_id": 6,
      "ko": "난세이기에 더욱,\n신의 없는 자는 살아남을 수 없음을 알아라!",
      "literal_id": 0,
      "record_id": 3828,
      "source_sc_utf16le_sha256": "5DBADB1BBA5C08036E90748BF8B6D4B6E47ED1C81D336D2D6B45D6CE0DB47D06"
    },
    {
      "block_id": 6,
      "ko": "이럴 수가…… 우리와 손을 끊다니 어리석군.",
      "literal_id": 0,
      "record_id": 3831,
      "source_sc_utf16le_sha256": "16D9274F16093D66D05430D9985352E84256B5CC262D9DE882594C0A65DD702E"
    },
    {
      "block_id": 6,
      "ko": "말도 안 됩니다!\n우리와 손을 끊겠다는 겁니까!",
      "literal_id": 0,
      "record_id": 3832,
      "source_sc_utf16le_sha256": "C05982004A8C5A8457B3EE92885DB38E9A95F323A6E2BA6ECE96D59A5187D8AD"
    },
    {
      "block_id": 6,
      "ko": "뭐라고…… 우리와 손을 끊겠다는 건가?",
      "literal_id": 0,
      "record_id": 3833,
      "source_sc_utf16le_sha256": "AC46BD8B57F0CF90C71CE6449B9645D600FEE6F30E4A38D6A6C5970A7F4B03CD"
    },
    {
      "block_id": 6,
      "ko": "이렇게 갑자기 손을 끊다니……!",
      "literal_id": 0,
      "record_id": 3837,
      "source_sc_utf16le_sha256": "2DF028E0933749BF17C5961DE772BE95A4084B50C42AF82847DF42BA2BDD7966"
    }
