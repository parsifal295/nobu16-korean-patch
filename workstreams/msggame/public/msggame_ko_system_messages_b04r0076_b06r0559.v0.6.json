    {
      "block_id": 6,
      "ko": "잠시 쉬어 가자",
      "literal_id": 0,
      "record_id": 298,
      "source_sc_utf16le_sha256": "CC39000B9BEF151ADCE117A328C94E821A001D7236C8F2A14D4577E831948853"
    },
    {
      "block_id": 6,
      "ko": "모두를 소집한 건가",
      "literal_id": 0,
      "record_id": 309,
      "source_sc_utf16le_sha256": "6E9C07609ECD0B9DD70473053AFCAEC9670A29D0D98F4EABEA1F95C35FA11728"
    },
    {
      "block_id": 6,
      "ko": "낯선 얼굴이 있군.",
      "literal_id": 0,
      "record_id": 310,
      "source_sc_utf16le_sha256": "3EED8C00B3296026ED153E0BAE40E92607C7F3097DE00BBE342EF6DC907E1C2F"
    },
    {
      "block_id": 6,
      "ko": "평정 시간이 되었나?",
      "literal_id": 0,
      "record_id": 311,
      "source_sc_utf16le_sha256": "0631B42C0FA2FAE05422A5C5CED0E5CB39C279BAA9F88C05765E023EC7E397D9"
    },
    {
      "block_id": 6,
      "ko": "언제 와도\n훌륭한 성이군",
      "literal_id": 0,
      "record_id": 312,
      "source_sc_utf16le_sha256": "7299E7C1CAB02D979F3C50DF8567E6D5241D6C48B95E24BF9ADCD9FD00A4144C"
    },
    {
      "block_id": 6,
      "ko": "급한 용건인가?",
      "literal_id": 0,
      "record_id": 313,
      "source_sc_utf16le_sha256": "5DB559D80EB5E389A6362A2400370A031BDF885EFBAB0BE6887953B3B5645748"
    },
    {
      "block_id": 6,
      "ko": "여기는\n마치 내 집 같군",
      "literal_id": 0,
      "record_id": 314,
      "source_sc_utf16le_sha256": "DD70CFFF1A9533FB823E969A2E63EBAF2FC41F59EC850991BB136AFE35C7D8E9"
    },
    {
      "block_id": 6,
      "ko": "갑자기 불러내다니……\n무슨 일일까?",
      "literal_id": 0,
      "record_id": 321,
      "source_sc_utf16le_sha256": "82EDB7B362062C477AC4DF9DB94284E7F0E7FA337B71781A7EFEE1FB32779389"
    },
    {
      "block_id": 6,
      "ko": "그분도\n오실까?",
      "literal_id": 0,
      "record_id": 322,
      "source_sc_utf16le_sha256": "C1B8D9FF76370D035A24E198EEFD0C93B92CAC40A04160940F5D35040F6D8606"
    },
    {
      "block_id": 6,
      "ko": "그래야지",
      "literal_id": 0,
      "record_id": 333,
      "source_sc_utf16le_sha256": "98D79ED55DF1966099142F4771631DB88A0D3D50EED20F39A63ECB11CDD780AE"
    },
    {
      "block_id": 6,
      "ko": "우선\n실행해 보자",
      "literal_id": 0,
      "record_id": 334,
      "source_sc_utf16le_sha256": "1B8FEDA7A5A4F20735C6ACB7DBCD2822736606168253D66E521DA23A80B71282"
    },
    {
      "block_id": 6,
      "ko": "역시\n혜안이십니다",
      "literal_id": 0,
      "record_id": 335,
      "source_sc_utf16le_sha256": "8AFBAC9D957A582C4204805CAF3D53107462389829D2D69C30A90DFE77999FA9"
    },
    {
      "block_id": 6,
      "ko": "좋다고 봅니다",
      "literal_id": 0,
      "record_id": 336,
      "source_sc_utf16le_sha256": "93D8840F84F5C29D7F94E7DB05D1FFCD827255CA39F7EC5859E365021C695B98"
    },
    {
      "block_id": 6,
      "ko": "내게 맡겨라!",
      "literal_id": 0,
      "record_id": 337,
      "source_sc_utf16le_sha256": "6161616A5DB1D650934BFBE1E1B124C017CBEDFD39DE211E7A04CE37E687D6E1"
    },
    {
      "block_id": 6,
      "ko": "이의는 없소",
      "literal_id": 0,
      "record_id": 338,
      "source_sc_utf16le_sha256": "1DA0B56C3D37DB674638F5EA75D079F7ADCC5474760FF87D7171C93D4E532A82"
    },
    {
      "block_id": 6,
      "ko": "미력하나마\n돕겠습니다",
      "literal_id": 0,
      "record_id": 345,
      "source_sc_utf16le_sha256": "C3C00C2C1199430AEBA0DB189A2A1D78C05399174428209CBCEA07E10AB29407"
    },
    {
      "block_id": 6,
      "ko": "훌륭한 생각입니다",
      "literal_id": 0,
      "record_id": 346,
      "source_sc_utf16le_sha256": "579E9F45A641C9E1A48A80CAAF5E48C466FD298340186C766F3A57EFA0085B5A"
    },
    {
      "block_id": 6,
      "ko": "돈을 쓰는 법을 보면,\n그 사람의 그릇을 알 수 있지.",
      "literal_id": 0,
      "record_id": 357,
      "source_sc_utf16le_sha256": "4C82F2B3207D06A438D962CA88C09DBA44B55525A9AB27D76F793B65432C88DF"
    },
    {
      "block_id": 6,
      "ko": "영지의 일을\n잘 생각하고 계시는군요.",
      "literal_id": 0,
      "record_id": 358,
      "source_sc_utf16le_sha256": "7166E4EF830C517AECF962005642DAD2B82B2905B30780C694A1F6AF932762FE"
    },
    {
      "block_id": 6,
      "ko": "이렇게 쓰는 것이군요?\n알겠습니다.",
      "literal_id": 0,
      "record_id": 359,
      "source_sc_utf16le_sha256": "39BE6B744C93608ABF84DE7F0452EC560DB1A04146C8F9C6C00904E2280FD751"
    },
    {
      "block_id": 6,
      "ko": "훗……\n역시 그렇습니까?",
      "literal_id": 0,
      "record_id": 360,
      "source_sc_utf16le_sha256": "DE4765F53C629FF68A889105355C1D2D808CB18CBEC6BB6281C0E6863E9C2421"
    },
    {
      "block_id": 6,
      "ko": "그렇군,\n뜻대로 하게.",
      "literal_id": 0,
      "record_id": 361,
      "source_sc_utf16le_sha256": "960D1BC39A04FB442ECAFC1EFB8FB15FE13F52966D4253B4158CCEE5434E62B4"
    },
    {
      "block_id": 6,
      "ko": "지출이 꽤 크겠군.",
      "literal_id": 0,
      "record_id": 362,
      "source_sc_utf16le_sha256": "8566DFCEF956A62C23F90812978A04E540D8EB8E915F54E95858E143259CDC69"
    },
    {
      "block_id": 6,
      "ko": "정책 문안을\n정리하겠습니다.",
      "literal_id": 0,
      "record_id": 369,
      "source_sc_utf16le_sha256": "4099D5BC6FD38BD01F5972071900E1DB6D53DDA05A1AE9168C594395794EBB49"
    },
    {
      "block_id": 6,
      "ko": "본가의 정책은\n이것이 최선일까……",
      "literal_id": 0,
      "record_id": 370,
      "source_sc_utf16le_sha256": "A5F24743260487EDAE9E4F25EB4681AC87EF4C917E740D67BBF82FD52281750B"
    },
    {
      "block_id": 6,
      "ko": "이번 거래는\n좋은 판단이었습니다",
      "literal_id": 0,
      "record_id": 381,
      "source_sc_utf16le_sha256": "992B87C36984294F8821BA13A43502696DFA4C45676784E2B3FB92D8754C2E6E"
    },
    {
      "block_id": 6,
      "ko": "상인에게도 이익을 줘야\n장사가 성립하는 법",
      "literal_id": 0,
      "record_id": 382,
      "source_sc_utf16le_sha256": "940B1C420FD78125A915B2691BF36D1049CF9E33C2CDC6E2A4F90AF13347B28B"
    },
    {
      "block_id": 6,
      "ko": "절반 이상의 성과를\n거둔 거래로 보이는군.",
      "literal_id": 0,
      "record_id": 383,
      "source_sc_utf16le_sha256": "CD83A22C9D82E337B5A87917E2A2EEF751F12CB917409E1FAC7799C65CF6A62E"
    },
    {
      "block_id": 6,
      "ko": "이번 거래는\n예상한 바입니다.",
      "literal_id": 0,
      "record_id": 384,
      "source_sc_utf16le_sha256": "816E879930554F9570CE82CA2AE3743BB742F9070A3D2425809844A192D006E2"
    },
    {
      "block_id": 6,
      "ko": "거래하느라 수고했네.",
      "literal_id": 0,
      "record_id": 385,
      "source_sc_utf16le_sha256": "FEF0855A1F5453999BCBF99A71D1AE14853D9DEBA248FEF642598DDD2F3D3BF8"
    },
    {
      "block_id": 6,
      "ko": "숨 막히는 공방이군……\n상인도 제법이야.",
      "literal_id": 0,
      "record_id": 386,
      "source_sc_utf16le_sha256": "93D12DE3401A15CA7FCDA2B2F67DA262E8EC4ED069C1D9BD6925469A004502B3"
    },
    {
      "block_id": 6,
      "ko": "좋은 거래를\n성사시킨 듯하군요.",
      "literal_id": 0,
      "record_id": 393,
      "source_sc_utf16le_sha256": "3A2BAFDE4CD892D8B773E5898C9EA71F9F065CDEF7F036FB10C1A9E8791513D1"
    },
    {
      "block_id": 6,
      "ko": "나도……\n뭔가 사고 싶었는데……",
      "literal_id": 0,
      "record_id": 394,
      "source_sc_utf16le_sha256": "82925F78C1D189A2D09DF2C87567FF6132C9570B8940F548C1BD7B49384AE8E5"
    },
    {
      "block_id": 6,
      "ko": "흠…… 싸울 준비를 마쳤나?",
      "literal_id": 0,
      "record_id": 405,
      "source_sc_utf16le_sha256": "8C9B038DF44CE844D25DCCF2DD8F3BDC0F96D48EF758B963AD1F45DB4AEFB694"
    },
    {
      "block_id": 6,
      "ko": "충분히\n생각하셨군요.",
      "literal_id": 0,
      "record_id": 406,
      "source_sc_utf16le_sha256": "E739EC3E3061E2EC496C88C1646AFFD3FDC34967701B7C5579AC6BB39268A861"
    },
    {
      "block_id": 6,
      "ko": "그렇군\n이런 전술인가",
      "literal_id": 0,
      "record_id": 407,
      "source_sc_utf16le_sha256": "2F91EC07AFE95D566A159E85021B354C0FACC4E748E8D08FB92B930FE02873C9"
    },
    {
      "block_id": 6,
      "ko": "역시 이런 식으로\n사람을 움직였군요.",
      "literal_id": 0,
      "record_id": 408,
      "source_sc_utf16le_sha256": "05C7C0AC5E17A4D7FA6E3A02F891CFD7E11EAE563A13D8486BE1BA191C3252F1"
    },
    {
      "block_id": 6,
      "ko": "수비든 공격이든\n성을 맡은 장수에게 달렸지",
      "literal_id": 0,
      "record_id": 409,
      "source_sc_utf16le_sha256": "20241EC0765A1906A6A4277D7297A5A95099ECE0E35887B82D4FD21C81D0FD2C"
    },
    {
      "block_id": 6,
      "ko": "호오, 절묘한 배치로군",
      "literal_id": 0,
      "record_id": 410,
      "source_sc_utf16le_sha256": "55A1245C10F3BDF9D8B9A071DAE6590DD68D72915627681A50A044A772F099CE"
    },
    {
      "block_id": 6,
      "ko": "장수 배치를 바꾼다……\n전쟁인가?",
      "literal_id": 0,
      "record_id": 417,
      "source_sc_utf16le_sha256": "65DE2C141385EFDE6EEF4F6FDC435E4FB2C31A9EAABFB84F225B3FFDA7282824"
    },
    {
      "block_id": 6,
      "ko": "이런 배치로\n맞서려는 건가?",
      "literal_id": 0,
      "record_id": 418,
      "source_sc_utf16le_sha256": "4C909A51E22ADFBF4A02742D0BDC3682BEF46D6F2D4537D49B2E071E3C48D3B4"
    },
    {
      "block_id": 6,
      "ko": "신상필벌은 무가가\n서 있는 근본이다",
      "literal_id": 0,
      "record_id": 429,
      "source_sc_utf16le_sha256": "0F0F309CD066D6B14E82BE0D16C23DD7EDFFEA5D979B548648DD30BF021D4930"
    },
    {
      "block_id": 6,
      "ko": "그리 눈에 띄는 일은\n하지 않는 편이 좋겠군……",
      "literal_id": 0,
      "record_id": 430,
      "source_sc_utf16le_sha256": "EB19DDAB259AA25B6EBD20DEEA8AAC34A72A65EC16F6AD3CCC012CE3A222D273"
    },
    {
      "block_id": 6,
      "ko": "그자는\n충성을 다하겠지",
      "literal_id": 0,
      "record_id": 431,
      "source_sc_utf16le_sha256": "E8628A1E3CE9CBB583CB3C2A3887F34EEF1950E1C2ECC541CBC28AE7A8486623"
    },
    {
      "block_id": 6,
      "ko": "역시 가보를\n빼앗겼군",
      "literal_id": 0,
      "record_id": 432,
      "source_sc_utf16le_sha256": "01192AA57BEDF712097A10F50CC0538F060BC1E2B3D6614136EC770B6F3BB5AC"
    },
    {
      "block_id": 6,
      "ko": "부러운 일이군.",
      "literal_id": 0,
      "record_id": 433,
      "source_sc_utf16le_sha256": "A2BF733780D29D17D6DD270C19BEDDF0369F9EF7A556F332C8F7D23CD6D997BA"
    },
    {
      "block_id": 6,
      "ko": "신분에 맞지 않는 명품을\n가지고 있었으니 말이야.",
      "literal_id": 0,
      "record_id": 434,
      "source_sc_utf16le_sha256": "0BEA90DD69E117F2F4716CF9F06B5854F9200C5440042527D761744B927C2FC4"
    },
    {
      "block_id": 6,
      "ko": "훌륭히 일하다 보면\n언젠가는 나도……",
      "literal_id": 0,
      "record_id": 441,
      "source_sc_utf16le_sha256": "E759A225D11326254050602F4D596B43A1456508B980DF70EC834721D31F16A7"
    },
    {
      "block_id": 6,
      "ko": "상을 받아도 마냥\n기뻐할 수는 없군……",
      "literal_id": 0,
      "record_id": 442,
      "source_sc_utf16le_sha256": "0970D854FB018B0B80C9B6AE168486D2C275B8F08DD46B25DCE9B59406CC5DE0"
    },
    {
      "block_id": 6,
      "ko": "오래도록 행복하기를",
      "literal_id": 0,
      "record_id": 453,
      "source_sc_utf16le_sha256": "180C48DC293137BC07A3651CA17C40B9B7D424344AB380E126BEE77919377988"
    },
    {
      "block_id": 6,
      "ko": "좋은 인연이 되기를",
      "literal_id": 0,
      "record_id": 454,
      "source_sc_utf16le_sha256": "40804EEBC81E972DEA825ABAAFF187516A74A86F1A023F7722DF967EEA9D2AAE"
    },
    {
      "block_id": 6,
      "ko": "축하합니다\n오래도록 행복하십시오.",
      "literal_id": 0,
      "record_id": 455,
      "source_sc_utf16le_sha256": "6B5155FE7A8CBCB86A566A1F8E88988AC05389A03D19B34A8C026128467D678C"
    },
    {
      "block_id": 6,
      "ko": "역시 두 사람은\n맺어질 운명이었군",
      "literal_id": 0,
      "record_id": 456,
      "source_sc_utf16le_sha256": "39232DFDF156E6837A86AE977DE82F40DF177FEB99DD3436C421BA224A1200D4"
    },
    {
      "block_id": 6,
      "ko": "경사로다",
      "literal_id": 0,
      "record_id": 457,
      "source_sc_utf16le_sha256": "BF89DE426A39B4731F9F5A675D103620EA8389E856C0B1EBA8C5CAF1DB91630A"
    },
    {
      "block_id": 6,
      "ko": "그 두 사람이\n부부가 되다니",
      "literal_id": 0,
      "record_id": 458,
      "source_sc_utf16le_sha256": "1D8BFDB274B8D53297C5FB60AFB637E71B3C2D84C36590E32674D937FB954EB6"
    },
    {
      "block_id": 6,
      "ko": "멋진 일이야……",
      "literal_id": 0,
      "record_id": 465,
      "source_sc_utf16le_sha256": "6B9B381BF8DAFC499A223DF2E10397D440FBB9370C8317972412C8F39B3C5928"
    },
    {
      "block_id": 6,
      "ko": "진심으로\n축하합니다!",
      "literal_id": 0,
      "record_id": 466,
      "source_sc_utf16le_sha256": "D5C3763419EA013487E5B6489AD1556204C60F72C7673C85D169F392EA3FB590"
    },
    {
      "block_id": 6,
      "ko": "새 당주를\n뒷받침해야겠군.",
      "literal_id": 0,
      "record_id": 477,
      "source_sc_utf16le_sha256": "9E1A771A617CDAED90F116A4B2EEE08F250F6D5B9FDD6D07D1F146A551ED4AB5"
    },
    {
      "block_id": 6,
      "ko": "참으로 어려운\n결단을 내리셨군……",
      "literal_id": 0,
      "record_id": 478,
      "source_sc_utf16le_sha256": "E62BF74598C56CB7FF2649BE116F119039DB44A10BFEFCCDE20717D6D327218E"
    },
    {
      "block_id": 6,
      "ko": "본가를 둘러싼 상황도\n달라지겠군……",
      "literal_id": 0,
      "record_id": 479,
      "source_sc_utf16le_sha256": "BD9D12C2A76443825DEAE54A46F89E5E0F142BB89030E8139DFE9F2FD7297FF5"
    },
    {
      "block_id": 6,
      "ko": "역시 은거할 때는\n지금이었나",
      "literal_id": 0,
      "record_id": 480,
      "source_sc_utf16le_sha256": "DEA1ECCFC4BF02B3F4B699C810B0E8EB87199A46A18CED79BC731E3E5ED45FB6"
    },
    {
      "block_id": 6,
      "ko": "선대 당주의\n훌륭한 물러남이군",
      "literal_id": 0,
      "record_id": 481,
      "source_sc_utf16le_sha256": "0706130D64E57EB50486CBB0A40C0F8B7F121EC79770EA001A045F1C92CE6BEB"
    },
    {
      "block_id": 6,
      "ko": "이 시기에\n은거하시다니",
      "literal_id": 0,
      "record_id": 482,
      "source_sc_utf16le_sha256": "A92DE89E475BB3644A2C65F54B0F75B8070774FF3A718AB477D5801D4187AF14"
    },
    {
      "block_id": 6,
      "ko": "당주가 바뀌었으니\n새 마음으로 시작해야겠군",
      "literal_id": 0,
      "record_id": 489,
      "source_sc_utf16le_sha256": "DA71720583CFC00552980979EE87A3C8C160DB2CA260BE553E8F3156ADF9C94D"
    },
    {
      "block_id": 6,
      "ko": "이것이\n세상사의 무상함인가?",
      "literal_id": 0,
      "record_id": 490,
      "source_sc_utf16le_sha256": "49D9E87B254E45D8EAAE8BCA9C0D54A36725FC2BD8EB9231F1F36FB7A2FEAA70"
    },
    {
      "block_id": 6,
      "ko": "가문을 통솔하려면,\n어쩔 수 없는 일이지.",
      "literal_id": 0,
      "record_id": 501,
      "source_sc_utf16le_sha256": "B3D8708294F270C10D894BFE7BD2F70057616A273C0EAFD4E43DFE644404F428"
    },
    {
      "block_id": 6,
      "ko": "이것도\n어쩔 수 없는 조치다",
      "literal_id": 0,
      "record_id": 502,
      "source_sc_utf16le_sha256": "E0616ECA2C3F7CB7C9BEAF8EF0BC31AC93B66D5946688B06CB6CC9D102820A39"
    },
    {
      "block_id": 6,
      "ko": "이런 처분도\n때로는 필요합니다",
      "literal_id": 0,
      "record_id": 503,
      "source_sc_utf16le_sha256": "5B2D58CBE0793BA70D98EA1BD66D28457E40716A42C809E8CDAF3639F3F8105D"
    },
    {
      "block_id": 6,
      "ko": "역시 그자가\n추방되었군요",
      "literal_id": 0,
      "record_id": 504,
      "source_sc_utf16le_sha256": "EC80071FAD7C3460C47C1A5CB7CE5EBEF43C986450DE42F6C0BED1F26583610F"
    },
    {
      "block_id": 6,
      "ko": "어쩔 수 없지",
      "literal_id": 0,
      "record_id": 505,
      "source_sc_utf16le_sha256": "83DB18B151881D1553B336D0434B415E55330A5FB913D87447737D38ED312E7B"
    },
    {
      "block_id": 6,
      "ko": "이런, 안타깝군……",
      "literal_id": 0,
      "record_id": 506,
      "source_sc_utf16le_sha256": "95F37803C1D880C554824F1FFF42CD302C6D1BD43175D891277F9CD217D93401"
    },
    {
      "block_id": 6,
      "ko": "가엾지만,\n어쩔 수 없지",
      "literal_id": 0,
      "record_id": 513,
      "source_sc_utf16le_sha256": "7AC582F2F9BF289A79BAE288D01F45CCFF9E64026447C18448CDA6609779C2E5"
    },
    {
      "block_id": 6,
      "ko": "당연한 응보다",
      "literal_id": 0,
      "record_id": 514,
      "source_sc_utf16le_sha256": "022D4A30A596D1ED0EF9C0988DACEE7E9ED90B81C08023FF0BD4A7808805DCA8"
    },
    {
      "block_id": 6,
      "ko": "군단은 운용이 중요하다.",
      "literal_id": 0,
      "record_id": 525,
      "source_sc_utf16le_sha256": "225F740CD4487115BAAE048E7B2441DF3F8C1A9B18A4A3D21C5EC3FE0479381C"
    },
    {
      "block_id": 6,
      "ko": "군단을 어떻게 다루느냐가\n본가의 미래를 정한다……",
      "literal_id": 0,
      "record_id": 526,
      "source_sc_utf16le_sha256": "1024E351144865E1E68112ACE0BAB68B76E6D7799EEB4721175A974D4FC3600F"
    },
    {
      "block_id": 6,
      "ko": "상황을\n잘 살피셨군요",
      "literal_id": 0,
      "record_id": 527,
      "source_sc_utf16le_sha256": "4C9CC04F95DDD68BC6BA4671AE46D3188625F3B12EBF689643B2AE5086060C03"
    },
    {
      "block_id": 6,
      "ko": "역시 군단을\n조정하셨군요.",
      "literal_id": 0,
      "record_id": 528,
      "source_sc_utf16le_sha256": "651B5BD3330088D44A88717A23E7C2B6B46876A908C2136DA69CB0138549BB53"
    },
    {
      "block_id": 6,
      "ko": "어디에 있든\n온 힘을 다할 뿐",
      "literal_id": 0,
      "record_id": 529,
      "source_sc_utf16le_sha256": "9F4EEDA9B125789FB2EE4199F6CCDCBC5697631784B4A323C81BB7ACB9608698"
    },
    {
      "block_id": 6,
      "ko": "참으로 훌륭한\n솜씨로군요.",
      "literal_id": 0,
      "record_id": 530,
      "source_sc_utf16le_sha256": "5E95E0AB65DE9E649F5B0F40A8B5951F6FF5414DAE03C68F57F8CCEFC552C203"
    },
    {
      "block_id": 6,
      "ko": "군단 변경은 마음에 들 때까지\n자유롭게 하십시오",
      "literal_id": 0,
      "record_id": 537,
      "source_sc_utf16le_sha256": "190A737A55EAAEBD6A25A8937275688039932E97BDC2292E22F9789720645CEB"
    },
    {
      "block_id": 6,
      "ko": "군단을 조정할 때면,\n문득 진지한 눈빛이 되시는군요.",
      "literal_id": 0,
      "record_id": 538,
      "source_sc_utf16le_sha256": "0FD556C243C67A2B9EEF8BC0734AA53804A642325B2E5959A7C147F3F3B0E141"
    },
    {
      "block_id": 6,
      "ko": "당연하지.",
      "literal_id": 0,
      "record_id": 545,
      "source_sc_utf16le_sha256": "72555AC92D09F00D2A8889127CCEFF92CE80A5645EF58C77532307F35A290495"
    },
    {
      "block_id": 6,
      "ko": "다음에도 힘내자.",
      "literal_id": 0,
      "record_id": 546,
      "source_sc_utf16le_sha256": "7D2BEBDBBA600FA236A2584739CD513EBB9E24E2441B92CF51DC145F55093DE9"
    },
    {
      "block_id": 6,
      "ko": "호오,\n그렇게 나오는군.",
      "literal_id": 0,
      "record_id": 547,
      "source_sc_utf16le_sha256": "94F4553F0006682A42263A9B8F59D22B6582B156C62BD75A051433A0323DF363"
    },
    {
      "block_id": 6,
      "ko": "어떻게든\n공훈을 세워야 한다.",
      "literal_id": 0,
      "record_id": 548,
      "source_sc_utf16le_sha256": "162464CE91FB22ADB6BEDE60B78C2B9541D370413E15703A892B8790F7652187"
    },
    {
      "block_id": 6,
      "ko": "어떻게 해야\n주군의 눈에 들 수 있을까?",
      "literal_id": 0,
      "record_id": 549,
      "source_sc_utf16le_sha256": "3B2F50A21413FC5A9029B0603CF8423D15C9FC2E618FACE11247C61F69330F60"
    },
    {
      "block_id": 6,
      "ko": "무슨 일이든 신뢰가 있어야 하지.",
      "literal_id": 0,
      "record_id": 550,
      "source_sc_utf16le_sha256": "B629F952D2EF8D1C33DB2AFD074C3799FA0D33E2FD3817477AB31D1E2D4E01E9"
    },
    {
      "block_id": 6,
      "ko": "두루 신경을 쓰는 것도\n중요한 일이다.",
      "literal_id": 0,
      "record_id": 551,
      "source_sc_utf16le_sha256": "B00BC68137DF7350437671E7587143287E1E16F1A3ECE19A1F38C010C1D04714"
    },
    {
      "block_id": 6,
      "ko": "주군께서는\n그렇게 생각하시는가?",
      "literal_id": 0,
      "record_id": 552,
      "source_sc_utf16le_sha256": "B3B9AE184C72989049C486F45114D88289627807B808AF41080C48952B4CB514"
    },
    {
      "block_id": 6,
      "ko": "조정과의 관계도\n소홀히 할 수 없다.",
      "literal_id": 0,
      "record_id": 553,
      "source_sc_utf16le_sha256": "061C44D49F25331A1A9260D570E817FAD48A6945D841B12D514E9DD252AD2E24"
    },
    {
      "block_id": 6,
      "ko": "사전 교섭을\n게을리해서는 안 된다.",
      "literal_id": 0,
      "record_id": 554,
      "source_sc_utf16le_sha256": "BF0F2AED8E8E6CFA9DFB0E594BABBC3EF5B8FE8FAB076270653F865FB8F653EB"
    },
    {
      "block_id": 6,
      "ko": "자, 내 진언을\n받아들여 주실까?",
      "literal_id": 0,
      "record_id": 559,
      "source_sc_utf16le_sha256": "8CF2BC2BFBA3075919E0003C0029715FD22557B7E74366A758DC9FB87B481175"
    }
  ],
