      "block_id": 6,
      "ko": "좋은 교섭이었습니다!",
      "literal_id": 0,
      "record_id": 2177,
      "source_sc_utf16le_sha256": "32924518B60E6BF14B25B7CFF810864A75BB9DCCE27628E231FEC57EC15FD1BB"
    },
