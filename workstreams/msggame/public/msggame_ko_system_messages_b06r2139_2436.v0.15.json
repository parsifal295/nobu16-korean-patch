      "source_sc_utf16le_sha256": "821B30C80D055D0B55C98031F851086CC54D5668773312AD66E7222A6FA2C20E"
    },
    {
      "block_id": 6,
      "ko": "정말 교섭을 거부하시겠습니까?",
