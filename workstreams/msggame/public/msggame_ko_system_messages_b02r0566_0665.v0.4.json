{
  "base_language": "SC",
  "defaults": {
    "status": "translated"
  },
  "distribution_policy": {
    "contains_commercial_source_text": false,
    "contains_complete_game_resource": false
  },
  "entries": [
    {
      "block_id": 2,
      "ko": "열세야말로\n내 계책을 펼칠 무대다!",
      "literal_id": 0,
      "record_id": 566,
      "source_sc_utf16le_sha256": "2115B37A939EE2B0EC80C70CB86036C5BF1894B12D7DD4DBD1928B7B97F88F4B"
    },
    {
      "block_id": 2,
      "ko": "적은 바로",
      "literal_id": 0,
      "record_id": 567,
      "source_sc_utf16le_sha256": "95C76935621E9601F97E9F6A92CCCF7D8C0CA4DA6C1FD7334293DFCA897FBD7A"
    },
    {
      "block_id": 2,
      "ko": "!\n여기서 무찔러라!",
      "literal_id": 1,
      "record_id": 567,
      "source_sc_utf16le_sha256": "32F6B1FAB0BA12EACFAADE96F8A1F137D1276C31C892DA74F1B000EFED29BCD0"
    },
    {
      "block_id": 2,
      "ko": "나무아미타불……\n불적에게 벌을 내리리라!",
      "literal_id": 0,
      "record_id": 568,
      "source_sc_utf16le_sha256": "AC9B8800EDB36645BA9C0A97C22A7429ADC9B2FF20738C251176788B7D887D41"
    },
    {
      "block_id": 2,
      "ko": "나타났는가, 군신이여……\n내 지휘로 악연을 끊겠다!",
      "literal_id": 0,
      "record_id": 569,
      "source_sc_utf16le_sha256": "466D6FE3AA9E8D8121D2F558C03CEAC33BCBC3035472A7638EEB57D7BDE95A8A"
    },
    {
      "block_id": 2,
      "ko": "왔는가, 숙적이여!\n이제 자웅을 겨루자!",
      "literal_id": 0,
      "record_id": 570,
      "source_sc_utf16le_sha256": "B0B511D3A5980F189B561122A6DF42686A4E509067B82749C0C48C88B717FED0"
    },
    {
      "block_id": 2,
      "ko": "무운을 빌 대상:",
      "literal_id": 0,
      "record_id": 571,
      "source_sc_utf16le_sha256": "C735FD02DAAAC8A17686C76E863B9FC1F6F353DFCE82CDA18E8166A376235030"
    },
    {
      "block_id": 2,
      "ko": "의 무운을 빌겠습니다.",
      "literal_id": 1,
      "record_id": 571,
      "source_sc_utf16le_sha256": "2DA69E52D81D6AB51DB7347CA4532D2379C62CD6848DB0FCC7D68B5B785BE62B"
    },
    {
      "block_id": 2,
      "ko": "일부러 배웅해 줘 고맙다.\n좋은 소식을 기다려라.",
      "literal_id": 0,
      "record_id": 572,
      "source_sc_utf16le_sha256": "DFAEA88D4A690FF39E6C09B9E3A8D626D9D35B8C988A397DD1861345B6D73663"
    },
    {
      "block_id": 2,
      "ko": "무운을\n빌고 있겠습니다.",
      "literal_id": 0,
      "record_id": 573,
      "source_sc_utf16le_sha256": "85F765581874B830A74B63D532DA14C8525516DB31678B907A5CE102DDE3BA37"
    },
    {
      "block_id": 2,
      "ko": "걱정 마라!\n",
      "literal_id": 0,
      "record_id": 574,
      "source_sc_utf16le_sha256": "5AC2AAB7F1AE5A10DEF1D047798E140783169208F5F3688959ED01095CDF7932"
    },
    {
      "block_id": 2,
      "ko": "은(는) 앞으로도 계속 출세할 테니!",
      "literal_id": 1,
      "record_id": 574,
      "source_sc_utf16le_sha256": "91B596396BC9CF32F0DE5B5C1E112CC9F33436F1FF02BDEA68D3DD28DC00EEE7"
    },
    {
      "block_id": 2,
      "ko": "친애하는",
      "literal_id": 0,
      "record_id": 575,
      "source_sc_utf16le_sha256": "2EEE150EF6E838D396BF4BADC7F48EAC2293801CE8AD7EBEF90737DCB06590EE"
    },
    {
      "block_id": 2,
      "ko": "이여, 잘 있어라……",
      "literal_id": 1,
      "record_id": 575,
      "source_sc_utf16le_sha256": "6F69B1A907A718AF8F518D1D7FE240397851A6FA050EA7D87638A2C42B7F87F0"
    },
    {
      "block_id": 2,
      "ko": "안심하십시오……\n본가의 앞날을 지켜볼 자:",
      "literal_id": 0,
      "record_id": 576,
      "source_sc_utf16le_sha256": "9F45E1FB1F776AC0D4A1B9A6D2CECDBEC7BFE6708887C8B1464CE2ECEDD71F09"
    },
    {
      "block_id": 2,
      "ko": "\n이(가) 끝까지 지켜보겠습니다.",
      "literal_id": 1,
      "record_id": 576,
      "source_sc_utf16le_sha256": "0D75599736253BA51CE32D6F8BE8A6F54C445A8DE6D10B3C7F2743103DA2A76F"
    },
    {
      "block_id": 2,
      "ko": "친애하는",
      "literal_id": 0,
      "record_id": 577,
      "source_sc_utf16le_sha256": "2EEE150EF6E838D396BF4BADC7F48EAC2293801CE8AD7EBEF90737DCB06590EE"
    },
    {
      "block_id": 2,
      "ko": "이여, 잘 있어라……",
      "literal_id": 1,
      "record_id": 577,
      "source_sc_utf16le_sha256": "6F69B1A907A718AF8F518D1D7FE240397851A6FA050EA7D87638A2C42B7F87F0"
    },
    {
      "block_id": 2,
      "ko": "오합지졸은 두렵지 않다.\n천운의 주인:",
      "literal_id": 0,
      "record_id": 578,
      "source_sc_utf16le_sha256": "5F0F4E7F777F4C8E201D2CD49A7BD3140A48358392A5A20E7BCCFC846C146D43"
    },
    {
      "block_id": 2,
      "ko": "!",
      "literal_id": 1,
      "record_id": 578,
      "source_sc_utf16le_sha256": "9CE3A684293E45828B19FDE30427ACE4BF46B227E2EDC71E236500057B5C6517"
    },
    {
      "block_id": 2,
      "ko": "이 정도 열세는",
      "literal_id": 0,
      "record_id": 579,
      "source_sc_utf16le_sha256": "C2FA3D1F020FC7B35FE97BF2F4C5AA7EDB1F5C46FB1EC2E31E62EF8A56180EE8"
    },
    {
      "block_id": 2,
      "ko": "이(가) 제압한다!\n출세의 발판으로 삼겠다!",
      "literal_id": 1,
      "record_id": 579,
      "source_sc_utf16le_sha256": "7F5C60523994E74F588E1A8AD2FDD0A629F4E6D1D2D8A7F8DCDE187D76F3CCF8"
    },
    {
      "block_id": 2,
      "ko": "고요한 세상을 위해……\n이 주베에, 손을 더럽히는 것도 마다하지 않겠다.",
      "literal_id": 0,
      "record_id": 580,
      "source_sc_utf16le_sha256": "33645B714D4F43E0449FEA54725AD96A183FC39E2136C7EB82DCDE8FBAA6B5F1"
    },
    {
      "block_id": 2,
      "ko": "실컷 맛보아라……\n살무사의 계략을.",
      "literal_id": 0,
      "record_id": 581,
      "source_sc_utf16le_sha256": "C2F96D195FE334F9F6723E9E86D24193DB47D50369221509810D2C527EB65AD7"
    },
    {
      "block_id": 2,
      "ko": "적의 수가 많다!\n미카와 무사의 기개를 보일 때다!",
      "literal_id": 0,
      "record_id": 582,
      "source_sc_utf16le_sha256": "212D84DB8FEB215B2BFD540E2D7B006F62BCBAE0E36F73467586C6E6C837E277"
    },
    {
      "block_id": 2,
      "ko": "적도 아군도 똑똑히 보아라!\n이 독안룡이 비상하는 모습을!",
      "literal_id": 0,
      "record_id": 583,
      "source_sc_utf16le_sha256": "260B271EF1795BE5F49BFC8B99D4A237C34C73E28C9930FFC90316826EDA1C23"
    },
    {
      "block_id": 2,
      "ko": "우리 결사대 아카조나에가……\n열세를 뒤집는다!",
      "literal_id": 0,
      "record_id": 584,
      "source_sc_utf16le_sha256": "FBDE1D59B16910312C604170FD8E4E8E1A219E6ABFEE63812D4096006017EBD1"
    },
    {
      "block_id": 2,
      "ko": "수의 차이는 지략으로 뒤집는다.\n이것이",
      "literal_id": 0,
      "record_id": 585,
      "source_sc_utf16le_sha256": "1C310956B56631AD6AE41446F9D211FE91EBC1CACAB53985694EB32A87A06962"
    },
    {
      "block_id": 2,
      "ko": "의 전투다!",
      "literal_id": 1,
      "record_id": 585,
      "source_sc_utf16le_sha256": "1B13AFE1E2ED5C789EBF7E108FE4BAB27619A3AAB2A95D54DC98DCE48C4B165B"
    },
    {
      "block_id": 2,
      "ko": "명백한 열세로군.\n어떻게 버텨 낼 것인가……!",
      "literal_id": 0,
      "record_id": 586,
      "source_sc_utf16le_sha256": "B808D22880F2195179CC336BCC828DC6FFFAFE751FA1F8B5721915EE285E6D28"
    },
    {
      "block_id": 2,
      "ko": "죽고자 싸우면 살고, 살고자 싸우면 죽는다……\n전군, 목숨을 내게 맡겨라!",
      "literal_id": 0,
      "record_id": 587,
      "source_sc_utf16le_sha256": "38BAEA1D022D4DA7D1EDA9C9E188B54CFEA6694E2A97816B8107B552B8D62A76"
    },
    {
      "block_id": 2,
      "ko": "수로 우리를 누를 수 있다 생각했나?\n",
      "literal_id": 0,
      "record_id": 588,
      "source_sc_utf16le_sha256": "164C874ABB887F10F68C4EFC9991F63E777709231294843AC86D742E441DBAC9"
    },
    {
      "block_id": 2,
      "ko": "도 얕보였군.",
      "literal_id": 1,
      "record_id": 588,
      "source_sc_utf16le_sha256": "7E54D2003861198C552074112075C03169207BF90F3D63F04B911D59BE7D1BAD"
    },
    {
      "block_id": 2,
      "ko": "허허, 병력이 많아 고생이겠군.\n자…… 어떤 수를 써 볼까.",
      "literal_id": 0,
      "record_id": 589,
      "source_sc_utf16le_sha256": "73585E880FB5160B64070E93F2BB98E61389243B75A8998BB51F9370BAFA18D4"
    },
    {
      "block_id": 2,
      "ko": "대군을 상대할 땐 필사의 각오를 다져라!\n천하에 우리의 무용을 보여 주자.",
      "literal_id": 0,
      "record_id": 590,
      "source_sc_utf16le_sha256": "745D233E53B4C33FFED699DCC23E8F00FD9E664BC9A6D5F5EBB4AF5CFC32CA9D"
    },
    {
      "block_id": 2,
      "ko": "적의 수가 더 많은가.\n한 수라도 틀리지 않도록 신중한 계책으로 이기자.",
      "literal_id": 0,
      "record_id": 591,
      "source_sc_utf16le_sha256": "5ABACBFAA77FD04318E24D673D0907CAE93283E0A9A4D66A3000E4546E1EA953"
    },
    {
      "block_id": 2,
      "ko": "대적 따위 두렵지 않다.\n어린 도깨비의 창이 꿰뚫지 못할 것은 없다.",
      "literal_id": 0,
      "record_id": 592,
      "source_sc_utf16le_sha256": "4893FD468D88EB1FD7A527DBF6B14A5B2E7CC7798758420AFA19A504DB161CB2"
    },
    {
      "block_id": 2,
      "ko": "붉은 귀신의 병사는 수에 기대지 않는다.\n자, 혈로를 열어라.",
      "literal_id": 0,
      "record_id": 593,
      "source_sc_utf16le_sha256": "5AE5683D45DFDCC9F07F087DE32E710BAAD2DDC1BDD80FD068C59DB9533122CA"
    },
    {
      "block_id": 2,
      "ko": "『돌아갈 수 없는 흉일』은 사실이었나.\n……물론 강적을 모조리 쓰러뜨리고,\n출세하겠다는 뜻이다!",
      "literal_id": 0,
      "record_id": 594,
      "source_sc_utf16le_sha256": "8C32F30675DE593C99026DD26835F24D0856D63DCBE0255A54D84FE64E67F872"
    },
    {
      "block_id": 2,
      "ko": "모두 당황하지 마라.\n내 눈엔 호랑이보다 강한 적은 보이지 않는다.",
      "literal_id": 0,
      "record_id": 595,
      "source_sc_utf16le_sha256": "D7789713E580D3D660D546268490F6CB3D188BFFA9B577B0FA3B9D3B36EF7DB9"
    },
    {
      "block_id": 2,
      "ko": "전쟁은 병력의 많고 적음으로 정해지지 않는다.\n모두 하나 되어 대군을 뒤집자.",
      "literal_id": 0,
      "record_id": 596,
      "source_sc_utf16le_sha256": "3F54E9F9ABA882ED2A37946C06DDEDA3F63138B0D0F61DFDC5D2C31077828516"
    },
    {
      "block_id": 2,
      "ko": "적은 마왕인가……\n이 한판으로 아버지를 뛰어넘겠다!",
      "literal_id": 0,
      "record_id": 597,
      "source_sc_utf16le_sha256": "EBD0CFA0A27C24972417C699489A78CC652EDD0A53C03EDB4CE72044EAC2FDF7"
    },
    {
      "block_id": 2,
      "ko": "적을 얼간이라 여기지 마라.\n우리는 우리 방식으로 이길 뿐이다.",
      "literal_id": 0,
      "record_id": 598,
      "source_sc_utf16le_sha256": "00D4D510E1348BDDA1F109462ECCDFDF16A15143AE88D272DA4C1295FF204F6B"
    },
    {
      "block_id": 2,
      "ko": "얼간이인가, 걸물인가……\n직접 가려 보는 것도 재미있겠군.",
      "literal_id": 0,
      "record_id": 599,
      "source_sc_utf16le_sha256": "649E1F6E41940A45DAA85BAA4026B7EA4B83B181723C14769217BBEF48BBF7FE"
    },
    {
      "block_id": 2,
      "ko": "천하포무라니 불손하기 짝이 없다!\n비사문천을 대신해 토벌하겠다!",
      "literal_id": 0,
      "record_id": 600,
      "source_sc_utf16le_sha256": "B9D8E26D87E3A3F849739D211B657E11410540B7FC8C43881C01B9DDC207AA5D"
    },
    {
      "block_id": 2,
      "ko": "이 또한 난세의 이치……\n의형님, 각오하십시오!",
      "literal_id": 0,
      "record_id": 601,
      "source_sc_utf16le_sha256": "4668361FC76BA82938B40D7C8CDEB34F7D5B1891A6AC46C0F95C4A5A42DB6CB4"
    },
    {
      "block_id": 2,
      "ko": "감히",
      "literal_id": 0,
      "record_id": 602,
      "source_sc_utf16le_sha256": "0371C4098FB8C952B82BB78EF4130A43823FD67089BEE9A3627DB1E76A9B2B3B"
    },
    {
      "block_id": 2,
      "ko": "에게 활을 겨누다니 가소롭다.\n결국 벼락출세한 자일 뿐인가!",
      "literal_id": 1,
      "record_id": 602,
      "source_sc_utf16le_sha256": "C3205384C5A046A87F0BFCC7BD8A1E5B9A103A3D5085084246D593DFFDC8D52E"
    },
    {
      "block_id": 2,
      "ko": "수많은 굴욕을 잊을 수 없다……\n용서란 없다. 토벌할 뿐이다!",
      "literal_id": 0,
      "record_id": 603,
      "source_sc_utf16le_sha256": "3A0E7E8834172169E008E2018D2275E66625A5E641BED8063C92F61BA3336934"
    },
    {
      "block_id": 2,
      "ko": "왜 그러느냐, 애송이.\n새 다구가 탐나면 내 목을 노려 보아라.",
      "literal_id": 0,
      "record_id": 604,
      "source_sc_utf16le_sha256": "6780EE7E3DE9CD6ABE375A5E71DCCC9FCE529468AEEB4911FC6FE711E716773E"
    },
    {
      "block_id": 2,
      "ko": "큰아버님, 무례를 용서하십시오!\n이 독안룡에게 길을 내주십시오!",
      "literal_id": 0,
      "record_id": 605,
      "source_sc_utf16le_sha256": "6A204087C3E2728B7B5D9A48E285F672A50341D8500F8BD28C7436D9819B1550"
    },
    {
      "block_id": 2,
      "ko": "적이 가이의 호랑이라 해도,\n",
      "literal_id": 0,
      "record_id": 606,
      "source_sc_utf16le_sha256": "BA6AC3B172D62271BCF94DFC88B9B00E22C08378B11D96ACBDF34184EC871E99"
    },
    {
      "block_id": 2,
      "ko": "의 깃발 아래 패배는 용납하지 않는다.",
      "literal_id": 1,
      "record_id": 606,
      "source_sc_utf16le_sha256": "7E0232A7481B66ED19E7E1D8EDEBA987007B9B20B6A9816DED4BBABFB13DEF7E"
    },
    {
      "block_id": 2,
      "ko": "적은 가이의 호랑이인가……\n무, 무사로서 전율이 멎지 않는군!",
      "literal_id": 0,
      "record_id": 607,
      "source_sc_utf16le_sha256": "FD5970B39A3165D49F7854BFAA4763A5CA892B9536D4324FF8EA6AD0E7456A9D"
    },
    {
      "block_id": 2,
      "ko": "늙은 호랑이의 실력이 어느 정도인가!\n새로운 전투를 보여 주마!",
      "literal_id": 0,
      "record_id": 608,
      "source_sc_utf16le_sha256": "6807C9A56E21029FE4BA7960C058BD69F4886B4C86EAF25FBE33814D77667C75"
    },
    {
      "block_id": 2,
      "ko": "적이 군신이라면 우리는 마왕이다.\n앞을 막는 자는 모조리 쓰러뜨려라!",
      "literal_id": 0,
      "record_id": 609,
      "source_sc_utf16le_sha256": "40731AC36AE9AD15A6936E3CC25D69D4677FC07250BCCB154FE9098C5BF6E588"
    },
    {
      "block_id": 2,
      "ko": "미카와 무사여, 맞서는 기개는 훌륭하다.\n가이의 호랑이가 싸우는 법을 보여 주마.",
      "literal_id": 0,
      "record_id": 610,
      "source_sc_utf16le_sha256": "671A049209C7D8A27AD0CF44A88C394DCA65E88C89AE47E51C57500219F5CDDF"
    },
    {
      "block_id": 2,
      "ko": "미카와의 너구리도 제법 살이 올랐군……\n모두 마음 단단히 먹어라!",
      "literal_id": 0,
      "record_id": 611,
      "source_sc_utf16le_sha256": "B826A383B1C5069769FCC3E593332EEFBFA92CCF947816E6348A82B2FF754BD2"
    },
    {
      "block_id": 2,
      "ko": "불구대천의 원수와 마주치다니……\n달이여, 내 싸움을 지켜보아라!",
      "literal_id": 0,
      "record_id": 612,
      "source_sc_utf16le_sha256": "F70C37E73CD5E325F5F813612D4AEE4268FD9BBFD371274BEBF8652A7D22FDD2"
    },
    {
      "block_id": 2,
      "ko": "교활한 원숭이 놈……\n내 손으로 짓이겨 주마!",
      "literal_id": 0,
      "record_id": 613,
      "source_sc_utf16le_sha256": "E0F3C24A585A6CB0F2E2D7452402EB1A46240CC19CE4679228393478428CFF66"
    },
    {
      "block_id": 2,
      "ko": "모두 절대 방심하지 마라.\n적은 지략가다. 겹겹의 함정을 경계하라.",
      "literal_id": 0,
      "record_id": 614,
      "source_sc_utf16le_sha256": "1F7A5E8BF800560C63FA5901311A17569D80AD6C9AE276BF08C3DA1A83074C97"
    },
    {
      "block_id": 2,
      "ko": "서방님, 다녀오십시오.\n부디 무리는 하지 마세요……",
      "literal_id": 0,
      "record_id": 615,
      "source_sc_utf16le_sha256": "4EA96ECC528A3D23E879C2BE70A13A576FABB48FFDA6A11501B65AFE1852CA12"
    },
    {
      "block_id": 2,
      "ko": "집은 걱정 말고 맡겨 주세요.\n이곳은",
      "literal_id": 0,
      "record_id": 616,
      "source_sc_utf16le_sha256": "7DF57EFB4865BA07B822AA95D789ED72BC81D7AE2AB1AE555F717614EEAB9CDA"
    },
    {
      "block_id": 2,
      "ko": "이(가) 지키겠습니다.",
      "literal_id": 1,
      "record_id": 616,
      "source_sc_utf16le_sha256": "D830B5794499F40ABDD779203F85332B1C86368ADBCD80739D6F884448805C10"
    },
    {
      "block_id": 2,
      "ko": "님……\n이곳에서 돌아오시길 기다리겠습니다.",
      "literal_id": 0,
      "record_id": 617,
      "source_sc_utf16le_sha256": "04E6DBCB858C7BF772F0F459FDD52C29368697149E19A30A26067B4C9587C133"
    },
    {
      "block_id": 2,
      "ko": "님, 출진하시는군요.\n도움을 드릴 사람:",
      "literal_id": 0,
      "record_id": 618,
      "source_sc_utf16le_sha256": "E8CFE2E1CBC46661D1F5AB63B82AD47BF63F07402EB5F3A2DFF1DB18DAE313CF"
    },
    {
      "block_id": 2,
      "ko": "에게 시키실 일이 있다면 무엇이든 말씀해 주세요……",
      "literal_id": 1,
      "record_id": 618,
      "source_sc_utf16le_sha256": "08FB3548C6120CD3BFA53466BDB20C6F969FA2C5B8C4721CA9B6C494827D9242"
    },
    {
      "block_id": 2,
      "ko": "님과 함께할 사람:",
      "literal_id": 0,
      "record_id": 619,
      "source_sc_utf16le_sha256": "1BACAB2BD9848C41276D056E03A45BB169E7E2FA96D855C00E968539B36A8202"
    },
    {
      "block_id": 2,
      "ko": "\n둘이서 공을 세우겠습니다!",
      "literal_id": 1,
      "record_id": 619,
      "source_sc_utf16le_sha256": "D213CCEBE5666D4977FE1E1AEC23F921FEC906CB4F8D5E00D5701704DE940D8D"
    },
    {
      "block_id": 2,
      "ko": "! 늘 고맙다.\n집을 잘 부탁한다.",
      "literal_id": 0,
      "record_id": 620,
      "source_sc_utf16le_sha256": "DFAA9B7C142DF688B76D4CA4FF5B1B97137C8B2F485EA68E95B7A769E06F0263"
    },
    {
      "block_id": 2,
      "ko": "배웅하느라 수고했다.\n그 단도는 절대 놓지 마라.",
      "literal_id": 0,
      "record_id": 621,
      "source_sc_utf16le_sha256": "2D60B0F9B77897E2A1DC9AD9C8CDE4915B0B5B86A4B72BE5AB6D80B9B0F88379"
    },
    {
      "block_id": 2,
      "ko": "아, 늘 배웅해 줘 고맙다.\n전투의 승리를 네게 바치마.",
      "literal_id": 0,
      "record_id": 622,
      "source_sc_utf16le_sha256": "83B9C777BEBF89E042DEF2863E05F834815A5324EB4EEA495CD9685539C796EC"
    },
    {
      "block_id": 2,
      "ko": "늘 고생이 많다.\n공적의 주인:",
      "literal_id": 0,
      "record_id": 623,
      "source_sc_utf16le_sha256": "EE4C48CC180F6D20CE3835937D456CBB70555EC6EAD6B56E42BF88785E37BAA6"
    },
    {
      "block_id": 2,
      "ko": "을(를) 잊지 않겠다.",
      "literal_id": 1,
      "record_id": 623,
      "source_sc_utf16le_sha256": "B0E6AEDA812E19B31923FE0561DE6B4922CF6286DB7AAAABA436DF20C65024F4"
    },
    {
      "block_id": 2,
      "ko": "말한 사람:",
      "literal_id": 0,
      "record_id": 624,
      "source_sc_utf16le_sha256": "6714622744215A59D4FB872421149E63259D4262C17F1A4DFFB877FD7A055797"
    },
    {
      "block_id": 2,
      "ko": "의 말이 맞다!\n내 공은 곧 우리 둘의 공이다!",
      "literal_id": 1,
      "record_id": 624,
      "source_sc_utf16le_sha256": "83266E6F5CE37B227265AF010F0BFD868E7FFE316D691021FCCE972264ECCAE3"
    },
    {
      "block_id": 2,
      "ko": "의",
      "literal_id": 0,
      "record_id": 625,
      "source_sc_utf16le_sha256": "26F49E51C62FA11E4FD7D754851317555EF7091B2925FC9517397FEE5871CC3D"
    },
    {
      "block_id": 2,
      "ko": "님이 황천길에 올랐습니다.\n고인의 명복을 빕시다.",
      "literal_id": 1,
      "record_id": 625,
      "source_sc_utf16le_sha256": "D095E857FE46221ECF5FB20D18F77A4DA3B21AF5B56C6CD2F7C5A10F7C663FDD"
    },
    {
      "block_id": 2,
      "ko": "원수의 이름:",
      "literal_id": 0,
      "record_id": 626,
      "source_sc_utf16le_sha256": "75F888FCD20B812E5948499D4B743402FAF31B3EA274FCF4A691A010C1D00DEF"
    },
    {
      "block_id": 2,
      "ko": "다메노부",
      "literal_id": 1,
      "record_id": 626,
      "source_sc_utf16le_sha256": "E08C5B4FB74DB5EF462F0FB94EB65507FC473F405F56AD1D2A414EE1F77C299F"
    },
    {
      "block_id": 2,
      "ko": "!\n그가 얕본 가문:",
      "literal_id": 2,
      "record_id": 626,
      "source_sc_utf16le_sha256": "E52E9F6C5DAE4AF6789BE3A088B5170F227CC210225D7A6B8C5CB06A42E98604"
    },
    {
      "block_id": 2,
      "ko": "에게 무릎 꿇려라.",
      "literal_id": 3,
      "record_id": 626,
      "source_sc_utf16le_sha256": "7883AC685C1C3A6F9AB67EF73310156E4F89553EA9C2CCC3C5482083662A1213"
    },
    {
      "block_id": 2,
      "ko": "악귀",
      "literal_id": 0,
      "record_id": 627,
      "source_sc_utf16le_sha256": "00753980D8B6E09E696B0D742A38B3CC11A1ADDBF8A3E2D429C4E3BB70D39826"
    },
    {
      "block_id": 2,
      "ko": "이(가) 나선다!\n상대할 가문:",
      "literal_id": 1,
      "record_id": 627,
      "source_sc_utf16le_sha256": "D7DB58CBF1ADEAF522EC005FBC0FAAE4EF9064A02FF836C88F90316C3ADB700B"
    },
    {
      "block_id": 2,
      "ko": "다테",
      "literal_id": 2,
      "record_id": 627,
      "source_sc_utf16le_sha256": "9B147498A3872964171425525B40C01B41EBF27469C3C5373326583596BA4BF7"
    },
    {
      "block_id": 2,
      "ko": "의 애송이에게 본때를 보여 주마!",
      "literal_id": 3,
      "record_id": 627,
      "source_sc_utf16le_sha256": "CABB14419AA5D2510A58992F780990DE8C3DB76B3690CDE0508672E24A22B88E"
    },
    {
      "block_id": 2,
      "ko": "독안룡이 악귀",
      "literal_id": 0,
      "record_id": 628,
      "source_sc_utf16le_sha256": "F6ED0AE596F82838558170686CE600327D069DC7877A830ED6B35B1F8B7B346D"
    },
    {
      "block_id": 2,
      "ko": "사타케",
      "literal_id": 1,
      "record_id": 628,
      "source_sc_utf16le_sha256": "F2B7342F42DCBCD078C4093C50F257E639F03673AD6E3E500A4109549ADB0651"
    },
    {
      "block_id": 2,
      "ko": "를 제압해 주마.\n모두, 지금이 고비다!",
      "literal_id": 2,
      "record_id": 628,
      "source_sc_utf16le_sha256": "DCDBEB4A3415A83E4345026EA69611E6936BA764E95CC68237F55C89A2E724AA"
    },
    {
      "block_id": 2,
      "ko": "어리석은 공방이여,\n새 시대를 열 자:",
      "literal_id": 0,
      "record_id": 629,
      "source_sc_utf16le_sha256": "A8BCDFE882D796AA6403609CEB50C2478679DCFEA5DA91EAE5D5412D29A01636"
    },
    {
      "block_id": 2,
      "ko": "에게 네놈은 필요 없다!",
      "literal_id": 1,
      "record_id": 629,
      "source_sc_utf16le_sha256": "E2774BBAB4D880B0C12E9A130876E54F830B30FEADD08625BC4C4775B9359ADF"
    },
    {
      "block_id": 2,
      "ko": "여기는 내게 맡겨라!\n총구를 겨눌 자:",
      "literal_id": 0,
      "record_id": 630,
      "source_sc_utf16le_sha256": "16EC608E84E0DBFB0D78268097E3BB0AEE0750D491822096FF94DCBA0B14BB1E"
    },
    {
      "block_id": 2,
      "ko": "노부나가",
      "literal_id": 1,
      "record_id": 630,
      "source_sc_utf16le_sha256": "E61D3D8BB8C23FB55801218B8452CEAB7187E4B4BBFF9312A7C781C2192E6FB4"
    },
    {
      "block_id": 2,
      "ko": "에게 이 화승총의 위력을 맛보여 주마!",
      "literal_id": 2,
      "record_id": 630,
      "source_sc_utf16le_sha256": "3177BED8E805C236A122565563F2772FCC9EFB9D31DE7D64A23C6F2783A5B570"
    },
    {
      "block_id": 2,
      "ko": "적은 서국무쌍의 맹장:",
      "literal_id": 0,
      "record_id": 631,
      "source_sc_utf16le_sha256": "4AA7776F84A693CA59BC5B90814E8727E9629C0DF31D5EAFCCB9D7ABE0428CE8"
    },
    {
      "block_id": 2,
      "ko": "스에",
      "literal_id": 1,
      "record_id": 631,
      "source_sc_utf16le_sha256": "5FC9F11C5BF5B1816F7F6BFDA7FA3A03B25107BD8E3263C1D147B4222DB4DFDD"
    },
    {
      "block_id": 2,
      "ko": "!\n모든 계책을 동원해 맞서자!",
      "literal_id": 2,
      "record_id": 631,
      "source_sc_utf16le_sha256": "5C157BD40F710282A15B2462B8D652D3C909C2B7350250D332C08E1B25EEF806"
    },
    {
      "block_id": 2,
      "ko": "명문",
      "literal_id": 0,
      "record_id": 632,
      "source_sc_utf16le_sha256": "9ADE3DBA505D977E646ADCD17E0298C75F75E7186784BFE913DEF1EFB0FA57ED"
    },
    {
      "block_id": 2,
      "ko": "이치조",
      "literal_id": 1,
      "record_id": 632,
      "source_sc_utf16le_sha256": "44B532E09E7D5EE5E6ADE067ED776898650F9BA46CF15D65EC7739EA83D8AFCE"
    },
    {
      "block_id": 2,
      "ko": "가문도 두렵지 않다.\n하극상을 이룰 자:",
      "literal_id": 2,
      "record_id": 632,
      "source_sc_utf16le_sha256": "B96B72C73C25DBBAA2168D65F2281042D4EEDB12CD0562BB4E6849351E420098"
    },
    {
      "block_id": 2,
      "ko": "!",
      "literal_id": 3,
      "record_id": 632,
      "source_sc_utf16le_sha256": "F529BEF1C12255705F4203E327BC8C352972FD24905B4AAD52889D974A52B5B6"
    },
    {
      "block_id": 2,
      "ko": "지금이 절호의 기회다.\n쓰러뜨릴 상대:",
      "literal_id": 0,
      "record_id": 633,
      "source_sc_utf16le_sha256": "B9D2F306AF82619D754AAD770A4DBBE7C9F3FE0FC85974D368E1CA6593927D30"
    },
    {
      "block_id": 2,
      "ko": "오토모",
      "literal_id": 1,
      "record_id": 633,
      "source_sc_utf16le_sha256": "461968A325FBF519BC25F5AAB253A1BC9CC6948E900A6C0B58AB6A290B229F6E"
    },
    {
      "block_id": 2,
      "ko": "를 꺾고 규슈를 제패하자.",
      "literal_id": 2,
      "record_id": 633,
      "source_sc_utf16le_sha256": "B4EAE5838A57F56761F9BA03D0419621A7ECCA28E3FF8742F13311FD33F837E3"
    },
    {
      "block_id": 2,
      "ko": "어리석은",
      "literal_id": 0,
      "record_id": 634,
      "source_sc_utf16le_sha256": "54B605B96BC7B7A30E7B092D31EBDD257767CC97B8705C3DBE6690DB6BE0CF4F"
    },
    {
      "block_id": 2,
      "ko": "시마즈",
      "literal_id": 1,
      "record_id": 634,
      "source_sc_utf16le_sha256": "F7BB5C41BCF30803935639676D53F7312A0908A8F0E4CD7C0B2ED883579F376F"
    },
    {
      "block_id": 2,
      "ko": "여,\n신의 위광을 똑똑히 보아라!",
      "literal_id": 2,
      "record_id": 634,
      "source_sc_utf16le_sha256": "D94CBD9F6575737A3FF13A66BE3CD13CF3DDAF5D9B35CF57CD0F5C5EB207E14D"
    },
    {
      "block_id": 2,
      "ko": "모두 출진할 때다!\n쓰러뜨릴 상대:",
      "literal_id": 0,
      "record_id": 635,
      "source_sc_utf16le_sha256": "5648C2C146D262FE9D4DDE97DEC3AB4A82B0848C23062E4C71152752EE5C7058"
    },
    {
      "block_id": 2,
      "ko": "시마즈",
      "literal_id": 1,
      "record_id": 635,
      "source_sc_utf16le_sha256": "F7BB5C41BCF30803935639676D53F7312A0908A8F0E4CD7C0B2ED883579F376F"
    },
    {
      "block_id": 2,
      "ko": "쯤은 단숨에 격파해 주마!",
      "literal_id": 2,
      "record_id": 635,
      "source_sc_utf16le_sha256": "98A107372B7536F3A1193D89C67082746725BDBC91DD151796B7821C4B5E45E2"
    },
    {
      "block_id": 2,
      "ko": "의",
      "literal_id": 0,
      "record_id": 636,
      "source_sc_utf16le_sha256": "26F49E51C62FA11E4FD7D754851317555EF7091B2925FC9517397FEE5871CC3D"
    },
    {
      "block_id": 2,
      "ko": "님 등\n",
      "literal_id": 1,
      "record_id": 636,
      "source_sc_utf16le_sha256": "39D255233F33C041D7A905E38B1991962179CF8A9C2FEF83398A7DCAE8A81F30"
    },
    {
      "block_id": 2,
      "ko": "명이 황천길에 올랐습니다.\n고인들의 명복을 빕시다.",
      "literal_id": 2,
      "record_id": 636,
      "source_sc_utf16le_sha256": "9F6BA908103C18BB5EE893F3258BAB6E511F95691A802D0F36F600E127DD4151"
    },
    {
      "block_id": 2,
      "ko": "당주",
      "literal_id": 0,
      "record_id": 637,
      "source_sc_utf16le_sha256": "B3C1F75ED4916A01C7651AE97444784945168D30C01965CAC4D6EFAFD4C0B945"
    },
    {
      "block_id": 2,
      "ko": "님이\n서거하셨습니다.",
      "literal_id": 1,
      "record_id": 637,
      "source_sc_utf16le_sha256": "88FB135DCE18692B59F328C491C72C1126B4268AD7762CD41DE1B72DA89A2D19"
    },
    {
      "block_id": 2,
      "ko": "의",
      "literal_id": 0,
      "record_id": 638,
      "source_sc_utf16le_sha256": "26F49E51C62FA11E4FD7D754851317555EF7091B2925FC9517397FEE5871CC3D"
    },
    {
      "block_id": 2,
      "ko": "님 등\n여러 세력의 당주가 서거한 듯합니다.",
      "literal_id": 1,
      "record_id": 638,
      "source_sc_utf16le_sha256": "77E2052BF4F4C847291F5B637393EAD18211D7BE041F1C5BBCA3A7EBA69B9AB6"
    },
    {
      "block_id": 2,
      "ko": "주군께서 서거하셨습니다.\n임종에 유언을 남기셨다고 합니다.",
      "literal_id": 0,
      "record_id": 639,
      "source_sc_utf16le_sha256": "E300A200E31D9C3231BAE9EFFADEC98E8328ED5FFE2920F19759AE6449090408"
    },
    {
      "block_id": 2,
      "ko": "적은 소문난 지장:",
      "literal_id": 0,
      "record_id": 640,
      "source_sc_utf16le_sha256": "9BCAF5F6CBD8FA4A03B7FB620506A1919C55AD83798C7D3EFE137EDE2578CAF8"
    },
    {
      "block_id": 2,
      "ko": ",\n내 상대로 부족함이 없다!",
      "literal_id": 1,
      "record_id": 640,
      "source_sc_utf16le_sha256": "A3D04BAE233B7A9111F67A0F19D7E1CDD773C15DFEAE5103B1023492ACBF6E75"
    },
    {
      "block_id": 2,
      "ko": "적은 소문난 지장:",
      "literal_id": 0,
      "record_id": 641,
      "source_sc_utf16le_sha256": "9BCAF5F6CBD8FA4A03B7FB620506A1919C55AD83798C7D3EFE137EDE2578CAF8"
    },
    {
      "block_id": 2,
      "ko": ",\n지략을 다해 승기를 잡자.",
      "literal_id": 1,
      "record_id": 641,
      "source_sc_utf16le_sha256": "121087F1DFDF8DDBDA44C722169C7956FBA48C8EDD98EF4F5D5573F14F682C80"
    },
    {
      "block_id": 2,
      "ko": "부인께서 황천길에 오르셨습니다.\n고인의 명복을 빕시다.",
      "literal_id": 0,
      "record_id": 642,
      "source_sc_utf16le_sha256": "D1B5A5265E6E0F7D370F43705546D295E55B121A51CDD74F7451AC82E18A3029"
    },
    {
      "block_id": 2,
      "ko": "군단장이 없어져,\n",
