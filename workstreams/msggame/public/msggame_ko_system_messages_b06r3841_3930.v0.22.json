    {
      "block_id": 6,
      "ko": "이번에는",
      "literal_id": 0,
      "record_id": 3848,
      "source_sc_utf16le_sha256": "C76DC3D042B3570CEE7C56F90882B65B0F452DC076BC45C429CA49901B360BE0"
    },
    {
      "block_id": 6,
      "ko": "의 체면을 보아,\n상대",
      "literal_id": 1,
      "record_id": 3848,
      "source_sc_utf16le_sha256": "E8B735091495D38E7DB4756846E5DBA61841BA134BB965EADA19F45846F81F66"
    },
    {
      "block_id": 6,
      "ko": "와의 전쟁을,\n멈춰 주실 수 있겠습니까?",
      "literal_id": 2,
      "record_id": 3848,
      "source_sc_utf16le_sha256": "A5E984596245F10AC19A6D4EA4C50E09DBB137F6279D739717CE6E777F1373BD"
    },
    {
      "block_id": 6,
      "ko": "……알겠습니다.\n이번에는",
      "literal_id": 0,
      "record_id": 3849,
      "source_sc_utf16le_sha256": "A8A5368D71FEA64BE7D7CB4E9584E3805FE5113A3E9F3A9D8C3C569B9D19B56B"
    },
    {
      "block_id": 6,
      "ko": "의 체면을 보아,\n상대",
      "literal_id": 1,
      "record_id": 3849,
      "source_sc_utf16le_sha256": "E8B735091495D38E7DB4756846E5DBA61841BA134BB965EADA19F45846F81F66"
    },
    {
      "block_id": 6,
      "ko": "와 정전하겠습니다. ",
      "literal_id": 2,
      "record_id": 3849,
      "source_sc_utf16le_sha256": "F9F4E2A58B68D0DBB9B71A2D0336C94AB400D69D16493AD607A4E63071FC0059"
    },
    {
      "block_id": 6,
      "ko": "에게는",
      "literal_id": 0,
      "record_id": 3850,
      "source_sc_utf16le_sha256": "0CEFEFF4B4617ECF6A1662FC44F111376E68261C6F1250E722AE78C143B4C306"
    },
    {
      "block_id": 6,
      "ko": "와의 동맹이 있어,\n섣불리 공격하는 것은 위험합니다.",
      "literal_id": 1,
      "record_id": 3850,
      "source_sc_utf16le_sha256": "1077085D6851EB98E3B4DB493B190F63FAA09F63BAC68ED27E7CC77A9AA9E582"
    },
    {
      "block_id": 6,
      "ko": "와",
      "literal_id": 0,
      "record_id": 3851,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 6,
      "ko": "의 동맹을",
      "literal_id": 1,
      "record_id": 3851,
      "source_sc_utf16le_sha256": "9C28BD323679FF092175BFBAC5B59CCE7225A9CEC6D30142CA1227C5424760B2"
    },
    {
      "block_id": 6,
      "ko": "개월 연장했습니다.",
      "literal_id": 2,
      "record_id": 3851,
      "source_sc_utf16le_sha256": "F5724FAFF8A44236862A8FE1131AE5970667E61D8EFC4CBCD8E6708BEDD71726"
    },
    {
      "block_id": 6,
      "ko": "와",
      "literal_id": 0,
      "record_id": 3852,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 6,
      "ko": "의 정전을",
      "literal_id": 1,
      "record_id": 3852,
      "source_sc_utf16le_sha256": "7F7BD5B3621C4E8C389956D32EF2BAD3C03931821E544339C594E992E04AF44B"
    },
    {
      "block_id": 6,
      "ko": "개월 연장했습니다.",
      "literal_id": 2,
      "record_id": 3852,
      "source_sc_utf16le_sha256": "F5724FAFF8A44236862A8FE1131AE5970667E61D8EFC4CBCD8E6708BEDD71726"
    },
    {
      "block_id": 6,
      "ko": "상대",
      "literal_id": 0,
      "record_id": 3853,
      "source_sc_utf16le_sha256": "62D5D8E7F7D29AE9B6CE8468CD8DCD8B898A6DEC335664A21DA159D7D314AC1C"
    },
    {
      "block_id": 6,
      "ko": "의 영내에 병력이 남아 있어,\n동맹이 연장되었지만,\n주변 세력은 불신을 품고 있습니다……",
      "literal_id": 1,
      "record_id": 3853,
      "source_sc_utf16le_sha256": "445FBF565C8FA07DFA7D1DE114D1E2BB8AA0205DF63390D6103698399B1E3462"
    },
    {
      "block_id": 6,
      "ko": "상대",
      "literal_id": 0,
      "record_id": 3854,
      "source_sc_utf16le_sha256": "62D5D8E7F7D29AE9B6CE8468CD8DCD8B898A6DEC335664A21DA159D7D314AC1C"
    },
    {
      "block_id": 6,
      "ko": "의 영내에 병력이 남아 있어,\n정전이 연장되었지만,\n주변 세력은 불신을 품고 있습니다……",
      "literal_id": 1,
      "record_id": 3854,
      "source_sc_utf16le_sha256": "445FBF565C8FA07DFA7D1DE114D1E2BB8AA0205DF63390D6103698399B1E3462"
    },
    {
      "block_id": 6,
      "ko": "다음 관직:",
      "literal_id": 0,
      "record_id": 3855,
      "source_sc_utf16le_sha256": "6742E709851AD9F0B752081AFC7F5F41C0E18F65483F94A5D24669D0E5758781"
    },
    {
      "block_id": 6,
      "ko": "이지만,\n본가의 위신이 부족해\n추천을 받기 어려울 듯합니다.",
      "literal_id": 1,
      "record_id": 3855,
      "source_sc_utf16le_sha256": "10549CEA173E5E18BAFC7EE7C8E4B133D4D3B2D23DA0E633D9824CF63E7CC7E7"
    },
    {
      "block_id": 6,
      "ko": "다음으로,\n상대",
      "literal_id": 0,
      "record_id": 3856,
      "source_sc_utf16le_sha256": "EA66790607F6D77C8B282856B4E60C4474674FEDD0D176D59DEC732E462E52A9"
    },
    {
      "block_id": 6,
      "ko": "의 관직 추천을 추진해 봅시다.",
      "literal_id": 1,
      "record_id": 3856,
      "source_sc_utf16le_sha256": "03B7B267542F8CBD59C1AF9C69BCC2CD4D84828A6CC5414B90B4BCD8AC572E0D"
    },
    {
      "block_id": 6,
      "ko": "다음 관직:",
      "literal_id": 0,
      "record_id": 3857,
      "source_sc_utf16le_sha256": "6742E709851AD9F0B752081AFC7F5F41C0E18F65483F94A5D24669D0E5758781"
    },
    {
      "block_id": 6,
      "ko": "이지만,\n본가의 위신과 가문 격이 다소 부족해\n상당한 금전이 들 듯합니다.",
      "literal_id": 1,
      "record_id": 3857,
      "source_sc_utf16le_sha256": "D23FFEAAA56BE767456084EFCF33C7B486C008A6BC0E7CD6B552365055475EDB"
    },
    {
      "block_id": 6,
      "ko": "연락 무장이 없어,\n조정의 신용이 오르지 않습니다.",
      "literal_id": 0,
      "record_id": 3858,
      "source_sc_utf16le_sha256": "8BFE842879BB349848057A187E71F32C0ED6DF0756E116D04B6EF7C3D3B2CAC2"
    },
    {
      "block_id": 6,
      "ko": "조정의 신용을 충분히 얻었지만,\n관직에 빈자리가 없다고 합니다……\n헌금을 중단하고 기다릴 수밖에 없습니다.",
      "literal_id": 0,
      "record_id": 3859,
      "source_sc_utf16le_sha256": "375F64429D83BA91216C5595F74E875B1DB7DD45D5D761B1DEC9F938FC3F0B55"
    },
    {
      "block_id": 6,
      "ko": "그대의 근왕의 뜻은 잘 알겠다.\n천자의 명으로",
      "literal_id": 0,
      "record_id": 3860,
      "source_sc_utf16le_sha256": "5A30F7D65D4B39792F3AB9D66A5399ABDB6529A71E46F5BCB8C346613F1D5A84"
    },
    {
      "block_id": 6,
      "ko": "을 내리겠다.",
      "literal_id": 1,
      "record_id": 3860,
      "source_sc_utf16le_sha256": "99060DCF4871333C4F69D0FCA880AD693CEB3CC4F47923C1BC5ED1852BC3898B"
    },
    {
      "block_id": 6,
      "ko": "비용이 들더라도,\n상대",
      "literal_id": 0,
      "record_id": 3861,
      "source_sc_utf16le_sha256": "6D7C695BAF98744862A61CE8BAA2F3C90811977D8CE6AE1541141CDDBDD80024"
    },
    {
      "block_id": 6,
      "ko": ",\n상대",
      "literal_id": 1,
      "record_id": 3861,
      "source_sc_utf16le_sha256": "80915EA501D9F85953C630E3DC9881B64D37F053FFF8E8D7D04252FD30EB5145"
    },
    {
      "block_id": 6,
      "ko": "에 잘 청원합시다.",
      "literal_id": 2,
      "record_id": 3861,
      "source_sc_utf16le_sha256": "99E83FF607108EF2E2FC9258001A533D8EA59DC52B99A21CEB1238929D81B099"
    },
    {
      "block_id": 6,
      "ko": "그대가",
      "literal_id": 0,
      "record_id": 3862,
      "source_sc_utf16le_sha256": "2294A039FC84A9ABD76E4E852E59173EC11ABA10A13454E053A9A9288837E869"
    },
    {
      "block_id": 6,
      "ko": "에 임명되었다는 소식을 들으면,\n분명 기뻐 춤출 것입니다.",
      "literal_id": 1,
      "record_id": 3862,
      "source_sc_utf16le_sha256": "D777A5D5B0E3D1FFAECA7BD5774E235E3678CF3EB97C7CAF9D122C5383B74D8B"
    },
    {
      "block_id": 6,
      "ko": "그대가",
      "literal_id": 0,
      "record_id": 3863,
      "source_sc_utf16le_sha256": "254CE47479C6203C42024945AFE516095254F981679F0BC81BC21C1398E31EF9"
    },
    {
      "block_id": 6,
      "ko": "에 임명되어,\n기뻐하지 않을 다이묘가 어디 있겠는가.",
      "literal_id": 1,
      "record_id": 3863,
      "source_sc_utf16le_sha256": "95C10645CEC91ECBD25C20EBCA86DF00035018BFC0B79E0E801CF4B3F80B7C60"
    },
    {
      "block_id": 6,
      "ko": "께서,\n",
      "literal_id": 0,
      "record_id": 3864,
      "source_sc_utf16le_sha256": "C3AAB26FF65A8CD8F5194C27CF3B7647831AAFFB7373E33C3197DC1FF857062F"
    },
    {
      "block_id": 6,
      "ko": "가 막부 사자로 찾아왔습니다.",
      "literal_id": 1,
      "record_id": 3864,
      "source_sc_utf16le_sha256": "786F3ABE0AD16A72DE150AA02C064C7717E64F292292CC7D59388DB75F799B4F"
    },
    {
      "block_id": 6,
      "ko": "의",
      "literal_id": 0,
      "record_id": 3865,
      "source_sc_utf16le_sha256": "ADBBFEEE15F23F91E370F71BB0E15814EFBC6C21C5E94184201C3A3D5B33658A"
    },
    {
      "block_id": 6,
      "ko": "활약이 주목받아,\n관직",
      "literal_id": 1,
      "record_id": 3865,
      "source_sc_utf16le_sha256": "739ECB53C40012E7EECBFE14E457BAA65CB805A6B3A2A1C492E92B630BAF5DF3"
    },
    {
      "block_id": 6,
      "ko": "의 중책을 맡게 되었습니다……\n더없는 영광입니다.",
      "literal_id": 2,
      "record_id": 3865,
      "source_sc_utf16le_sha256": "D8A1B46F15C6F26BDB100FB94426C5AB5CE2E88981B122145C67118F40D3DD59"
    },
    {
      "block_id": 6,
      "ko": "그대가",
      "literal_id": 0,
      "record_id": 3866,
      "source_sc_utf16le_sha256": "D58E8AA3D7249D6166B509E42270DA3313C60FA1754B087EB64EF3B9BA0B76A7"
    },
    {
      "block_id": 6,
      "ko": "에 임명되면,\n임지 국중에 대한 영향력도 높아질 것입니다.",
      "literal_id": 1,
      "record_id": 3866,
      "source_sc_utf16le_sha256": "41A113518DE13AE178B1193CB60D5BD7B78A66B9016F32FFAC9451FFBA849C96"
    },
    {
      "block_id": 6,
      "ko": "그대가",
      "literal_id": 0,
      "record_id": 3867,
      "source_sc_utf16le_sha256": "D58E8AA3D7249D6166B509E42270DA3313C60FA1754B087EB64EF3B9BA0B76A7"
    },
    {
      "block_id": 6,
      "ko": "에 임명되면,\n본가의 위신도 더욱 높아질 것입니다.",
      "literal_id": 1,
      "record_id": 3867,
      "source_sc_utf16le_sha256": "77BDA0AB46AA4C36C960B8834C2963C6766E8C711F5495D58B5C45F1C91F1E1D"
    },
    {
      "block_id": 6,
      "ko": "뭐라고?관직",
      "literal_id": 0,
      "record_id": 3868,
      "source_sc_utf16le_sha256": "FB6A48828F5A6294ED709C650A1351C175849685B7BE1F1AF3303AE82A54D452"
    },
    {
      "block_id": 6,
      "ko": "취임을 거절하다니……!",
      "literal_id": 1,
      "record_id": 3868,
      "source_sc_utf16le_sha256": "C6364ADDB826380966DCC3C2A2E59D11991919F7DA6195196FAAF9A5F0205583"
    },
    {
      "block_id": 6,
      "ko": "취임은,\n대단히 죄송하지만 사양하겠습니다.",
      "literal_id": 0,
      "record_id": 3869,
      "source_sc_utf16le_sha256": "29C3A2B5C80DA659553A574E378A3BC535D1AB922183ED9ABB3311E0944D0818"
    },
    {
      "block_id": 6,
      "ko": "동의:",
      "literal_id": 0,
      "record_id": 3870,
      "source_sc_utf16le_sha256": "13FEDEDF19DF1338CF7BEDC39393EEE99C34C730623D103F1BCA0576900344E5"
    },
    {
      "block_id": 6,
      "ko": "가",
      "literal_id": 1,
      "record_id": 3870,
      "source_sc_utf16le_sha256": "075237D9C3B4C13F5AA65D60023ABEDD01997F9E587490B06BF48371AC28557F"
    },
    {
      "block_id": 6,
