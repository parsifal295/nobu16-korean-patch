      "source_sc_utf16le_sha256": "F5B9A959D25FBFB5FE8262193A8FA6C771C8C7454D1360B256459DD98AA19EC1"
    },
    {
      "block_id": 6,
      "ko": "」의 발전을 중단했습니다.",
      "literal_id": 1,
      "record_id": 3874,
      "source_sc_utf16le_sha256": "9F6573AE3B80DD3D7FB09C4D786EC0A8A49AD1163BA3DE766786882B63EE5DBC"
    },
    {
      "block_id": 6,
      "ko": "발전 한도에 도달해 정책「",
      "literal_id": 0,
      "record_id": 3875,
      "source_sc_utf16le_sha256": "68C65871EB09480B0FCCDF36D61BBE90B50E2FD86A5AE5770C10E6CAB5611C1B"
    },
    {
      "block_id": 6,
      "ko": "」의 발전을 중단했습니다.",
      "literal_id": 1,
      "record_id": 3875,
      "source_sc_utf16le_sha256": "9F6573AE3B80DD3D7FB09C4D786EC0A8A49AD1163BA3DE766786882B63EE5DBC"
    },
    {
      "block_id": 6,
      "ko": "무장이 없어 정책「",
      "literal_id": 0,
      "record_id": 3876,
      "source_sc_utf16le_sha256": "D64A2AC1B8528FB1E640BFBD9378F8BFCE28E9E006CAD2A2C55EE9D8CEC6E42A"
    },
    {
      "block_id": 6,
      "ko": "」의 작업을 중단했습니다.",
      "literal_id": 1,
      "record_id": 3876,
      "source_sc_utf16le_sha256": "5C66C30407977CBD12616342B960635DA7D0752E2890FBCBD80FA9281C21AB2A"
    },
    {
      "block_id": 6,
      "ko": "이대로면 금전 수지가 적자가 됩니다.\n계속하시겠습니까?",
      "literal_id": 0,
      "record_id": 3877,
      "source_sc_utf16le_sha256": "C4F0758572B8A38D547B83D0BEDF514B870C52ABE4BEF22E3DE617C67F643D4F"
    },
    {
      "block_id": 6,
      "ko": "봉행 변경으로 정책“",
      "literal_id": 0,
      "record_id": 3878,
      "source_sc_utf16le_sha256": "54C3A37C547C677BF413EF9C4A1664C5B78FC205F5E5E62D0F37BA71D081DADA"
    },
    {
      "block_id": 6,
      "ko": "”의 발전을 중단했습니다.",
      "literal_id": 1,
      "record_id": 3878,
      "source_sc_utf16le_sha256": "69451FEBD02C858FF168C7EFAEAEFE6AEA3A787A0978C7396CFE37C17CF78094"
    },
    {
      "block_id": 6,
      "ko": "봉행 변경으로 정책“",
      "literal_id": 0,
      "record_id": 3879,
      "source_sc_utf16le_sha256": "54C3A37C547C677BF413EF9C4A1664C5B78FC205F5E5E62D0F37BA71D081DADA"
    },
    {
      "block_id": 6,
      "ko": "”을 철회했습니다.",
      "literal_id": 1,
      "record_id": 3879,
      "source_sc_utf16le_sha256": "8360300ADFF2E78BB638783DB198B96475AC4627054153D6EFA9511CFBB33FEE"
    },
    {
      "block_id": 6,
      "ko": "철거 대상:",
      "literal_id": 0,
      "record_id": 3880,
      "source_sc_utf16le_sha256": "51FCA2320CA63068B701ADF6EC8E42D807CFD71D871899529D7461DD9D79DD32"
    },
    {
      "block_id": 6,
      "ko": "을 철거하시겠습니까?",
      "literal_id": 1,
      "record_id": 3880,
      "source_sc_utf16le_sha256": "FDC76E124CEE30B06FDEABC0D43F83CCC233B412AE4D2879F65183506AFF2564"
    },
    {
      "block_id": 6,
      "ko": "건설의 임무, 알겠습니다.\n이번에",
      "literal_id": 0,
      "record_id": 3881,
      "source_sc_utf16le_sha256": "20733ADE6CF28B8BCFFA3610C4BDBB414A7260A8B0E77828C7F0EA757F80A7CC"
    },
    {
      "block_id": 6,
      "ko": "을 완성하면,\n반드시 본가에 이로울 것입니다.",
      "literal_id": 1,
      "record_id": 3881,
      "source_sc_utf16le_sha256": "3C624A0474A477AF1161EC348AB8F6C2DE75D28BCE4471CE04781C35501A91B6"
    },
    {
      "block_id": 6,
      "ko": "알겠습니다,\n그대가",
      "literal_id": 0,
      "record_id": 3882,
      "source_sc_utf16le_sha256": "9AB91FDBF032412E9CF79A2C8BB50DFE1F999C4835EAAF8F9F9770144FE393A7"
    },
    {
      "block_id": 6,
      "ko": "나서면,\n",
      "literal_id": 1,
      "record_id": 3882,
      "source_sc_utf16le_sha256": "78967C56557762F862C2F0634F767BCA0A783276072546E880C3879109CC7197"
    },
    {
      "block_id": 6,
      "ko": "의 건설쯤은 식은 죽 먹기입니다.",
      "literal_id": 2,
      "record_id": 3882,
      "source_sc_utf16le_sha256": "04F275744667AF38032D52ECB276FE230121FCBD61E7BB9E5AB66B2CD6780564"
    },
    {
      "block_id": 6,
      "ko": "의 건설은 훌륭한 계책이니,\n즉시 시행하겠습니다.",
      "literal_id": 0,
      "record_id": 3883,
      "source_sc_utf16le_sha256": "8370B531E1D4B08AEC1C64C45B2965BE5A09A2AB55309FDCCE50CF059DF8D34D"
    },
    {
      "block_id": 6,
      "ko": "건설 시작:",
      "literal_id": 0,
      "record_id": 3884,
      "source_sc_utf16le_sha256": "339F653AAF2FE5B0C400D8A511C9D2E27F333338D81B71A2A819C30269A02856"
    },
    {
      "block_id": 6,
      "ko": "의 건설을 시작하겠습니다.\n부지런히 일한 자에게는 큰 상을 내릴 테니,\n모두 힘써 주십시오.",
      "literal_id": 1,
      "record_id": 3884,
      "source_sc_utf16le_sha256": "84789B5C53D565D43F51E14F9EFA0D245CFA202ED860FEE4D7629AB7A6A50FD7"
    },
    {
      "block_id": 6,
      "ko": "건설 시작:",
      "literal_id": 0,
      "record_id": 3885,
      "source_sc_utf16le_sha256": "339F653AAF2FE5B0C400D8A511C9D2E27F333338D81B71A2A819C30269A02856"
    },
    {
      "block_id": 6,
      "ko": "의 건설에 힘써,\n우리 성하를 더욱 훌륭하게 만들겠습니다.",
      "literal_id": 1,
      "record_id": 3885,
      "source_sc_utf16le_sha256": "A503921BCB11CDEACE0D86381D51E1E3F404CAB26758D501338AC7BA51F9D8D9"
    },
    {
      "block_id": 6,
      "ko": "우리 성하에",
      "literal_id": 0,
      "record_id": 3886,
      "source_sc_utf16le_sha256": "E26FD40E471EA5BE1B26C223CE3D03D5C043E50B3290F5A6AEC4B162FA5B2AF2"
    },
    {
      "block_id": 6,
      "ko": "을 건설하겠습니다.\n손을 빼지 말고 후세에 남길 만한 것으로 합시다.",
      "literal_id": 1,
      "record_id": 3886,
      "source_sc_utf16le_sha256": "F320BAD4DABEB8A0DB798E4E035832EC946B8C957A87885F8D6BBA85E44EB62A"
    },
    {
      "block_id": 6,
      "ko": "이제 시간을 진행하면 시설 건설이 시작됩니다.\n이번은 튜토리얼이므로 금전과 노동력은 들지 않습니다.\n건설 결과도 곧바로 확인할 수 있습니다.",
      "literal_id": 0,
      "record_id": 3887,
      "source_sc_utf16le_sha256": "1FEB5F72F8655BEFCCCC0FE78ABAB3CDB39716E376623DE5F74A22F50241181E"
    },
    {
      "block_id": 6,
      "ko": "직위를 내려 준 것에 감사하고 있습니다.",
      "literal_id": 0,
      "record_id": 3889,
      "source_sc_utf16le_sha256": "4E032954E88F9FA0A9EB6C73CCC3E165327A083248315FDC54058014CBCE49F7"
    },
    {
      "block_id": 6,
      "ko": "선물을 준 것에 감사하고 있습니다.",
      "literal_id": 0,
      "record_id": 3890,
      "source_sc_utf16le_sha256": "BBAFE1D984090199860312E8F4029FC44BC356D0378835F587A30D64AE8A7776"
    },
    {
      "block_id": 6,
      "ko": "본가의 세력에 일목을 두고 있습니다.",
      "literal_id": 0,
      "record_id": 3891,
      "source_sc_utf16le_sha256": "A6376516C3346EADCC29A8261A6869114E951ED836AE3CC551ED356946EDE93C"
    },
    {
      "block_id": 6,
      "ko": "혼인 관계에 있어\n신뢰할 수 있습니다.",
      "literal_id": 0,
      "record_id": 3892,
      "source_sc_utf16le_sha256": "4912DBB685E4702351CC7095538DFA63357F184C9D47A9D4286671D6ACAC2308"
    },
    {
      "block_id": 6,
      "ko": "동맹으로서 신뢰하고 있습니다.",
      "literal_id": 0,
      "record_id": 3893,
      "source_sc_utf16le_sha256": "4A687976EA8217340546745620205800297DFD78913CAAC53A14246AFDB6A758"
    },
    {
      "block_id": 6,
      "ko": "주종 관계에 있는 세력으로서\n신뢰하고 있습니다.",
      "literal_id": 0,
      "record_id": 3894,
      "source_sc_utf16le_sha256": "4838A814CEA3BAEDB7D787B10792E382B98995BB651AF73B99B36EB88F1D8E67"
    },
    {
      "block_id": 6,
      "ko": "본가를 매우 신뢰하고 있습니다.",
      "literal_id": 0,
      "record_id": 3895,
      "source_sc_utf16le_sha256": "BA622D3E726489DA2BB0EE2D351EE5020831BE4E1AF4AB99EE22B1502BA36B57"
    },
    {
      "block_id": 6,
      "ko": "에",
      "literal_id": 0,
      "record_id": 3896,
      "source_sc_utf16le_sha256": "075237D9C3B4C13F5AA65D60023ABEDD01997F9E587490B06BF48371AC28557F"
    },
    {
      "block_id": 6,
      "ko": "\n호감을 품고 있습니다.",
      "literal_id": 1,
      "record_id": 3896,
      "source_sc_utf16le_sha256": "772367709BEC29FA4DCAD533E9DEDD6C2DD40FC58647605907721F863569CDA5"
    },
    {
      "block_id": 6,
      "ko": "와",
      "literal_id": 0,
      "record_id": 3897,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 6,
      "ko": "\n마음이 잘 맞습니다.",
      "literal_id": 1,
      "record_id": 3897,
      "source_sc_utf16le_sha256": "7DF11DBE83856E754DF6A7409C5F6782D42DE06E3513FEE76EE334D8B872C4AF"
    },
    {
      "block_id": 6,
      "ko": "선물로 경계를 풀었습니다.",
      "literal_id": 0,
      "record_id": 3898,
      "source_sc_utf16le_sha256": "C59EE7111F30E6AA6BAB227C40C6D2FB7F9A997F5D06598F12F86E667BFCD709"
    },
    {
      "block_id": 6,
      "ko": "본가의 기세를 주시하고 있습니다.",
      "literal_id": 0,
      "record_id": 3899,
      "source_sc_utf16le_sha256": "17C190F1087955AC75229A01C108EEECD8A0F8ED69019FC312FA039007BEE98C"
    },
    {
      "block_id": 6,
      "ko": "원군 요청은 거절했지만\n납득하고 있습니다.",
      "literal_id": 0,
      "record_id": 3900,
      "source_sc_utf16le_sha256": "0D830485A414829E22EE72506E6D547476D90141ED1EBC7ACB74E252B40E6D8C"
    },
    {
      "block_id": 6,
      "ko": "불의를 저지른\n본가를 의심하고 있습니다.",
      "literal_id": 0,
      "record_id": 3901,
      "source_sc_utf16le_sha256": "2F5F8B9D2F0DB7C8B0A801104E6B6EF8CDD6033E09C73349BBAF911CEBC1B321"
    },
    {
      "block_id": 6,
      "ko": "동맹으로서 경계를 풀고 있습니다.",
      "literal_id": 0,
      "record_id": 3902,
      "source_sc_utf16le_sha256": "CA06ED7B17E029689446D5E272C1C2747C5AE44601341019BC484784DC481F82"
    },
    {
      "block_id": 6,
      "ko": "주종 관계에 있어\n경계를 풀고 있습니다.",
      "literal_id": 0,
      "record_id": 3903,
      "source_sc_utf16le_sha256": "9B2EFAB21C55D7DDBD707CEC0A1B1AAAB8F8F40824EBD9E3A55ADD7B81F3E479"
    },
    {
      "block_id": 6,
      "ko": "특별히 관심을 두지 않습니다.",
      "literal_id": 0,
      "record_id": 3904,
      "source_sc_utf16le_sha256": "9113307745AD5F63857D5B52A829ACC1F08D8F2FBB5B017B345FFC2E3E5EACCC"
    },
    {
      "block_id": 6,
      "ko": "칼을 맞댄 지 얼마 되지 않았지만\n원한은 없습니다.",
      "literal_id": 0,
      "record_id": 3905,
      "source_sc_utf16le_sha256": "6225F74475D5B1D44370B4D6C5C9762DC8DDCE050A3919712BE2B9D4495B9832"
    },
    {
      "block_id": 6,
      "ko": "본가를 방패로 삼아\n중재한 지 얼마 되지 않았습니다.",
      "literal_id": 0,
      "record_id": 3906,
      "source_sc_utf16le_sha256": "6225F74475D5B1D44370B4D6C5C9762DC8DDCE050A3919712BE2B9D4495B9832"
    },
    {
      "block_id": 6,
      "ko": "불구대천의 원수로 여기고 있습니다.",
      "literal_id": 0,
      "record_id": 3907,
      "source_sc_utf16le_sha256": "27F42EB66FD45F67E02150049FAE76D7E9450ACE8BB8C2123648145DB9D4E984"
    },
    {
      "block_id": 6,
      "ko": "배신자를 원망하고 있습니다.",
      "literal_id": 0,
      "record_id": 3908,
      "source_sc_utf16le_sha256": "7CB97B383AA76A7373C5F5AC9CFED42416A05B2A301D7ACD3F6D897B05D5A008"
    },
    {
      "block_id": 6,
      "ko": "동맹 제안을 거절당해\n원망하고 있습니다.",
      "literal_id": 0,
      "record_id": 3909,
      "source_sc_utf16le_sha256": "F876209B76CDBFBAC1E4DD2CE69E25F14E6F01F60595C6FC6CDAF3FCFAFC734A"
    },
    {
      "block_id": 6,
      "ko": "원군 요청을 거절당해\n당황하고 있습니다.",
      "literal_id": 0,
      "record_id": 3910,
      "source_sc_utf16le_sha256": "319B9A2B0DD4ECC475F9F7B3919CBFF5189F38133CDC89D745031DD76FF49577"
    },
    {
      "block_id": 6,
      "ko": "본가와의\n전투에서 크게 패했습니다.",
      "literal_id": 0,
      "record_id": 3911,
      "source_sc_utf16le_sha256": "18AEABCE6B8C174B993AE2A2B9883E6F7C95A68E8AEAF344E91929EB411BF49A"
    },
    {
      "block_id": 6,
      "ko": "불의를 저지른\n본가를 경계하고 있습니다.",
      "literal_id": 0,
      "record_id": 3912,
      "source_sc_utf16le_sha256": "6EFD742A8E3CA46E5A30AF25ACE869C306BE9F3C9B0A5039597D430D3F49995B"
    },
    {
      "block_id": 6,
      "ko": "주종 관계이지만\n신뢰하지 않고 있습니다.",
      "literal_id": 0,
      "record_id": 3913,
      "source_sc_utf16le_sha256": "EF86C503E0453DDBB4BC69FA9D7054B7A3EA932F5C5ECD5364AD06E979CDA356"
    },
    {
      "block_id": 6,
      "ko": "본가를 경계하고 있습니다.",
      "literal_id": 0,
      "record_id": 3914,
      "source_sc_utf16le_sha256": "5EAEAC42D2BA83BCEAB32E97B91B66214F20235733457472BDCEEFC9EA96EBD9"
    },
    {
      "block_id": 6,
      "ko": "아버지의 원수로 원망하고 있습니다.",
      "literal_id": 0,
      "record_id": 3915,
      "source_sc_utf16le_sha256": "DB6E4744F6FCE73916FB624CBEB83C7455D9839A55DC078EF0991F4C4EC8F1D0"
    },
    {
      "block_id": 6,
      "ko": "자식의 원수로 원망하고 있습니다.",
      "literal_id": 0,
      "record_id": 3916,
      "source_sc_utf16le_sha256": "86CEFE032BAB19D156C6964A30E19685A112860DD670AAB44A7D8A00FA908CBE"
    },
    {
      "block_id": 6,
      "ko": "형의 원수로 원망하고 있습니다.",
      "literal_id": 0,
      "record_id": 3917,
      "source_sc_utf16le_sha256": "2B462FD8411D7502BE3E61E547AFF9CCEAB10A1D2F87365C5921E573CC46A376"
    },
    {
      "block_id": 6,
      "ko": "아우의 원수로 원망하고 있습니다.",
      "literal_id": 0,
      "record_id": 3918,
      "source_sc_utf16le_sha256": "91910454122328B9FAC9B01CB2DDE63FE0BA2C671B5CEC9BBB4F35E7A2EC8E37"
    },
    {
      "block_id": 6,
      "ko": "친족의 원수로 원망하고 있습니다.",
      "literal_id": 0,
      "record_id": 3919,
      "source_sc_utf16le_sha256": "3920EA42895B67929DF13CC9A967FD26C365CABCBD4E39DC54C56C3670AE1EA7"
    },
    {
      "block_id": 6,
      "ko": "현재 교전 중인 적입니다.",
      "literal_id": 0,
      "record_id": 3920,
      "source_sc_utf16le_sha256": "7DBBF8F32291F16C18859218FE57E9555A8601AE11A83945B0047CB4F60BC9C6"
    },
    {
      "block_id": 6,
      "ko": "칼을 맞댄 지 얼마 되지 않아\n경계하고 있습니다.",
      "literal_id": 0,
      "record_id": 3921,
      "source_sc_utf16le_sha256": "A793A443AF56F441A03740A67750DFCF5850C3E3CDCC87F71F44ECDC50D87B20"
    },
    {
      "block_id": 6,
      "ko": "계략을 당해\n강하게 경계하고 있습니다.",
      "literal_id": 0,
      "record_id": 3922,
      "source_sc_utf16le_sha256": "496181B25EF3853CAF8A7B12FB7C13710B9DF1091C42E6CC3A26155E1B245695"
    },
    {
      "block_id": 6,
      "ko": "혐오:",
      "literal_id": 0,
      "record_id": 3923,
      "source_sc_utf16le_sha256": "8B02BD2E88F433C2E635E25537072F0571D7DEC19E265E4A0C835543A21566AC"
    },
    {
      "block_id": 6,
      "ko": ".",
      "literal_id": 1,
      "record_id": 3923,
      "source_sc_utf16le_sha256": "99060DCF4871333C4F69D0FCA880AD693CEB3CC4F47923C1BC5ED1852BC3898B"
    },
    {
      "block_id": 6,
      "ko": "동맹국이 있는\n본가를 경계하고 있습니다.",
      "literal_id": 0,
      "record_id": 3924,
      "source_sc_utf16le_sha256": "3EC8B41656D6DA9A0FE9F4BD48753581433B12FFC9B2F87AE701EBDBC6203DFF"
    },
    {
      "block_id": 6,
      "ko": "와",
      "literal_id": 0,
      "record_id": 3925,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 6,
      "ko": "\n마음이 맞지 않습니다.",
      "literal_id": 1,
      "record_id": 3925,
      "source_sc_utf16le_sha256": "4E9001EFBEDB4BBAA1E0CB68B0F6B9F3806DA07DBDF57C70E61C96613020C691"
    },
    {
      "block_id": 6,
      "ko": "본가를 방패로 삼아\n중재한 지 얼마 되지 않았습니다.",
      "literal_id": 0,
      "record_id": 3926,
      "source_sc_utf16le_sha256": "6225F74475D5B1D44370B4D6C5C9762DC8DDCE050A3919712BE2B9D4495B9832"
    },
    {
      "block_id": 6,
      "ko": "장군가를 멸망시킨\n본가를 경계하고 있습니다.",
      "literal_id": 0,
      "record_id": 3927,
      "source_sc_utf16le_sha256": "91D3266287CEC1D277276D281E88808E1FFB970C5128636F7E059EBA3FAE6F1F"
    },
    {
      "block_id": 6,
      "ko": "어느 직위를 내리시겠습니까?",
      "literal_id": 0,
      "record_id": 3928,
      "source_sc_utf16le_sha256": "176AA8792C6E234B917FCCD47800B99025C1F9B2F73E3958C882F91A2B0EAF48"
    },
    {
      "block_id": 6,
      "ko": "좋습니다.\n그렇다면",
      "literal_id": 0,
      "record_id": 3929,
      "source_sc_utf16le_sha256": "4488C91B6D20FE414D19F9EDB0E42AFA2F984C11C59E3F3D35B1E54297FE5FF3"
    },
    {
      "block_id": 6,
      "ko": "을",
      "literal_id": 1,
      "record_id": 3929,
      "source_sc_utf16le_sha256": "6BE056B6FC90133B8A2CA31B7CFA7520B6C9597A7254F6BA050B3FC314461F0B"
    },
    {
      "block_id": 6,
      "ko": "에게 내리겠습니다.\n막부를 위한 충성과 근면을 기대하겠습니다.",
      "literal_id": 2,
      "record_id": 3929,
      "source_sc_utf16le_sha256": "DED2C8074A3B8E544E77CC5173FDEBA6D0686A4B224EBB7FC3E96248809A70B2"
    },
    {
      "block_id": 6,
      "ko": "에",
      "literal_id": 0,
      "record_id": 3930,
      "source_sc_utf16le_sha256": "CE62C8443D12564BD99C195960B92E6BDE59EC7C58C497D81196A300EEDAD014"
    }
  ],
