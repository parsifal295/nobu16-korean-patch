      "source_sc_utf16le_sha256": "5CD58F5D7370CFACF652D6E98B07E6B86181C6D30608A3E514EE23C69162D6CA"
    },
    {
      "block_id": 2,
      "ko": "님, 지금까지 본가의 주인으로서\n정말 수고 많으셨습니다.\n후임:",
      "literal_id": 0,
