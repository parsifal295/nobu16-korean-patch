    },
    {
      "block_id": 2,
      "ko": "이(가) 성인식을 마치고 성인이 되었습니다.",
      "literal_id": 1,
      "record_id": 97,
      "source_sc_utf16le_sha256": "5C0E86BC612688D1F20B3F0C41132FE7AB509DC8EF4454E679A73C5842D57ACB"
    },
    {
      "block_id": 2,
      "ko": "가신의 딸:",
      "literal_id": 0,
      "record_id": 98,
      "source_sc_utf16le_sha256": "456D29B024236211C3EF215E5B96663573052AB712EDEF65A1D68A04CD5CED49"
    },
    {
      "block_id": 2,
      "ko": "이(가) 성인이 되었습니다.",
      "literal_id": 1,
      "record_id": 98,
      "source_sc_utf16le_sha256": "5456D0F5E9A55F5A28EA343A01AE8CBBED57D7061E1623E8AFB7F1C9C16831D5"
    },
    {
      "block_id": 2,
      "ko": "성인식을 마쳐 저도 어엿한 성인이 되었습니다.\n무가의 아내로서 맡은 바를 다하도록,\n앞으로도 정진하겠습니다.",
      "literal_id": 0,
      "record_id": 103,
      "source_sc_utf16le_sha256": "B505E1211FD87F928E9A0C44123AAEDB3C23F3F7E39E953DB79524C9315715E9"
    },
    {
      "block_id": 2,
      "ko": "마침내 어엿한 성인이 되었으니,\n앞으로 주군을 훌륭히 보필하고,\n본가의 번영에 조금이나마 힘이 되겠습니다.",
      "literal_id": 0,
      "record_id": 104,
      "source_sc_utf16le_sha256": "E11634C07B53AD2795113A6DEC709D94C723B95804D5292319929FB2A11734C9"
    },
    {
      "block_id": 2,
      "ko": "님, 찾아뵈었습니다.\n성인식도 마쳤으니 이제부터\n충성을 바칠 대상:",
      "literal_id": 0,
      "record_id": 109,
      "source_sc_utf16le_sha256": "5573A7D2BC846FD61F0CB1A7B1C61962556DF29E8BEE357C614DD81F2CDF9F91"
    },
    {
      "block_id": 2,
      "ko": "입니다.",
      "literal_id": 1,
      "record_id": 109,
      "source_sc_utf16le_sha256": "A3B9EE6D53B5D6047462794262764B0A5F00A568ED983532DDABFA3ED4AC5368"
    },
    {
      "block_id": 2,
      "ko": "성인식을 마친 무가의 딸로서,\n충성을 바칠 대상:",
      "literal_id": 0,
      "record_id": 110,
      "source_sc_utf16le_sha256": "01C7B0979301CDF0BFD84A4800D874E47BD3BFF7C51A6818B9018971751AEF06"
    },
    {
      "block_id": 2,
      "ko": "에게 힘을 보탤 날을 맞아,\n오랫동안 기다려 온 보람을 느낍니다.",
      "literal_id": 1,
      "record_id": 110,
      "source_sc_utf16le_sha256": "73DAE8B44F261DE309C9C45EAB01362ADB472B5F875213C4D7EE5BA1643A7E5D"
    },
    {
      "block_id": 2,
      "ko": "원복 완료 인원:",
      "literal_id": 0,
      "record_id": 111,
      "source_sc_utf16le_sha256": "0CEFEFF4B4617ECF6A1662FC44F111376E68261C6F1250E722AE78C143B4C306"
    },
    {
      "block_id": 2,
      "ko": "명.\n어엿한 무장으로 성장했습니다.",
      "literal_id": 1,
      "record_id": 111,
      "source_sc_utf16le_sha256": "33DD0AF3EE33514AAB9A95A112179D67C73D7D539D3ACECF566B6988F741F8BA"
    },
    {
      "block_id": 2,
      "ko": "휘하 합류 인원:",
      "literal_id": 0,
      "record_id": 112,
      "source_sc_utf16le_sha256": "0CEFEFF4B4617ECF6A1662FC44F111376E68261C6F1250E722AE78C143B4C306"
    },
    {
      "block_id": 2,
      "ko": "명.\n원복을 마치고 휘하의 무장이 되었습니다.",
      "literal_id": 1,
      "record_id": 112,
      "source_sc_utf16le_sha256": "03BDD5B236B3346C66CFA6C7E53347F6A94D6705FC6747C72E7AAB01F58AEB41"
    },
    {
      "block_id": 2,
      "ko": "의 적대 목표를 갱신했습니다.",
      "literal_id": 0,
      "record_id": 113,
      "source_sc_utf16le_sha256": "C9ED1BD2CD934D15CA9976FCE765DFB90AF7B1BF4ACCF2BD23DD5A8F44FE2F80"
    },
    {
      "block_id": 2,
      "ko": "의 수입이 부족하여 금전 공납량이 감소했습니다.",
      "literal_id": 0,
      "record_id": 114,
      "source_sc_utf16le_sha256": "70646D837FD80D5BBC8F899A96E150C0FE73E2C4C3272756E04E83C81395968F"
    },
    {
      "block_id": 2,
      "ko": "의 수입이 부족하여 군량 공납량이 감소했습니다.",
      "literal_id": 0,
      "record_id": 115,
      "source_sc_utf16le_sha256": "70259CFEA772A0C9E94AA958C4DC350BEA6B6463A0F22ED08835A1FC734D3E4B"
    },
    {
      "block_id": 2,
      "ko": "의 수입이 부족하여 군마 공납량이 감소했습니다.",
      "literal_id": 0,
      "record_id": 116,
      "source_sc_utf16le_sha256": "24475B4779F3C3706C853077C2CCE3F0C3B52F7D3906C23A7A4C8A8481D6B9BC"
    },
    {
      "block_id": 2,
      "ko": "의 수입이 부족하여 철포 공납량이 감소했습니다.",
      "literal_id": 0,
      "record_id": 117,
      "source_sc_utf16le_sha256": "A58C7E359FC298AD2777516AB9D34FDC44EB2428C4AC4B2998282F6A5C27793C"
    },
    {
      "block_id": 2,
      "ko": "플레이어 세력이 멸망했습니다.\n게임을 종료합니다.",
      "literal_id": 0,
      "record_id": 118,
      "source_sc_utf16le_sha256": "6EB768527B0BA3FCB8253CA6C0E0C184C1012C92FBD87856DBB00B99AA2A4B25"
    },
    {
      "block_id": 2,
      "ko": "혼인 동맹 파기 대상:",
      "literal_id": 0,
      "record_id": 119,
