    },
    {
      "block_id": 2,
      "ko": "입니다.\n실행하시겠습니까?",
      "literal_id": 1,
      "record_id": 119,
      "source_sc_utf16le_sha256": "DEB5FD6FD1D12A54F9986AFFB47DA5A6A908AA76B20AA067C67E7822E8505092"
    },
    {
      "block_id": 2,
      "ko": "혼인 동맹 파기 대상:",
      "literal_id": 0,
      "record_id": 120,
      "source_sc_utf16le_sha256": "56B460D1790413B40AC762C268F8A104A710427AA031A38937F23D98D3745C48"
    },
    {
      "block_id": 2,
      "ko": "등입니다.\n실행하시겠습니까?",
      "literal_id": 1,
      "record_id": 120,
      "source_sc_utf16le_sha256": "B1EBEFFE471E2725EE1EFC0D8DAB6EA9C081F8B916A76CF01D165C83142F09EB"
    },
    {
      "block_id": 2,
      "ko": "혈연관계가 없는 대상:",
      "literal_id": 0,
      "record_id": 121,
      "source_sc_utf16le_sha256": "75B34DE51D4F0C7F13A37B5A35A4A9F1431B479F8DE11B62CED378E2CC056BF9"
    },
    {
      "block_id": 2,
      "ko": ".\n이로 인해 출가하려는 공주가 있습니다. 허락하시겠습니까?",
      "literal_id": 1,
      "record_id": 121,
      "source_sc_utf16le_sha256": "2409F8F9A1901127B60BB26C882600A5BF0F14E7C29FAF21CEE1D2F00F646939"
    },
    {
      "block_id": 2,
      "ko": "나머지는 제게 맡겨주십시오.\n후임 당주:",
      "literal_id": 0,
      "record_id": 126,
      "source_sc_utf16le_sha256": "B205CBA7506EB2190BCE17C25CAB9F9661CFB3E032FC1C779F55FD22F90122DD"
    },
    {
      "block_id": 2,
      "ko": "이(가) 본가를 패자로 만들겠습니다.",
