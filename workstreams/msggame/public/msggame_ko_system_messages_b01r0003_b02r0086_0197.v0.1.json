    },
    {
      "block_id": 2,
      "ko": "입니다.",
      "literal_id": 1,
      "record_id": 144,
      "source_sc_utf16le_sha256": "C15AF3DB954BE6883553D1B9A8821AB4AC38D8829CFFBD5E339F1EB015414B52"
    },
    {
      "block_id": 2,
      "ko": "변경 전 세력명:",
      "literal_id": 0,
      "record_id": 145,
      "source_sc_utf16le_sha256": "A519B531389D9789593D61CF138E75138B35117C5C48E10F3CBC0DA7FA292192"
    },
    {
