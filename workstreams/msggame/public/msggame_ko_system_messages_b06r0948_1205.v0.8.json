  },
  "entries": [
    {
      "block_id": 6,
      "ko": "가끔은 사치도\n부려 보고 싶군",
      "literal_id": 0,
      "record_id": 948,
      "source_sc_utf16le_sha256": "150F439468313EB5B7FB3219C5C7C51AD751EA5C8EF22C8414A326A2D96194D1"
    },
    {
      "block_id": 6,
      "ko": "군량을 팔겠습니까?",
      "literal_id": 0,
      "record_id": 955,
      "source_sc_utf16le_sha256": "AA7BD14FCA56E24666DD42A83DBD154AE08EA5E4CEFB06B7B6A94F1C1C5AD21D"
    },
    {
      "block_id": 6,
      "ko": "제 물건도 사 주실 수 없습니까?",
      "literal_id": 0,
      "record_id": 956,
      "source_sc_utf16le_sha256": "E0145A3AB240BDB7FE5369A55D8CA6578D2D603E66561120295C850C8C98864A"
    },
    {
      "block_id": 6,
      "ko": "어디에서든\n일해 보이겠습니다",
      "literal_id": 0,
      "record_id": 967,
      "source_sc_utf16le_sha256": "9E1B55E311B64D6BC49C63A7221BB4F06C062E3455A13E4D585D7F47C06C20CA"
    },
    {
      "block_id": 6,
      "ko": "영지가 넓어지면\n이동도 어쩔 수 없지",
      "literal_id": 0,
      "record_id": 968,
      "source_sc_utf16le_sha256": "92356C40B9A2F0F5248E412EA85B131CF5CD4E6BEA5BFC155ED4D217B873A884"
    },
    {
      "block_id": 6,
      "ko": "적재적소라는\n말이 있습니다",
      "literal_id": 0,
      "record_id": 969,
      "source_sc_utf16le_sha256": "3D48E85AB12F87623DCD6D5F7FFA6276EB7B3394AEB06CBAB89DB10605294800"
    },
    {
      "block_id": 6,
      "ko": "이사 비용은\n어떻게 되는 겁니까?",
      "literal_id": 0,
      "record_id": 970,
      "source_sc_utf16le_sha256": "F15BE04EF917097925E1ADA7E8A09AF5E30D94C2563495995C192C689B0BE4F2"
    },
    {
      "block_id": 6,
      "ko": "싸울 수 있는 곳이라면\n상관없다",
      "literal_id": 0,
      "record_id": 971,
      "source_sc_utf16le_sha256": "69860834069601C4EB804FBA71DCA27D827946C246F8C3D6E1C988A819B81C5E"
    },
    {
      "block_id": 6,
      "ko": "살던 곳을 떠나는 건\n조금 쓸쓸하군",
      "literal_id": 0,
      "record_id": 972,
      "source_sc_utf16le_sha256": "BBB97AC1AD263F9E91EE5E1F89DAE43E71E372C304F3BE15B2AE4D35D29FF97F"
    },
    {
      "block_id": 6,
      "ko": "배치를 바꾸는 것이군요",
      "literal_id": 0,
      "record_id": 979,
      "source_sc_utf16le_sha256": "E571683DD146D7AF925F24C0A75E07F0053F605CAD444AE8C997DF52326B7B19"
    },
    {
      "block_id": 6,
      "ko": "새로운 곳으로\n이동하게 되는 겁니까?",
      "literal_id": 0,
      "record_id": 980,
      "source_sc_utf16le_sha256": "76E3CB558172B612A7DC54427FC76ECE1C7ED46863CEEFD3F0CB797CDF10FEBD"
    },
    {
      "block_id": 6,
      "ko": "가신의 마음을\n사로잡는 것도 중요하지",
      "literal_id": 0,
      "record_id": 991,
      "source_sc_utf16le_sha256": "EF95115E78645DBDF3005E7EDAAC12DB772DA727F187B08252AF929A1DF00B73"
    },
    {
      "block_id": 6,
      "ko": "박탈이라니 두렵군……",
      "literal_id": 0,
      "record_id": 992,
      "source_sc_utf16le_sha256": "4EA78E636A69DD0948CD7DCEBEDC608876C3BE4E81369214389DD307BF03547A"
    },
    {
      "block_id": 6,
      "ko": "공을 세우려면\n어찌해야 할까?",
      "literal_id": 0,
      "record_id": 993,
      "source_sc_utf16le_sha256": "D57B02FD550F7763CBA9EBC434B089034344AF69239F864E5DFF347EB3AFC830"
    },
    {
      "block_id": 6,
      "ko": "칭찬일까, 꾸중일까……",
      "literal_id": 0,
      "record_id": 994,
      "source_sc_utf16le_sha256": "F6B1C9E9CF99B5696AB42D81F9AFB7D3F36F657A710576DBA5973203270A56C1"
    },
    {
      "block_id": 6,
      "ko": "공에는 보답해야겠지",
      "literal_id": 0,
      "record_id": 995,
      "source_sc_utf16le_sha256": "21D9737F8C1971A4F157005612777A60A59B9E86784AF30843CC37328E113D9A"
    },
    {
      "block_id": 6,
      "ko": "무언가 받는다면\n거절할 이유가 없지",
      "literal_id": 0,
      "record_id": 996,
      "source_sc_utf16le_sha256": "69A4A822E53EB43F10381C85B36539BC571311DCA0AC95A39C169FBCE4A0D6BC"
    },
    {
      "block_id": 6,
      "ko": "무슨 상을 내리려는 걸까?",
      "literal_id": 0,
      "record_id": 1003,
      "source_sc_utf16le_sha256": "7B82E6F8D273C559259268AFE58E1FEC54698C8EB26F4AAFEE8D29679B36353C"
    },
    {
      "block_id": 6,
      "ko": "칭찬해 주신다면\n얼마나 기쁠까",
      "literal_id": 0,
      "record_id": 1004,
      "source_sc_utf16le_sha256": "DF6DA72D5343AD6125EC5E14B4A25CF97A7F9997697936C346A8F72B9133AB3B"
    },
    {
      "block_id": 6,
      "ko": "오…… 좋은 소식이기를",
      "literal_id": 0,
      "record_id": 1015,
      "source_sc_utf16le_sha256": "7A754ADD26FFDAFF1A50BD252429B02ABA6599861F8A2D591EE222D56A37561E"
    },
    {
      "block_id": 6,
      "ko": "좋은 날이\n될 것 같군",
      "literal_id": 0,
      "record_id": 1016,
      "source_sc_utf16le_sha256": "A7F6382A3C9001E4442BCD4CFEA61FA727DB1516487F2954532FEF6817C23A32"
    },
    {
      "block_id": 6,
      "ko": "기쁜 일이\n되겠군요",
      "literal_id": 0,
      "record_id": 1017,
      "source_sc_utf16le_sha256": "2912B051D4A9B59AE6F91F0494AC1EB114783F5CB79A2A173CC025197378D17C"
    },
    {
      "block_id": 6,
      "ko": "새 부부는\n분명 그들이겠지……",
      "literal_id": 0,
      "record_id": 1018,
      "source_sc_utf16le_sha256": "15F3902BB076BCA4799DDD9DE339EF860C25E7B99861CC8A5F1BDC8CAD5ADE2E"
    },
    {
      "block_id": 6,
      "ko": "우리 가문의 전기가 될까",
      "literal_id": 0,
      "record_id": 1019,
      "source_sc_utf16le_sha256": "66E4B10B11B9DDC8B1C5F0E3E15A909A1237558A6E8B15327D0384AEC3445341"
    },
    {
      "block_id": 6,
      "ko": "호오, 혼인이라……",
      "literal_id": 0,
      "record_id": 1020,
      "source_sc_utf16le_sha256": "C0813345EFF5F1DAE117F1C804653E5CE9BCFF1B787CAE14A6FD979B6D257616"
    },
    {
      "block_id": 6,
      "ko": "누가 혼인하는 거지?",
      "literal_id": 0,
      "record_id": 1027,
      "source_sc_utf16le_sha256": "F3B38814BAB2405C7F11517126E492E2B58A4AB55686A2997B698FFDB3C0C582"
    },
    {
      "block_id": 6,
      "ko": "설마…… 나인가?",
      "literal_id": 0,
      "record_id": 1028,
      "source_sc_utf16le_sha256": "28688692B6612DC7A54180AAF4192052D293613725910C58065EC88A511B034E"
    },
    {
      "block_id": 6,
      "ko": "결심하셨습니까?",
      "literal_id": 0,
      "record_id": 1039,
      "source_sc_utf16le_sha256": "A7A778BA1E9ECBD15281183690932DF2373AE36A7B9EDDD900F7D171FC9622AC"
    },
    {
      "block_id": 6,
      "ko": "설마 가독을\n물려주시려는 겁니까?",
      "literal_id": 0,
      "record_id": 1040,
      "source_sc_utf16le_sha256": "67B01F893B16CC2EE94A0D17D367C784FE9EF6436E0D87AE58F5576E3755DEF7"
    },
    {
      "block_id": 6,
      "ko": "다음 세대로 넘어가는 건가……",
      "literal_id": 0,
      "record_id": 1041,
      "source_sc_utf16le_sha256": "7E1C59ABC87293E27A033E2FA71BDC25364E01C9091F472C3381E05A6748EB8F"
    },
    {
      "block_id": 6,
      "ko": "은거를\n생각하고 계십니까?",
      "literal_id": 0,
      "record_id": 1042,
      "source_sc_utf16le_sha256": "10AE92D93DA0F56D1F69E526CA575D29E5CF9CE8472231410F499EB123F9A4E7"
    },
    {
      "block_id": 6,
      "ko": "모실 수 있어\n영광이었습니다……",
      "literal_id": 0,
      "record_id": 1043,
      "source_sc_utf16le_sha256": "52F71B75A003B1B14C0FF49A1DE979D4C00F9F7A1A048C59849DCE2DDDCD4D68"
    },
    {
      "block_id": 6,
      "ko": "가독을 넘긴다고?\n설마……",
      "literal_id": 0,
      "record_id": 1044,
      "source_sc_utf16le_sha256": "B74259BB45E5F51F43E420B4E92B30CA3BA27D6FD2A3C305ABF666B81DC1DB79"
    },
    {
      "block_id": 6,
      "ko": "주군께서 설마\n은거하시다니……",
      "literal_id": 0,
      "record_id": 1051,
      "source_sc_utf16le_sha256": "7B859CE7E2BAC50DF775A9DEFB6053F827D4011F517BAC03463AB868B2E3CDA7"
    },
    {
      "block_id": 6,
      "ko": "가독에서\n물러나시는 겁니까?",
      "literal_id": 0,
      "record_id": 1052,
      "source_sc_utf16le_sha256": "955BCC93124628D0443884D3E22C83FCCAE758E390A2BB42D763E7B85CBB4DB1"
    },
    {
      "block_id": 6,
      "ko": "어쩔 수 없는\n판단이겠지",
      "literal_id": 0,
      "record_id": 1063,
      "source_sc_utf16le_sha256": "5138B2B24FC7A9D55A6804272FE7DF3EA20CAFC4425EAE5BFAE03C8A24310A6A"
    },
    {
      "block_id": 6,
      "ko": "그런 것이군",
      "literal_id": 0,
      "record_id": 1064,
      "source_sc_utf16le_sha256": "FEE38D9D506EDA41C2E2D8F82ECD4C11DD8899979437746940B4E2F787E2CC32"
    },
    {
      "block_id": 6,
      "ko": "무슨 의심받을 짓을\n저질렀단 말인가?",
      "literal_id": 0,
      "record_id": 1065,
      "source_sc_utf16le_sha256": "0695513B2B188E31BAECF4E9CAB44EC953BACB3A8ACDFBD5F0507669747879A5"
    },
    {
      "block_id": 6,
      "ko": "추방이라니……",
      "literal_id": 0,
      "record_id": 1066,
      "source_sc_utf16le_sha256": "C73950FDED89E7CFD9E3E41888381E87B2899A680C8B92B7FE277056A204FEAD"
    },
    {
      "block_id": 6,
      "ko": "남은 자들만으로도\n충분하겠지",
      "literal_id": 0,
      "record_id": 1067,
      "source_sc_utf16le_sha256": "313EB995C4C6F4D6444990155EA044CD2F46BA05FCF8DA76F1577061F4183547"
    },
    {
      "block_id": 6,
      "ko": "그자를\n추방하신 겁니까?",
      "literal_id": 0,
      "record_id": 1068,
      "source_sc_utf16le_sha256": "DB9FA683177E7A9321EAA4142F38B80B129515730C4968B51A8549B6238241B8"
    },
    {
      "block_id": 6,
      "ko": "어쩔 수 없군……",
      "literal_id": 0,
      "record_id": 1075,
      "source_sc_utf16le_sha256": "0CAE135E01266D3EAA9A92921D32767CA72CAC51360CDE3595F3B7EA1288FED9"
    },
    {
      "block_id": 6,
      "ko": "누군가 추방되었군요",
      "literal_id": 0,
      "record_id": 1076,
      "source_sc_utf16le_sha256": "E25C27D5AAA8DF28AD3F440922DF87A83D62BBE75EFE2F171B8C980C9678841F"
    },
    {
      "block_id": 6,
      "ko": "새 군단을 편성하시겠습니까?",
      "literal_id": 0,
      "record_id": 1087,
      "source_sc_utf16le_sha256": "4EC9E885B73DDD4CAEDAA4D6C6D677FFE04327E41ECD63D8F43FFEBF7FBF112E"
    },
    {
      "block_id": 6,
      "ko": "내가 나설\n기회가 있으려나?",
      "literal_id": 0,
      "record_id": 1088,
      "source_sc_utf16le_sha256": "F1AF000BF240281EE07836BDFE17CA4C06A8294F26935F64F8B48C5FDD793DDA"
    },
    {
      "block_id": 6,
      "ko": "편성을 재검토하는 건\n좋은 생각입니다",
      "literal_id": 0,
      "record_id": 1089,
      "source_sc_utf16le_sha256": "F2D015080F1948587FEBD723AF7CFF46F8BADD08F635450EB9BA4536E16E549E"
    },
    {
      "block_id": 6,
      "ko": "과연 어떤 편성이 될까……",
      "literal_id": 0,
      "record_id": 1090,
      "source_sc_utf16le_sha256": "86C2136703F9A7CFF370A7C048C7BEBF0BFCCB9F4BE8A2E09C03504173CEAD2E"
    },
    {
      "block_id": 6,
      "ko": "군단을 다시 짜는 것도\n좋은 방법이지",
      "literal_id": 0,
      "record_id": 1091,
      "source_sc_utf16le_sha256": "928247DF32FA4D8CBBF9AC232D2BA7E0EC5AEE348ACFF578CA7226113889802B"
    },
    {
      "block_id": 6,
      "ko": "군단 구성에서\n전략이 드러나는 법이지",
      "literal_id": 0,
      "record_id": 1092,
      "source_sc_utf16le_sha256": "C03FAFB7D9CD37A52132C37A5EE09AAB3C8BFA16724A503D6BE22B6CA0DA2E00"
    },
    {
      "block_id": 6,
      "ko": "군단을\n편성하시겠습니까?",
      "literal_id": 0,
      "record_id": 1099,
      "source_sc_utf16le_sha256": "964346233234E50CDBC15FC4B0B49699E8E7BEB58D3DC9885BAF6119B64F8B59"
    },
    {
      "block_id": 6,
      "ko": "좋은 곳에\n배속되면 좋겠군",
      "literal_id": 0,
      "record_id": 1100,
      "source_sc_utf16le_sha256": "1F63A7A5FA978BF8A0B128FA394AAD36C16BFEB2EEFB8B53C7970E97F81E3E97"
    },
    {
      "block_id": 6,
      "ko": "논의는 다 끝났나?",
      "literal_id": 0,
      "record_id": 1111,
      "source_sc_utf16le_sha256": "BB630E8D9FC9FCA6C7BFC519DD468B30B1771E851A21104F3D89FC7BA0884C98"
    },
    {
      "block_id": 6,
      "ko": "오늘은\n뭘 먹을까?",
      "literal_id": 0,
      "record_id": 1112,
      "source_sc_utf16le_sha256": "F3E45EC27FF4584A7A0BC1E700B5EB43F985E89201DF5716D69D0072773E3CF0"
    },
    {
      "block_id": 6,
      "ko": "이제 이야기도\n끝난 거겠지?",
      "literal_id": 0,
      "record_id": 1113,
      "source_sc_utf16le_sha256": "BCAE4DBA7B997B67C09FD0C9A6E568173ADC51E8B725501FAF1B204728CAA38D"
    },
    {
      "block_id": 6,
      "ko": "정말 따분하군",
      "literal_id": 0,
      "record_id": 1114,
      "source_sc_utf16le_sha256": "D49E71FCB32B63A119076DC27969CD027501F897848E4D747A9D6A135DAA9A67"
    },
    {
      "block_id": 6,
      "ko": "드디어 끝났군",
      "literal_id": 0,
      "record_id": 1115,
      "source_sc_utf16le_sha256": "658AB213E6C732B38C29F9AF9BB999193C4E720B9CDF01E77460B903E1BA6568"
    },
    {
      "block_id": 6,
      "ko": "하마터면 잠들 뻔했군",
      "literal_id": 0,
      "record_id": 1116,
      "source_sc_utf16le_sha256": "021A717DF07EA06732E70A2386822297FB4FBDF9EA17C44247E61DBE822DB515"
    },
    {
      "block_id": 6,
      "ko": "이제 곧\n끝나겠네요",
      "literal_id": 0,
      "record_id": 1123,
      "source_sc_utf16le_sha256": "36BD747F133CDC7B306B3B16ECE4CE7094BC660CBEE44F321F60B2FF56BDE39B"
    },
    {
      "block_id": 6,
      "ko": "배가 고프네요",
      "literal_id": 0,
      "record_id": 1124,
      "source_sc_utf16le_sha256": "534548EDC8B027AFCAB95BEBD9893748CB59579F0E66CD73DE5B6B07AB551C14"
    },
    {
      "block_id": 6,
      "ko": "이번에는 내가……!",
      "literal_id": 0,
      "record_id": 1131,
      "source_sc_utf16le_sha256": "C0FC4BCCBAC487E4420194C85083F3ADDB03643B79E629C5E8BA383C84F10E40"
    },
    {
      "block_id": 6,
      "ko": "나도 모르게\n자세를 바로잡았다.",
      "literal_id": 0,
      "record_id": 1132,
      "source_sc_utf16le_sha256": "EA4A28595928B644CE6FA8CBAEDF80431A0AAD61B913F4590E67B28B6BF3E4BD"
    },
    {
      "block_id": 6,
      "ko": "누가 공훈\n일위가 될까?",
      "literal_id": 0,
      "record_id": 1133,
      "source_sc_utf16le_sha256": "586484F365D45C2B3A3CACFCE4FA434C4C12C9D84267A9514D72C585A99C348E"
    },
    {
      "block_id": 6,
      "ko": "슬슬 논공행상을\n할 때인가?",
      "literal_id": 0,
      "record_id": 1134,
      "source_sc_utf16le_sha256": "C51CFEC019D7DF9A37B373A30B6AED6FAD7D78C40BF98D346E89012B50A7310B"
    },
    {
      "block_id": 6,
      "ko": "어서 빨리\n승진하고 싶군.",
      "literal_id": 0,
      "record_id": 1135,
      "source_sc_utf16le_sha256": "AE80F9E5D41593A75860A7C8EB838135C86FBCF938A8A5C40411E3480E5B5FC4"
    },
    {
      "block_id": 6,
      "ko": "뒤를 찔리면\n곤란하니까.",
      "literal_id": 0,
      "record_id": 1136,
