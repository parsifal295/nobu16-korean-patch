{
  "base_language": "SC",
  "defaults": {
    "status": "translated"
  },
  "distribution_policy": {
    "contains_commercial_source_text": false,
    "contains_complete_game_resource": false
  },
  "entries": [
    {
      "block_id": 6,
      "ko": "내 헌책은 들을 생각도 없나……\n참으로 가볍게 보는군",
      "literal_id": 0,
      "record_id": 560,
      "source_sc_utf16le_sha256": "7CD37C7588C1C00DD05DAC04D2F1E91C1A5A8FE9F57986FAEB6C32DE3F2836E1"
    },
    {
      "block_id": 6,
      "ko": "내 진언을 하루라도 빨리\n살펴 주었으면 좋겠는데",
      "literal_id": 0,
      "record_id": 561,
      "source_sc_utf16le_sha256": "BC7931C999FFFB538AF776700F1A94C6DE5EBFD65502C7A31EF253F14BA3A43A"
    },
    {
      "block_id": 6,
      "ko": "이번에도 내 구신은\n들어 주지 않는 건가……",
      "literal_id": 0,
      "record_id": 562,
      "source_sc_utf16le_sha256": "286649E444D8F465927EB30B185CCFE896AD872DBE55FB55B500EE64290780F8"
    },
    {
      "block_id": 6,
      "ko": "구신에 아무 소식이 없군……",
      "literal_id": 0,
      "record_id": 563,
      "source_sc_utf16le_sha256": "007A1B876E9647739E6CAE2222380633803A98B4B045E66618F47A221C8E3EE8"
    },
    {
      "block_id": 6,
      "ko": "진언은 필요 없다……\n그런 뜻인가?",
      "literal_id": 0,
      "record_id": 564,
      "source_sc_utf16le_sha256": "6B8F193003DDFB5EC70F6666421D7F794B3790ADF40ED0E930615EAB3EFE59BC"
    },
    {
      "block_id": 6,
      "ko": "주군께 다시 알려야겠군\n내가 구신 중이라고……",
      "literal_id": 0,
      "record_id": 571,
      "source_sc_utf16le_sha256": "C58628BFF980CB09DA2D6C026F815C4ACF6CCE5B3D3B8D7F402ECC5D113CF93D"
    },
    {
      "block_id": 6,
      "ko": "그렇게 자신 있게 구신했건만\n내버려 두다니……",
      "literal_id": 0,
      "record_id": 572,
      "source_sc_utf16le_sha256": "7234EE935A6B96EFCFE4B2281699F8B41EFE3C1F52DC2325BAF951C49D1B3142"
    },
    {
      "block_id": 6,
      "ko": "라면\n공략은 반드시 성공할 것이다.",
      "literal_id": 0,
      "record_id": 583,
      "source_sc_utf16le_sha256": "CF2882D70DD92F6A14F9AD47B2E84ECD558C95F006472470646E733726A4E1F4"
    },
    {
      "block_id": 6,
      "ko": "공략",
      "literal_id": 0,
      "record_id": 584,
      "source_sc_utf16le_sha256": "D1AB50E09BF005013BBED9D6E297C215D1DC8823F3A194DFAFB26B5D5B09BFF5"
    },
    {
      "block_id": 6,
      "ko": "\n아군을 믿어 보자",
      "literal_id": 1,
      "record_id": 584,
      "source_sc_utf16le_sha256": "1E77ED4FEF77178162114F0E4326B488A432F668E74D8CF65CE49713D346D46A"
    },
    {
      "block_id": 6,
      "ko": "라면\n분명 예상대로 되겠지……",
      "literal_id": 0,
      "record_id": 585,
      "source_sc_utf16le_sha256": "5AFC0BB949B7EEB79DDE42FD80C485BA9233A679CBA7F8CD9305B37C1662EF2F"
    },
    {
      "block_id": 6,
      "ko": "공략 대상:",
      "literal_id": 0,
      "record_id": 586,
      "source_sc_utf16le_sha256": "31C03386D5C8F14C2282DF10F313C9FF2C97A7DC364B328720BC6D665A0CAF19"
    },
    {
      "block_id": 6,
      "ko": "\n부디 성공하기를",
      "literal_id": 1,
      "record_id": 586,
      "source_sc_utf16le_sha256": "621E40E0AED27C7D0BFED03B75DE651CAA0BA7BF9621846E6F46E3188BA5D725"
    },
    {
      "block_id": 6,
      "ko": "에게\n저 성을 함락할 힘이 있을까……",
      "literal_id": 0,
      "record_id": 587,
      "source_sc_utf16le_sha256": "3D35634E8DA65526AFC01FB73BAF145816AF42D7E77217214D59A86E59587DFD"
    },
    {
      "block_id": 6,
      "ko": "인가……\n함락할 수 있으면 좋겠군",
      "literal_id": 0,
      "record_id": 588,
      "source_sc_utf16le_sha256": "107836ECA56A1FC286438BA7154A04EB836467BC3E907F3F46971E94D2B26621"
    },
    {
      "block_id": 6,
      "ko": "라면\n분명 문제없을 겁니다",
      "literal_id": 0,
      "record_id": 595,
      "source_sc_utf16le_sha256": "1BF5DE6C33543EB435AF5088AD353C40C0E09E5FCA8AB208DF39246C128DD5B6"
    },
    {
      "block_id": 6,
      "ko": "공격 대상:",
      "literal_id": 0,
      "record_id": 596,
      "source_sc_utf16le_sha256": "C3C9EE6759C066F5A35A9507560AB7C5A5AE0452D09554E7D8441178A6AD15E8"
    },
    {
      "block_id": 6,
      "ko": "의 승리를\n반드시 빕니다.",
      "literal_id": 1,
      "record_id": 596,
      "source_sc_utf16le_sha256": "F18BD586101BE1756668E191868A918E60DF630B6D924D92075E37FED327F14D"
    },
    {
      "block_id": 6,
      "ko": "의 활약이라면\n반드시 무공을 세울 것이다",
      "literal_id": 0,
      "record_id": 607,
      "source_sc_utf16le_sha256": "D9A7D83D9CB294C14E395C60545C162D167282C54B7FDE7095FDC8EA1F13CDAD"
    },
    {
      "block_id": 6,
      "ko": "무운을 빈다:",
      "literal_id": 0,
      "record_id": 608,
      "source_sc_utf16le_sha256": "67C01B5B60A954F8687DB71BE0BD43208527F624AA47E258987D355F20BD35F4"
    },
    {
      "block_id": 6,
      "ko": "\n승리가 함께하기를",
      "literal_id": 1,
      "record_id": 608,
      "source_sc_utf16le_sha256": "3B177A7FEA3A957C098C575B51622BC4EB33919B1052672BB7DE8CB99931919C"
    },
    {
      "block_id": 6,
      "ko": "의 전투는\n분명 예상대로 되겠지……",
      "literal_id": 0,
      "record_id": 609,
      "source_sc_utf16le_sha256": "060997E926AD711C07625F34D4BB5021734B8708BAA50003BF8CD6B0D9FD760C"
    },
    {
      "block_id": 6,
      "ko": "작전 대상:",
      "literal_id": 0,
      "record_id": 610,
      "source_sc_utf16le_sha256": "B30EE8E622CE0722F826D807CD26B40DF978F7BA6F32429A5FBA349CC5D26CA5"
    },
    {
      "block_id": 6,
      "ko": "\n내 계산대로 움직인다면……",
      "literal_id": 1,
      "record_id": 610,
      "source_sc_utf16le_sha256": "BAB5B71F9E771FC62DB963D0F4A586545712E13EC7DFF4BC78A240F69089AC7D"
    },
    {
      "block_id": 6,
      "ko": "!\n전력을 다하라",
      "literal_id": 0,
      "record_id": 611,
      "source_sc_utf16le_sha256": "86757984D054B3A630F7EE0A19F5542DF34DDBD34577B002F2BF77E6787F78A4"
    },
    {
      "block_id": 6,
      "ko": "!\n온 힘을 쏟아라",
      "literal_id": 0,
      "record_id": 612,
      "source_sc_utf16le_sha256": "EF080AE9370FB41E087094417A874D6EF53CF8C84A32E9ED97CB855506D540DC"
    },
    {
      "block_id": 6,
      "ko": "\n반드시 이겨!",
      "literal_id": 0,
      "record_id": 619,
      "source_sc_utf16le_sha256": "601377B56ABA0EDB7C09506FEE1C04FB5237C0BF122CE644593053BCA758E1F6"
    },
    {
      "block_id": 6,
      "ko": "\n부디, 꼭 이겨!",
      "literal_id": 0,
      "record_id": 620,
      "source_sc_utf16le_sha256": "84FDA4F7C4461E7E961A3740ACDD7318EAF62E51A38760434C4853CA21C55FEF"
    },
    {
      "block_id": 6,
      "ko": "가증스러운 상대:",
      "literal_id": 0,
      "record_id": 631,
      "source_sc_utf16le_sha256": "A46FA69721422A8E160A28754953154F65800D795C535E4E685350D69C0A086B"
    },
    {
      "block_id": 6,
      "ko": "\n본가를 공격 대상으로 삼다니",
      "literal_id": 1,
      "record_id": 631,
      "source_sc_utf16le_sha256": "4825F96BF42024F25AEDC00E0DC060B5278E255F8ABDF0D562A794F213E2989F"
    },
    {
      "block_id": 6,
      "ko": "교전 상대:",
      "literal_id": 0,
      "record_id": 632,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 6,
      "ko": "와의 싸움이\n눈앞에 닥쳤군",
      "literal_id": 1,
      "record_id": 632,
      "source_sc_utf16le_sha256": "FF673AC2272B5C2D342020487D4BC755B8090708DB48220FE117DC05FBE06BDE"
    },
    {
      "block_id": 6,
      "ko": "의 표적은\n본가인 듯합니다",
      "literal_id": 0,
      "record_id": 633,
      "source_sc_utf16le_sha256": "A70B6820D333F47A3A356AAF2A0E9250997AE88D4C63D4254C1C56D1C7DD12A2"
    },
    {
      "block_id": 6,
      "ko": "……역시\n본가를 공격하려는 건가",
      "literal_id": 0,
      "record_id": 634,
      "source_sc_utf16le_sha256": "70FF82B2C26AE2A5CB8660A79E5A091ACE107FF66FFAFD09C900C5C5738A6EE6"
    },
    {
      "block_id": 6,
      "ko": "수상한 상대:",
      "literal_id": 0,
      "record_id": 635,
      "source_sc_utf16le_sha256": "A46FA69721422A8E160A28754953154F65800D795C535E4E685350D69C0A086B"
    },
    {
      "block_id": 6,
      "ko": "……\n불온한 움직임을 보이는군",
      "literal_id": 1,
      "record_id": 635,
      "source_sc_utf16le_sha256": "4B2A6F55A59388D72E0913F5211C46C8C0BB37819FCA47AFC2D5FB7EDF9EBFE1"
    },
    {
      "block_id": 6,
      "ko": "의 군세가\n금방이라도 쳐들어오겠군",
      "literal_id": 0,
      "record_id": 636,
      "source_sc_utf16le_sha256": "6FD0ACF75F025128F3BAB392D1A2BBE3DE00B74139E584C5F9966EBF71F46131"
    },
    {
      "block_id": 6,
      "ko": "의 움직임이\n수상합니다……조심하십시오!",
      "literal_id": 0,
      "record_id": 643,
      "source_sc_utf16le_sha256": "CED7485EDB4019C9BA23547B9BC288BCA947DBC2DC43DB877B21D5CBCFD7904A"
    },
    {
      "block_id": 6,
      "ko": "교전 상대:",
      "literal_id": 0,
      "record_id": 644,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 6,
      "ko": "와의 싸움은\n피할 수 없을 듯합니다……",
      "literal_id": 1,
      "record_id": 644,
      "source_sc_utf16le_sha256": "612001DEC7DA50A40BA2D38BC9C553CEF137753CEBB1B5453639AD1ED74D9AD9"
    },
    {
      "block_id": 6,
      "ko": "저 마을의 제방도……\n많이 낡았군……",
      "literal_id": 0,
      "record_id": 655,
      "source_sc_utf16le_sha256": "852037A62AF373CA0426CB9B3C07D50F64761EAD2659679DE0A364739503DAE0"
    },
    {
      "block_id": 6,
      "ko": "축제를 허락했다간\n또 소란과 싸움이 나겠군……",
      "literal_id": 0,
      "record_id": 656,
      "source_sc_utf16le_sha256": "721FCF67C1AE9F755370E66356B957063D2DD000653CA88880C47C9B0047DEB2"
    },
    {
      "block_id": 6,
      "ko": "내 영민들이\n좀 더 편히 살게 하고 싶군……",
      "literal_id": 0,
      "record_id": 657,
      "source_sc_utf16le_sha256": "6251178815D8234B005F0C7528DDDB4C9A5E47267CC82FF10A421E39A545A77B"
    },
    {
      "block_id": 6,
      "ko": "내가 다스리는 곳이니\n내 지행지는 평온하군",
      "literal_id": 0,
      "record_id": 658,
      "source_sc_utf16le_sha256": "3B1E524B843DAF3ED5BBB821FA1D862958254E343E0A6DE9138172C2FB2498B5"
    },
    {
      "block_id": 6,
      "ko": "우선 마을에서\n병사를 내게 해야겠군",
      "literal_id": 0,
      "record_id": 659,
      "source_sc_utf16le_sha256": "5C5E5833C65F31132B806E7F216EEF0C7ADA26AD621D06195BBEFC9739993268"
    },
    {
      "block_id": 6,
      "ko": "영민들이 나를\n두려워하는군……",
      "literal_id": 0,
      "record_id": 660,
      "source_sc_utf16le_sha256": "A9A195D6166521865A774ABB1FDE6FC282CBDDC651E85720F10EE241EEB6FF9E"
    },
    {
      "block_id": 6,
      "ko": "지행지를 더 낫게 만들\n좋은 방도가 없을까",
      "literal_id": 0,
      "record_id": 667,
      "source_sc_utf16le_sha256": "66D5C8D871F8EBCC2B21C038F0FCF3A689270A6B0E0EF08FDCA40DC409D9DC85"
    },
    {
      "block_id": 6,
      "ko": "아아, 지행지 따위\n될 대로 되라지!",
      "literal_id": 0,
      "record_id": 668,
      "source_sc_utf16le_sha256": "05EA8E895C9FEC221436AA02EBF5077D6F1019BA5F14A43E6DDB4B4B61739A62"
    },
    {
      "block_id": 6,
      "ko": "후후……이 정도 일로\n바쁘다고 할 수는 없지",
      "literal_id": 0,
      "record_id": 679,
      "source_sc_utf16le_sha256": "5D8993D79C2B05868635C5B635BC2CED8A89350CC476EF73EFF19FD1D595EA52"
    },
    {
      "block_id": 6,
      "ko": "남보다 두 배는 힘써야\n두각을 드러낼 수 있다",
      "literal_id": 0,
      "record_id": 680,
      "source_sc_utf16le_sha256": "888FD2157ECEB3ACD7A7F3D6C6C3D00983780F9878BDEC324A75D1FFA44F1BB2"
    },
    {
      "block_id": 6,
      "ko": "이야……어제는 그래도\n잠깐이나마 잤습니다",
      "literal_id": 0,
      "record_id": 681,
      "source_sc_utf16le_sha256": "D51BA15DB5BBB93B91BB7C1B0BCEA6FFF98245E5C6DA18AA04F7766996B3A795"
    },
    {
      "block_id": 6,
      "ko": "후우……격무도 결국\n기대받는다는 뜻인가",
      "literal_id": 0,
      "record_id": 682,
      "source_sc_utf16le_sha256": "FF4F35DA2174E0DEA067C99F0518155723FE80440992B1DA9AAFDD744C8F0B77"
    },
    {
      "block_id": 6,
      "ko": "이런, 칼을 손질할\n시간조차 없을 정도로군",
      "literal_id": 0,
      "record_id": 683,
      "source_sc_utf16le_sha256": "51D4AD611F6E82658C309D3CB3A45200FFE9096843A57D882DD8054EA73CB472"
    },
    {
      "block_id": 6,
      "ko": "한가해지면\n검술 수련이나 할까",
      "literal_id": 0,
      "record_id": 684,
      "source_sc_utf16le_sha256": "3F45BA8D36804329DC257093E82BD798D6EDAD28C3B2202050A630E60B083B30"
    },
    {
      "block_id": 6,
      "ko": "후후……너무 일해서\n조금 야위었나",
      "literal_id": 0,
      "record_id": 691,
      "source_sc_utf16le_sha256": "21B8438C04EE37BADBBDDCB2AF76311228C05C7956A89820477BAAC2B3CA4867"
    },
    {
      "block_id": 6,
      "ko": "아아……어깨가 뻐근해\n누가 좀 주물러 줘!",
      "literal_id": 0,
      "record_id": 692,
      "source_sc_utf16le_sha256": "D8D719F51BE9156E822DA47ACBDFE01D7A3D510595E71FB8CC90AD69D8FE2665"
    },
    {
      "block_id": 6,
      "ko": "자, 이곳의 방식을\n배워 보도록 할까",
      "literal_id": 0,
      "record_id": 703,
      "source_sc_utf16le_sha256": "7FAE6BE7F3D01A51C7123A2116E7444C9698387CE691F6EBF248C537B00C27CC"
    },
    {
      "block_id": 6,
      "ko": "낭비가 많아 보이지만……\n아직 의견을 낼 때는 아니군",
      "literal_id": 0,
      "record_id": 704,
      "source_sc_utf16le_sha256": "5CEAC3B9CB1C43B02E59BCCCD5C838A607AFD86237D3E86B47F18C0C8D133A79"
    },
    {
      "block_id": 6,
      "ko": "고참들이 시끄러워 보이니\n얌전히 있어야겠군",
      "literal_id": 0,
      "record_id": 705,
      "source_sc_utf16le_sha256": "26FB00009281879260A5EE664E1100711A3B1BC130B7503B9FCE6B1E6DD244D1"
    },
    {
      "block_id": 6,
      "ko": "역시 조금 긴장되네요\n아주 조금……이지만",
      "literal_id": 0,
      "record_id": 706,
      "source_sc_utf16le_sha256": "76620AE73EC7C633B1EB37728344F06A625F5962369DA302A025E423CD59F022"
    },
    {
      "block_id": 6,
      "ko": "신참이라고\n얕보게 두진 않겠다",
      "literal_id": 0,
      "record_id": 707,
      "source_sc_utf16le_sha256": "BC87F77C2A1410995E1DA97E704BD4C848D836F166CAEC5E2297E9DBF8EF4A6F"
    },
    {
      "block_id": 6,
      "ko": "고참 녀석들……\n다가오면 베겠다!",
      "literal_id": 0,
      "record_id": 708,
      "source_sc_utf16le_sha256": "A5ABBBA4BB8C33B50012C5CAB0F60B2BB5FCF1203A628184BD667F717CEC228C"
    },
    {
      "block_id": 6,
      "ko": "하루빨리 평정중 여러분께\n인정받고 싶군",
      "literal_id": 0,
      "record_id": 715,
      "source_sc_utf16le_sha256": "F590E2E8C23555350A7C8EF64312923A3DD829466D70567B200D0AC55A4FBA61"
    },
    {
      "block_id": 6,
      "ko": "평정중의 일원이니\n힘껏 해내야지",
      "literal_id": 0,
      "record_id": 716,
      "source_sc_utf16le_sha256": "F3A6C1C242F4C85E7EEE7C2411CD6895A96C52476527DA03A95899A188AEB947"
    },
    {
      "block_id": 6,
      "ko": "동석 상대:",
      "literal_id": 0,
      "record_id": 727,
      "source_sc_utf16le_sha256": "513FC5E1132129E8DBAC2066BEAC1AFBCCF3B945868985DABE268FD41BBFAF03"
    },
    {
      "block_id": 6,
      "ko": "라니,\n감히 나와 같은 자리에 앉다니",
      "literal_id": 1,
      "record_id": 727,
      "source_sc_utf16le_sha256": "9DB6F150D8C4FCBAB9A6000C37C0A2596109646C27F880D846764D505C5DA85F"
    },
    {
      "block_id": 6,
      "ko": "평정 참여자:",
      "literal_id": 0,
      "record_id": 728,
      "source_sc_utf16le_sha256": "B8E6C74DC6160F4EC965A75EC4E29E9E9A6FA277AC4D05BC7694D1B94115BF53"
    },
    {
      "block_id": 6,
      "ko": "라……\n주군은 무슨 생각이신가",
      "literal_id": 1,
      "record_id": 728,
      "source_sc_utf16le_sha256": "0495ED0BC1C6F5411F96715FF04317498B7A230C5E94C82B6F494CD2ECF1DB71"
    },
    {
      "block_id": 6,
      "ko": "……\n건방져 보이는 자군요",
      "literal_id": 0,
      "record_id": 729,
      "source_sc_utf16le_sha256": "410C33560AE7898EAD91D78A0E9F53108E46CA1A34F9ACEA21748AE4A12AB65D"
    },
    {
      "block_id": 6,
      "ko": "……역시\n긴장하고 있군요",
      "literal_id": 0,
      "record_id": 730,
      "source_sc_utf16le_sha256": "44320EDEF49317FAA1A2DE6F4FBEDA420BE0BE2924EAB1CAEE83ECC6B890CADB"
    },
    {
      "block_id": 6,
      "ko": "마음에 들지 않는 얼굴이 있군\n누구라고는 안 하겠지만……",
      "literal_id": 0,
      "record_id": 731,
      "source_sc_utf16le_sha256": "8EA0850DD193FBC66EC7F684EC59F5BC274246FFB37EE0B8DCB87E3B940249F3"
    },
    {
      "block_id": 6,
      "ko": "……\n엄하게 지도해야겠군",
      "literal_id": 0,
      "record_id": 732,
      "source_sc_utf16le_sha256": "0900E557BEC24BD4B55912055F7B1F6D69270B30746709EF0C8ECA72F7D5631A"
    },
    {
      "block_id": 6,
      "ko": "\n설마 이 자리에 오다니.",
      "literal_id": 0,
      "record_id": 739,
      "source_sc_utf16le_sha256": "063AD2D42A74F134CFB6CE33D4ED297607842DBADF8BDD9520136938EA729980"
    },
    {
      "block_id": 6,
      "ko": "이 자리에 어울리지 않는 자:\n",
      "literal_id": 0,
      "record_id": 740,
      "source_sc_utf16le_sha256": "D0348AD3D932EFCE69A0593FA1E196DB33CBADD54462B25531EC4E8A6B95D7AB"
    },
    {
      "block_id": 6,
      "ko": ".",
      "literal_id": 1,
      "record_id": 740,
      "source_sc_utf16le_sha256": "99060DCF4871333C4F69D0FCA880AD693CEB3CC4F47923C1BC5ED1852BC3898B"
    },
    {
      "block_id": 6,
      "ko": "주군이 지나치게 강경하면\n가신들의 사기가 꺾이지……",
      "literal_id": 0,
      "record_id": 751,
      "source_sc_utf16le_sha256": "BCFC8236C2953C539760958A3F3A7241760C5D4C0C79B6D3CC2E8ACD191919DE"
    },
    {
      "block_id": 6,
      "ko": "이 참상은……\n이제 되돌릴 수 없나",
      "literal_id": 0,
      "record_id": 752,
      "source_sc_utf16le_sha256": "EEC67861B4E65F26DC9B1B441900109F018D9E9DA0349BBC4AA8161DD42A4867"
    },
    {
      "block_id": 6,
      "ko": "간언을 듣지 않는 주군 아래선\n어떤 양책도 무의미하지……",
      "literal_id": 0,
      "record_id": 753,
      "source_sc_utf16le_sha256": "A6B4DEFFAB16CD9FFBCB2ACFE1FE349F0C2C21D4A16D56696FB292F69174EE3F"
    },
    {
      "block_id": 6,
      "ko": "이런 꼴이라면\n어떤 양책도 무의미하군……",
      "literal_id": 0,
      "record_id": 754,
      "source_sc_utf16le_sha256": "1E11A1A91DA58971AB27D5666C295A14A1E20581990B957DF20DA0792BB24A37"
    },
    {
      "block_id": 6,
      "ko": "우리 가신들은 그저\n창을 대신하는 도구일 뿐인가",
      "literal_id": 0,
      "record_id": 755,
      "source_sc_utf16le_sha256": "B6A3E6181C3E19689C649C479FAB5B42BE1D3492011DC8A749F91357A424CA8A"
    },
    {
      "block_id": 6,
      "ko": "헛된 발버둥은 그만두고\n마지막만은 깨끗하게……",
      "literal_id": 0,
      "record_id": 756,
      "source_sc_utf16le_sha256": "0424BC8B82D2E7CCA93AB73C97766E4B8BF71ED8D5A4B313192629627FBB0A5B"
    },
    {
      "block_id": 6,
      "ko": "조금만 더 모두의 의견에\n귀 기울여 주신다면……",
      "literal_id": 0,
      "record_id": 763,
      "source_sc_utf16le_sha256": "912AAC872C908DC7646334F2D1C2C07CD02521944AB962AEC37EFE62C677590B"
    },
    {
      "block_id": 6,
      "ko": "이렇게 되어 버렸으니\n이제는……",
      "literal_id": 0,
      "record_id": 764,
      "source_sc_utf16le_sha256": "11C4049442B6E92D16414ADBEB471F68D6BB3E3B4E46E14B3624DFAADFC791BB"
    },
    {
      "block_id": 6,
      "ko": "가신이 늘었다 해도\n규율은 규율이다",
      "literal_id": 0,
      "record_id": 775,
      "source_sc_utf16le_sha256": "4D2DF9449B6E49FCCDB239B66EE906FA462E142C9ABE8DAA5D480F261401DA36"
    },
    {
      "block_id": 6,
      "ko": "본가의 기세를\n막을 자가 어디 있겠는가",
      "literal_id": 0,
      "record_id": 776,
      "source_sc_utf16le_sha256": "500EE931F21831A9A2240BCC860CAD27AD352FFA9BB2590A52A98524A2FB713D"
    },
    {
      "block_id": 6,
      "ko": "세력이 커졌기에\n쓸 수 있는 수단도 있지",
      "literal_id": 0,
      "record_id": 777,
      "source_sc_utf16le_sha256": "BE3C8CDB268373386B50D462FF8D743658D53BB5762F325C3F39277E2F7F1471"
    },
    {
      "block_id": 6,
      "ko": "본가의 확대도\n내 예상대로군……",
      "literal_id": 0,
      "record_id": 778,
      "source_sc_utf16le_sha256": "F49B18FA5AD24822C656B0B0603B4DCC62A7CB0626513320D3DBA0E3C390D84A"
    },
    {
      "block_id": 6,
      "ko": "견마지로도 마다하지 않고\n본가를 위해 힘쓰겠다",
      "literal_id": 0,
      "record_id": 779,
      "source_sc_utf16le_sha256": "2E02B828E4AF5E8FEB0BDD8E377A3C4C3B76A107A64A565908E867C4A6491CCC"
    },
    {
      "block_id": 6,
      "ko": "우리의 기세는 드높다!\n도약의 명을 내려 주십시오",
      "literal_id": 0,
      "record_id": 780,
      "source_sc_utf16le_sha256": "1DF4ECD037A1048D02DED2212F3902CF41827BF0432FC2538300F8F114EBE88F"
    },
    {
      "block_id": 6,
      "ko": "본가의 일거수일투족이\n천하를 뒤흔들 것입니다",
      "literal_id": 0,
      "record_id": 787,
      "source_sc_utf16le_sha256": "163DEAFD5BAC510CCA0F10ED9A30512862972BE30E8DE68EEFD2AF6679A32872"
    },
    {
      "block_id": 6,
      "ko": "본가의 규모라면\n반드시 해낼 수 있는 일이 있겠지",
      "literal_id": 0,
      "record_id": 788,
      "source_sc_utf16le_sha256": "27A3A37DAAABB416E018EA1025137BF9518335128DDEB15BCB4414B007FB227C"
    },
    {
      "block_id": 6,
      "ko": "오래 머물 곳은\n아닌 듯하군",
      "literal_id": 0,
      "record_id": 799,
      "source_sc_utf16le_sha256": "E9F82E74E0849742CDF0AA92BD55818633E0E2C3A423CC623B10DACCCF89DB03"
    },
    {
      "block_id": 6,
      "ko": "나를 품을 만한\n그릇은 아닌가 보군……",
      "literal_id": 0,
      "record_id": 800,
      "source_sc_utf16le_sha256": "83307FC6AEFE65C289B731D593BD64252F09168DBD9B4C8DA29CEE336827752A"
    },
    {
      "block_id": 6,
      "ko": "이 가문의 물은\n내게 맞지 않는 듯하군……",
      "literal_id": 0,
      "record_id": 801,
      "source_sc_utf16le_sha256": "24D0664816D788BDEA4CE9DC1C220F0ED93D07D426ABFC8E47A6C9624E7E0652"
    },
    {
      "block_id": 6,
      "ko": "내 헌책을 바칠 주군은\n따로 있는 듯하군……",
      "literal_id": 0,
      "record_id": 802,
      "source_sc_utf16le_sha256": "ACA5DE29A2343763C494AAED6B3CF6F22BC6C8F5BA26BC73DBB0C7F5E9BD1CD3"
    },
    {
      "block_id": 6,
      "ko": "인내에도 한계가 있다……",
      "literal_id": 0,
      "record_id": 803,
      "source_sc_utf16le_sha256": "EE087A3D0FE6FC973E6AE046E4D9727FFE3A951A22F049CD8299CF9C0E4166FE"
    },
    {
      "block_id": 6,
      "ko": "분을 풀 길이 없군……",
      "literal_id": 0,
      "record_id": 804,
      "source_sc_utf16le_sha256": "52CE9F9BD89EEE821D1E6EEA4A1DA20D6B05F22EC2023A171F39B946D15282D2"
    },
    {
      "block_id": 6,
      "ko": "가신들의 불만은\n전혀 개의치 않으십니까……",
      "literal_id": 0,
      "record_id": 811,
      "source_sc_utf16le_sha256": "278443654258C42ECDB021C83EED548FAF921028BF030D39DCE99E045307297C"
    },
    {
      "block_id": 6,
      "ko": "가신들의 불만을\n이토록 내버려 두시다니……",
      "literal_id": 0,
      "record_id": 812,
      "source_sc_utf16le_sha256": "5578CC185F673BC65576021F5AD2E39B59BCB9FD24E2D4AE9AB769B23C25E151"
    },
    {
      "block_id": 6,
      "ko": "동석 상대:",
      "literal_id": 0,
      "record_id": 823,
      "source_sc_utf16le_sha256": "6080340828DE9C0BF221E8D587B5FA9631E0866715ECDC680D8C56DA2DC52A3A"
    },
    {
      "block_id": 6,
      "ko": "인가……\n모두 본가를 위해서다",
      "literal_id": 1,
      "record_id": 823,
      "source_sc_utf16le_sha256": "FF1DC7790FD261BC442204CF85879D82F5A6419FAADD8190933F3F30FE94FCBC"
    },
    {
      "block_id": 6,
      "ko": "동료:",
      "literal_id": 0,
      "record_id": 824,
      "source_sc_utf16le_sha256": "42E91BF64B561544B509DC279D7F0290FC6E19A7A3BD2F4395AE2EA3FD7D4BB7"
    },
    {
      "block_id": 6,
      "ko": "……\n인정 못 할 만큼 옹졸하진 않다",
      "literal_id": 1,
      "record_id": 824,
      "source_sc_utf16le_sha256": "95F61F8993342378C7F582635C1F39FB5A083F9923C972F3A6BDFD1ED5B1188D"
    },
    {
      "block_id": 6,
      "ko": "뒤처리 대상:",
      "literal_id": 0,
      "record_id": 825,
      "source_sc_utf16le_sha256": "E0C204806691B1F5BB44B40083ABB6A1993884447579F59298A5244385826AA6"
    },
    {
      "block_id": 6,
      "ko": "\n그자의 실수까지 수습하긴 싫군요",
      "literal_id": 1,
      "record_id": 825,
      "source_sc_utf16le_sha256": "AF2D0240BC8270D0B89B8CB467AAC60AEF2FEC9D8CB1473B09043BF46896EA4B"
    },
    {
      "block_id": 6,
      "ko": "평정 참여:",
      "literal_id": 0,
      "record_id": 826,
      "source_sc_utf16le_sha256": "3F8C8A417AAB92D45DDFEEAB033F332633AC22FB7D5660B04D1B44AE1F29290D"
    },
    {
      "block_id": 6,
      "ko": "……\n그자를 본가에 둘 필요가 있나",
      "literal_id": 1,
      "record_id": 826,
      "source_sc_utf16le_sha256": "81D955467E83B32C0E1D3C1467996E98D6BE4C1A5696CF9CD35DB0E22EB3C531"
    },
    {
      "block_id": 6,
      "ko": "따위는\n안중에도 없다",
      "literal_id": 0,
      "record_id": 827,
      "source_sc_utf16le_sha256": "18EB4288E172B38BD2DD882490EC7583346C2EB09ABF5A2E5C809F0A94347B8F"
    },
    {
      "block_id": 6,
      "ko": "무례한 자:",
      "literal_id": 0,
      "record_id": 828,
      "source_sc_utf16le_sha256": "0492B9531B956BE6664B5ED77D6EB3FA11E8D838FD8CE280727260697CCB5DD8"
    },
    {
      "block_id": 6,
      "ko": "\n자리도 분간하지 못하는군",
      "literal_id": 1,
      "record_id": 828,
      "source_sc_utf16le_sha256": "971F478D6933C92A70335F7D62D59414DD8CB98B090CE80CB9B97819F9186E24"
    },
    {
      "block_id": 6,
      "ko": "협력이라……\n상대:",
      "literal_id": 0,
      "record_id": 835,
      "source_sc_utf16le_sha256": "D7C86465A51312B403752443FED8F6E6813DF7383C303E1BE782E0693BDD9271"
    },
    {
      "block_id": 6,
      "ko": "와도 힘을 합쳐야 한다니",
      "literal_id": 1,
      "record_id": 835,
      "source_sc_utf16le_sha256": "724D6012F2716B733613587DDFE18E506D5C235A5651AD999080B531665160A0"
    },
    {
      "block_id": 6,
      "ko": "의 얼굴이라……\n솔직히 보고 싶지도 않군",
      "literal_id": 0,
      "record_id": 836,
      "source_sc_utf16le_sha256": "822BBBC61128DB5443359B8EA57018841428615E62764C6514F2E75B45904A08"
    },
    {
      "block_id": 6,
      "ko": "상처가 아프군……",
      "literal_id": 0,
      "record_id": 847,
      "source_sc_utf16le_sha256": "E547FB492ADDAE5B52B64F814A5A5C6C0E499BA8B141A228DBF05C655ADDB309"
    },
    {
      "block_id": 6,
      "ko": "이런 날에는\n몸이 쑤시는군……",
      "literal_id": 0,
      "record_id": 848,
      "source_sc_utf16le_sha256": "285B62E2F69ECF9FAF3B42980613F45E5DFEBCDE16C7064DA949477032F5F462"
    },
    {
      "block_id": 6,
      "ko": "상처가 좀 아프네요……",
      "literal_id": 0,
      "record_id": 849,
      "source_sc_utf16le_sha256": "0E7A92E4F7921B46B8EB6EFAA54E5647748BD6E9485BA080933989C7D8B20756"
    },
    {
      "block_id": 6,
      "ko": "상처가 나을 때까지\n느긋하게 쉬고 싶군……",
      "literal_id": 0,
      "record_id": 850,
      "source_sc_utf16le_sha256": "5374BB0F7357DEA1A404843BC3D7A7A133DB902F659F7DBD2594707D9B56E8A7"
    },
    {
      "block_id": 6,
      "ko": "상처가 아프군……",
      "literal_id": 0,
      "record_id": 851,
      "source_sc_utf16le_sha256": "3FBBF68803F956F1C94E95ADAF4C61B07308DC47EE18607C5FCB97B92289E2C7"
    },
    {
      "block_id": 6,
      "ko": "이 정도 상처야\n핥으면 낫는다……",
      "literal_id": 0,
      "record_id": 852,
      "source_sc_utf16le_sha256": "B48036F50D61467927BC3FDFCE8C9CADEAA19A0612C4D19FEF49B83424B1DC29"
    },
    {
      "block_id": 6,
      "ko": "상처가……아픕니다……",
      "literal_id": 0,
      "record_id": 859,
      "source_sc_utf16le_sha256": "3FBBF68803F956F1C94E95ADAF4C61B07308DC47EE18607C5FCB97B92289E2C7"
    },
    {
      "block_id": 6,
      "ko": "이깟 상처로\n약한 소리는 할 수 없습니다……",
      "literal_id": 0,
      "record_id": 860,
      "source_sc_utf16le_sha256": "CB51216B54A13113394AAFAF2E636B78D49828529122E68D9FB005F45C441B84"
    },
    {
      "block_id": 6,
      "ko": "머리가 어질어질하군……",
      "literal_id": 0,
      "record_id": 871,
      "source_sc_utf16le_sha256": "C56FA63FC3B8FF6384ED8FF2585BFDC26DBD47B2E81538CBD534A392C6A0256A"
    },
    {
      "block_id": 6,
      "ko": "나도 여기까지인가……",
      "literal_id": 0,
      "record_id": 872,
      "source_sc_utf16le_sha256": "42E3AA04280DB243808016724B1F9061F9609F13E29AAD256A09A432F0565FEE"
    },
    {
      "block_id": 6,
      "ko": "아아……몸 상태가 좋지 않군……",
      "literal_id": 0,
      "record_id": 873,
      "source_sc_utf16le_sha256": "38CDFC73EE75B7DFDAF0BA615DA10711ADDB40A0D9FC2E3D54430085F6EBBF6E"
    },
    {
      "block_id": 6,
      "ko": "이제 죽을 날이\n가까운 모양이군……",
      "literal_id": 0,
      "record_id": 874,
      "source_sc_utf16le_sha256": "35CF1C57A48221C46B24EB474B35C9CD7F51750CD85AA8A970DA45ADD4E58361"
    },
    {
      "block_id": 6,
      "ko": "한기가 드는군……",
      "literal_id": 0,
      "record_id": 875,
      "source_sc_utf16le_sha256": "76B3322BDC52D8D2A85B880F787C9AB043596FF178CDDCC228F97A602998830C"
    },
    {
      "block_id": 6,
      "ko": "평생을 전장에서\n살았건만……",
      "literal_id": 0,
      "record_id": 876,
      "source_sc_utf16le_sha256": "99212A36DFE403376FA855252EC37908A584E4CE53A9131E7C0DA46DA5EFE80D"
    },
    {
      "block_id": 6,
      "ko": "열이 내리지 않네요……",
      "literal_id": 0,
      "record_id": 883,
      "source_sc_utf16le_sha256": "4C49B7722AFB233A691F5EAE090EFE08A804E776C98D02C8CF035587EC6EF5CF"
    },
    {
      "block_id": 6,
      "ko": "이별할 날이\n가까운지도 모르겠군……",
      "literal_id": 0,
      "record_id": 884,
      "source_sc_utf16le_sha256": "3BEF3A6C1C093F72764E29A310B22549A011B2ECACFB7487A8568C94BB5595EC"
    },
    {
      "block_id": 6,
      "ko": "어떤 방침이 되려나",
      "literal_id": 0,
      "record_id": 895,
      "source_sc_utf16le_sha256": "EBD07A0B367E154F925DFD307FC0BA3305B5BD758D8F907777035B75D352C591"
    },
    {
      "block_id": 6,
      "ko": "결단은 빠를수록 좋다",
      "literal_id": 0,
      "record_id": 896,
      "source_sc_utf16le_sha256": "34DFC01D77DCE0D0E8676E630BDFC1C1BD38FC7111F6E91F5456FDF0D9832CC5"
    },
    {
      "block_id": 6,
      "ko": "새로운 방침인가",
      "literal_id": 0,
      "record_id": 897,
      "source_sc_utf16le_sha256": "BDA7F9833987230B13D306C5CB8A1CCEF05B7F87E5784067C708134E34827F01"
    },
    {
      "block_id": 6,
      "ko": "깊이 생각해 주시면 좋겠군",
      "literal_id": 0,
      "record_id": 898,
      "source_sc_utf16le_sha256": "5D05EFD1E8AB585140D7660D1FFB7CC2BE352C271B6C41A8C23F54C800022B28"
    },
    {
      "block_id": 6,
      "ko": "방침이 정해지는 건가",
      "literal_id": 0,
      "record_id": 899,
      "source_sc_utf16le_sha256": "4F9792B7E9D6D0A4D81841DE2CD21D58A7CC146C83F4A546F50CA004BECA3DDA"
    },
    {
      "block_id": 6,
      "ko": "현 상황을 타개할 방법이 있는가",
      "literal_id": 0,
      "record_id": 900,
      "source_sc_utf16le_sha256": "46C3168B4784A0D0D357326C89B26A3E612B51C96DFE873B85BD493E7A94ED05"
    },
    {
      "block_id": 6,
      "ko": "어떤 지침이 될까요",
      "literal_id": 0,
      "record_id": 907,
      "source_sc_utf16le_sha256": "81EA16C2F8FB734804549ABDC8BBE939CD1474AA649D7E16CEC43F88C5DB01A4"
    },
    {
      "block_id": 6,
      "ko": "마침내 결단하시는군요",
      "literal_id": 0,
      "record_id": 908,
      "source_sc_utf16le_sha256": "16928DFC9C833232EB20B726078ADBB543BB355CE7FD47DAAF48FEA5E5631000"
    },
    {
      "block_id": 6,
      "ko": "정책은 나라 세우기의 기초지.",
      "literal_id": 0,
      "record_id": 919,
      "source_sc_utf16le_sha256": "EB5D00303A285ADF1E50D03A389CE63330983C976DD280FC0A1FB83288B75378"
    },
    {
      "block_id": 6,
      "ko": "정책은 본가의 지침이니 소홀히 할 수 없다.",
      "literal_id": 0,
      "record_id": 920,
      "source_sc_utf16le_sha256": "A38C263D27F92EEFB5F715A4FB1DDD2AAD2214208B05410D67360B581900BC6A"
    },
    {
      "block_id": 6,
      "ko": "정책은 신중히 정해야 한다.",
      "literal_id": 0,
      "record_id": 921,
      "source_sc_utf16le_sha256": "BEF466632D3B76C01F6DF7DBA011E8AB2AF4699E165F0FAF2DEA7BF2639B1CD0"
    },
    {
      "block_id": 6,
      "ko": "정책에 따라\n전략도 달라지겠지…… ",
      "literal_id": 0,
      "record_id": 922,
      "source_sc_utf16le_sha256": "33A0B0F3D97339A1B5E4A1A3B1EA58F63FD1FE707AED0A59791222635AE2B864"
    },
    {
      "block_id": 6,
      "ko": "정책을 발령하시는 건가?",
      "literal_id": 0,
      "record_id": 923,
      "source_sc_utf16le_sha256": "A31FAC1AA10CB9BDCC44E85ACBA91788F4E19CF2F1564C83AC32459049AE6612"
    },
    {
      "block_id": 6,
      "ko": "그 정책을\n발령해 주신다면……",
      "literal_id": 0,
      "record_id": 924,
      "source_sc_utf16le_sha256": "7378150E154CDD56EF1B173B5A4B25A49996020DD3D6F3B15E153AECB03BC834"
    },
    {
      "block_id": 6,
      "ko": "정책을 발령하는 건가?",
      "literal_id": 0,
      "record_id": 931,
      "source_sc_utf16le_sha256": "BE6A61B713540FA2696A00699C5C159AF41E7736DF535EC7F92FF03BF1E15EF6"
    },
    {
      "block_id": 6,
      "ko": "백성의 이해를 얻을\n좋은 정책을 부탁드립니다……",
      "literal_id": 0,
      "record_id": 932,
      "source_sc_utf16le_sha256": "ECA9F665C93CEC00891BEC1A0A2B9B8012CDA00BF148F228A32CA0C31088B815"
    },
    {
      "block_id": 6,
      "ko": "군량 재고를\n확인해 봅시다",
      "literal_id": 0,
      "record_id": 943,
      "source_sc_utf16le_sha256": "85E9CC3ED6DB5BB7EBFF8EAEF27354B38FB8148A6F210D20210E6E3B6EDAA4C0"
    },
    {
      "block_id": 6,
      "ko": "금전과 군량, 어느 쪽도 빠뜨릴 수 없지……",
      "literal_id": 0,
      "record_id": 944,
      "source_sc_utf16le_sha256": "CD7A54DD5F9F5A8B8B6895B09CA4A1E12B9D212A434C8C1B51E6D550CF4FC2DD"
    },
    {
      "block_id": 6,
      "ko": "남는 군량은\n파는 것도 방법입니다",
      "literal_id": 0,
      "record_id": 945,
      "source_sc_utf16le_sha256": "551696A985B988B70777DA1983A5A76853F7FDE59EF76236E0D9A71E204BD07B"
    },
    {
      "block_id": 6,
      "ko": "걱정 없을 만큼 많은 쌀에\n파묻혀 보고 싶군",
      "literal_id": 0,
      "record_id": 946,
      "source_sc_utf16le_sha256": "AE4666DBD2DA3E1E8F9C6F88A7D151BDC62D25668557D6810FD1E63A821B9A21"
    },
    {
      "block_id": 6,
      "ko": "상인을 부릅시다",
      "literal_id": 0,
      "record_id": 947,
      "source_sc_utf16le_sha256": "948E1218E1513C69465B78C94C6F190F40C8F1385F36FB46DEAF7E50DC73143A"
    }
  ],
