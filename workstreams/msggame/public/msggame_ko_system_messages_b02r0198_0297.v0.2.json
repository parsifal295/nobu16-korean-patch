      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "내 영지는 한 치도 침범하게 두지 않겠다!\n철저히 지켜 내겠다!",
      "literal_id": 0,
      "record_id": 225,
      "source_sc_utf16le_sha256": "6CB99C7365ED252DCD05668127E4F669A4ADCC7F1740F1D5818721AC00CB0126"
    },
    {
      "block_id": 2,
      "ko": "수비야말로 내 특기다!\n철벽의 방비를 보여 주마.",
      "literal_id": 0,
      "record_id": 226,
      "source_sc_utf16le_sha256": "A71CD1A7BA1FC0DB61183FE72D22BEFE4714DA20658FDF1AFC9CE405BCC40346"
    },
    {
      "block_id": 2,
      "ko": "내 힘을 똑똑히 보아라!",
      "literal_id": 0,
      "record_id": 227,
      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "성 공략은 내 본분이다.\n선봉은 우리 부대가 맡겠다!",
      "literal_id": 0,
      "record_id": 228,
      "source_sc_utf16le_sha256": "BE59695FF2BCE9A4F59B52E7B2D0E281488F5CA04407656A8ADF994C93062813"
    },
    {
      "block_id": 2,
      "ko": "내 힘을 똑똑히 보아라!",
      "literal_id": 0,
      "record_id": 229,
      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "싸움이야말로 무가의 본분!\n내 활약을 기대하라!",
      "literal_id": 0,
      "record_id": 230,
