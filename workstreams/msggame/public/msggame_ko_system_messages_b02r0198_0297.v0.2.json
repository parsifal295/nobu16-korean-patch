      "source_sc_utf16le_sha256": "A3021EE5AA26693764FB5B2B487FE56221A290735A4B5620B1E8F5571A5B345C"
    },
    {
      "block_id": 2,
      "ko": "뒷일이라면 내게 맡겨라……\n보좌할 대상:",
      "literal_id": 0,
      "record_id": 242,
      "source_sc_utf16le_sha256": "6EE5C8CEAC369F02ABF24BDFD3724E2741B44FD95CF0283A845A3D6198D43128"
    },
    {
      "block_id": 2,
      "ko": ".\n반드시 성과를 내 보이겠다.",
      "literal_id": 1,
      "record_id": 242,
      "source_sc_utf16le_sha256": "87655884F745AA0F307B525B4E5880472EFAA1AE8998F7AAAB918FE77599820C"
    },
    {
      "block_id": 2,
      "ko": "내 힘을 똑똑히 보아라!",
      "literal_id": 0,
      "record_id": 243,
      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "수상전에서는 질 수 없다.\n해신의 가호가 우리와 함께하기를.",
      "literal_id": 0,
      "record_id": 244,
      "source_sc_utf16le_sha256": "A5FAF8153E211D48C941D79B7E6BEE5AF5E685A6295D86281F7B0485CAE8EA37"
    },
    {
      "block_id": 2,
      "ko": "내 힘을 똑똑히 보아라!",
      "literal_id": 0,
      "record_id": 245,
      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "내 힘을 똑똑히 보아라!",
      "literal_id": 0,
      "record_id": 246,
      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "공사는 원래 내 특기지……\n신속히 끝내 주마.",
      "literal_id": 0,
      "record_id": 247,
