      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "내 힘을 똑똑히 보아라!",
      "literal_id": 0,
      "record_id": 240,
      "source_sc_utf16le_sha256": "B7B7410BAF5E0AD51CE54199781A1DD0DA0E5C93DCF04B732B121414D056FDFB"
    },
    {
      "block_id": 2,
      "ko": "뒤에서 하는 일은 내게 맡겨라……\n머리를 쓰는 방식부터 다르지……",
      "literal_id": 0,
