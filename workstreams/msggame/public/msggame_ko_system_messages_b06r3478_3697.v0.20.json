  "entries": [
    {
      "block_id": 6,
      "ko": "대인을 위해 힘쓸 수 있어\n더없이 영광입니다.\n상으로",
      "literal_id": 0,
      "record_id": 3478,
      "source_sc_utf16le_sha256": "A33611BB1ED15B7D5BD7A073EFE52BF5D2F089B258DFB40B92D71C2BBDF188A8"
    },
    {
      "block_id": 6,
      "ko": "이나 관직 등을 내려 주셔도 됩니다.",
      "literal_id": 1,
      "record_id": 3478,
      "source_sc_utf16le_sha256": "B8DDC40B4F84F4740C92A2DA3DDAAC1A1AE742176ED23D98A2B3CC64A4245FE6"
    },
    {
      "block_id": 6,
      "ko": "대인을 위해 힘쓸 수 있어\n더없이 영광입니다.\n상으로",
      "literal_id": 0,
      "record_id": 3479,
      "source_sc_utf16le_sha256": "A33611BB1ED15B7D5BD7A073EFE52BF5D2F089B258DFB40B92D71C2BBDF188A8"
    },
    {
      "block_id": 6,
      "ko": "이나 관직 등을 내려 주셔도 됩니다.",
      "literal_id": 1,
      "record_id": 3479,
      "source_sc_utf16le_sha256": "B8DDC40B4F84F4740C92A2DA3DDAAC1A1AE742176ED23D98A2B3CC64A4245FE6"
    },
    {
      "block_id": 6,
      "ko": "대인을 위해 힘쓸 수 있어\n더없이 영광입니다.\n상으로",
      "literal_id": 0,
      "record_id": 3483,
      "source_sc_utf16le_sha256": "A33611BB1ED15B7D5BD7A073EFE52BF5D2F089B258DFB40B92D71C2BBDF188A8"
    },
    {
      "block_id": 6,
      "ko": "이나 관직 등을 내려 주셔도 됩니다.",
      "literal_id": 1,
      "record_id": 3483,
      "source_sc_utf16le_sha256": "B8DDC40B4F84F4740C92A2DA3DDAAC1A1AE742176ED23D98A2B3CC64A4245FE6"
    },
    {
      "block_id": 6,
      "ko": "말하자면:",
      "literal_id": 0,
      "record_id": 3489,
      "source_sc_utf16le_sha256": "EE83BC3C945C5824BF3F8971F1495EC0BB530451DEA7494CEF231220EA3E932E"
    },
    {
      "block_id": 6,
      "ko": "은 그야말로 가신의 얼굴……\n공훈 1위를 차지하지 못해서야\n도저히",
      "literal_id": 1,
      "record_id": 3489,
      "source_sc_utf16le_sha256": "1365169FA7704F44C122CE58E47BD1C0BB4955DCF6F5C7A3466066A84AAA2EC2"
    },
    {
      "block_id": 6,
      "ko": "의 패업을 받들기엔 역부족이겠지.",
      "literal_id": 2,
      "record_id": 3489,
      "source_sc_utf16le_sha256": "F795D2192065F847DF0A932DC621746E415440D5DE4D52ECCBF01747CB8ECEA3"
    },
    {
      "block_id": 6,
      "ko": "대인께서 중용해 주신 덕에\n제가 이 자리에 설 수 있었습니다.\n앞으로도 대인을 위해 힘쓰는 것을 사명으로 삼겠습니다.",
      "literal_id": 0,
      "record_id": 3490,
      "source_sc_utf16le_sha256": "759A014E1E2E735830DFA9D8D5B98B9866D717F260747671649C80310E18D16A"
    },
    {
      "block_id": 6,
      "ko": "공훈 1위라……\n뭐, 거드름 피우는 데 질려서\n제 직분의 일을 했을 뿐이오.",
      "literal_id": 0,
      "record_id": 3491,
      "source_sc_utf16le_sha256": "E03EE4D82B15202AF6706F32D13402F06BD504008BDF8271407B2953F9066524"
    },
    {
      "block_id": 6,
      "ko": "대인께서 중용해 주신 덕에\n제가 이 자리에 설 수 있었습니다.\n앞으로도 대인을 위해 힘쓰는 것을 사명으로 삼겠습니다.",
      "literal_id": 0,
      "record_id": 3495,
      "source_sc_utf16le_sha256": "759A014E1E2E735830DFA9D8D5B98B9866D717F260747671649C80310E18D16A"
    },
    {
      "block_id": 6,
      "ko": "평소의 노력이 인정받은 모양이군요.\n앞으로도 더욱 정진하겠습니다.",
      "literal_id": 0,
      "record_id": 3499,
      "source_sc_utf16le_sha256": "A01E761428A0EA9B0306703D8CE11274A6978398CDC8FA6A7A06C85BAFD2AC36"
    },
    {
      "block_id": 6,
      "ko": "오,",
      "literal_id": 0,
      "record_id": 3500,
      "source_sc_utf16le_sha256": "226B2E476A303245D398E58C6B25A457A1EF84AB303D5DD399401AEA51EEF913"
    },
    {
      "block_id": 6,
      "ko": "께서",
      "literal_id": 1,
      "record_id": 3500,
      "source_sc_utf16le_sha256": "EE4458C984EAF91DC03E95EE4E22C7796FE16AA5BA9EAED9B0C6063F1CA16809"
    },
    {
      "block_id": 6,
      "ko": "이 되셨군요……\n그러나",
      "literal_id": 2,
      "record_id": 3500,
      "source_sc_utf16le_sha256": "50E6B974A8A1DC2C82805E676423CDDE7677C8460B3E7D4604C1DC1BCA1C1925"
    },
    {
      "block_id": 6,
      "ko": "의 판단을 후회하게 하지 않도록\n이 직위에 걸맞게 힘쓰겠습니다.",
      "literal_id": 3,
      "record_id": 3500,
      "source_sc_utf16le_sha256": "BB6EB4736568D50CB1BA01BF69BC4E050D061B80ECA027EB794C46D256BE94C2"
    },
    {
      "block_id": 6,
      "ko": "승진할 기회를 받다니,\n더없이 감사할 따름입니다.",
      "literal_id": 0,
      "record_id": 3501,
      "source_sc_utf16le_sha256": "FC1E76DDBEDF4785013290CD4270F252DBC4DFF4C122C3E647FA95D8DBB8BC4B"
    },
    {
      "block_id": 6,
      "ko": "발탁 직위:",
      "literal_id": 0,
      "record_id": 3502,
      "source_sc_utf16le_sha256": "1F69E7F0442656B8A9D3EBA4F20F6CBF9427A4A9709AEBAFF6851CFE4ACF3D81"
    },
    {
      "block_id": 6,
      "ko": "에 발탁되다니……\n우쭐해하지 않고\n더 큰 공훈을 세우겠습니다.",
      "literal_id": 1,
      "record_id": 3502,
      "source_sc_utf16le_sha256": "73DD5D48E7B7323DA5514BCA795929B45051A88EFB1F2246389CD2BBEBFDB8C5"
    },
    {
      "block_id": 6,
      "ko": "새 직위:",
      "literal_id": 0,
      "record_id": 3503,
      "source_sc_utf16le_sha256": "5F05CEAF6097ADE9A2708A2667A84A18D4C874DA8533E531F2A78FFF1BE95F9A"
    },
    {
      "block_id": 6,
      "ko": "이 된다면\n그에 걸맞은 책임도 따르겠지요.\n마음 단단히 먹겠습니다.",
      "literal_id": 1,
      "record_id": 3503,
      "source_sc_utf16le_sha256": "3253DF5E2F90A8F7FD65B4EB499C2F45C5F59C065A267C95923E7E93556B555E"
    },
    {
      "block_id": 6,
      "ko": "마침내",
      "literal_id": 0,
      "record_id": 3504,
      "source_sc_utf16le_sha256": "EF94CB376C6C7F89305250CC865160CC8ECCD322A0427D022250144EE33108C5"
    },
    {
      "block_id": 6,
      "ko": "이 되었습니다……!\n이 은혜는 평생을 걸고 갚겠습니다.",
      "literal_id": 1,
      "record_id": 3504,
      "source_sc_utf16le_sha256": "D619CA93F646CA3B16EEC1F3DEC3B0594AD490832457A649D4AAD3C18BC6C00F"
    },
    {
      "block_id": 6,
      "ko": "일한 보람이 있군요.\n충성을 다한 것도 헛되지 않았습니다.\n더욱 본가를 번영시키겠습니다.",
      "literal_id": 0,
      "record_id": 3505,
      "source_sc_utf16le_sha256": "2E55317B8D0296D964D96AB46FEB0D49003A9A9DF155FBB07E614EFC651CB073"
    },
    {
      "block_id": 6,
      "ko": "승진 직위:",
      "literal_id": 0,
      "record_id": 3506,
      "source_sc_utf16le_sha256": "EE4458C984EAF91DC03E95EE4E22C7796FE16AA5BA9EAED9B0C6063F1CA16809"
    },
    {
      "block_id": 6,
      "ko": "이 되는 일이\n이토록 기쁠 줄이야.",
      "literal_id": 1,
      "record_id": 3506,
      "source_sc_utf16le_sha256": "C240DE92A8B2F8EF3D6911391A80B047277ED4F1B0C8B2E9DB57E4ECDCC51454"
    },
    {
      "block_id": 6,
      "ko": "가신 모두가 더욱 충성을 다해\n본가를 일으켜 세워야 합니다……",
      "literal_id": 0,
      "record_id": 3507,
      "source_sc_utf16le_sha256": "2718069B001DB022E18727BDB53D69C8F6C2C317E719801DFF21F50262843ED3"
    },
    {
      "block_id": 6,
      "ko": "공이 많은 자, 적은 자……\n논공행상은 자신의 공적을 돌아보는\n좋은 계기가 되겠군요.",
      "literal_id": 0,
      "record_id": 3508,
      "source_sc_utf16le_sha256": "221712E9DC136AA4C04BBF590604A289B7CBA0048B64C7847D2A4A4E9A2F4378"
    },
    {
      "block_id": 6,
      "ko": "상벌을 분명히 하는 것은 나라의 근본.\n공을 세운 자에게 합당한 상을 내리는 것은\n당연한 일입니다.",
      "literal_id": 0,
      "record_id": 3509,
      "source_sc_utf16le_sha256": "705252D7AB08890E091345BC9BE28504F92B87BF718025AAD7FA4BF5DB909DE5"
    },
    {
      "block_id": 6,
      "ko": "의",
      "literal_id": 0,
      "record_id": 3514,
      "source_sc_utf16le_sha256": "26F49E51C62FA11E4FD7D754851317555EF7091B2925FC9517397FEE5871CC3D"
    },
    {
      "block_id": 6,
      "ko": "가 공훈 1위라니……\n기쁘기도 하지만,\n더욱",
      "literal_id": 1,
      "record_id": 3514,
      "source_sc_utf16le_sha256": "641EAFDBC9590DF7BAAC79A8474F0E70BDB7F5C961DE03F7B06783FF0B2A0288"
    },
    {
      "block_id": 6,
      "ko": "의 오른팔이 되겠습니다.",
      "literal_id": 2,
      "record_id": 3514,
      "source_sc_utf16le_sha256": "61E858A65645DAECB64DCC19613EDFB1BE91E5B008741F5B0C852B2A6A3EDDAA"
    },
    {
      "block_id": 6,
      "ko": "공훈 1위라니 참으로 기쁩니다.\n아직 미숙하지만 한 걸음씩 나아가며\n본가에 공헌하겠습니다.",
      "literal_id": 0,
      "record_id": 3515,
      "source_sc_utf16le_sha256": "514D0CC90A66B5D9FA61324ACBA04A33CE7B588E7968D3559F3C4747CACCA885"
    },
    {
      "block_id": 6,
      "ko": "제가 공훈 1위라니……\n미숙한 제게 과분한 평가입니다.\n황송할 따름입니다.",
      "literal_id": 0,
      "record_id": 3516,
      "source_sc_utf16le_sha256": "12F60CE09EB1F0D57177550D3DD8647E66066BF8E932808151216BDFC93C21B2"
    },
    {
      "block_id": 6,
      "ko": "공훈 1위라니 정말 기쁩니다.\n앞으로도 이 영예에 자만하지 않고\n스스로를 엄히 다스리겠습니다.",
      "literal_id": 0,
      "record_id": 3517,
      "source_sc_utf16le_sha256": "A172C7B323D0A45EB30BC92A22B68448AE018BCACD313BAD1E3A824056CD401B"
    },
    {
      "block_id": 6,
      "ko": "공훈 1위라니……\n부하들은 제 무모함에\n진땀을 빼고 있을 줄 알았는데…… ",
      "literal_id": 0,
      "record_id": 3518,
      "source_sc_utf16le_sha256": "6E382CF051721855B9246717074B56A42E5EA86B618175F7B2C3690B793CB4C2"
    },
    {
      "block_id": 6,
      "ko": "공훈 1위라니요?!\n이를 계기로,\n다음에도 힘껏 뛰겠습니다!",
      "literal_id": 0,
      "record_id": 3524,
      "source_sc_utf16le_sha256": "286D00C11B18FDB5042269000E5AD380389F27C4F866B891E34F237357DB44F9"
    },
    {
      "block_id": 6,
      "ko": "아직 한참 더 일할 수 있습니다!\n더 많은 일을 맡겨 주십시오!",
      "literal_id": 0,
      "record_id": 3525,
      "source_sc_utf16le_sha256": "542F86D0FCF7AA145A6F0BD48E349FDCB50D045CAE62C1AFDBEEFF5F6FDFEECF"
    },
    {
      "block_id": 6,
      "ko": "공훈 수석이 되다니,\n더없이 영광입니다.\n앞으로도 본가의 번영을 위해 힘쓰겠습니다!",
      "literal_id": 0,
      "record_id": 3536,
      "source_sc_utf16le_sha256": "6C448CC775E9308E38AFC8AB9974C19E9F58B58E37EF234FD5375B070FA7361B"
    },
    {
      "block_id": 6,
      "ko": "가신은 그야말로 가문의 얼굴……\n공훈 1위를 차지하지 못한다면\n도저히",
      "literal_id": 0,
      "record_id": 3537,
      "source_sc_utf16le_sha256": "31AB67912E7F039C13E6E9C7141754552FA4C5F0885DFD0B39F299A6528B06BD"
    },
    {
      "block_id": 6,
      "ko": "의 패업을 뒷받침하기엔 역부족이겠지.",
      "literal_id": 1,
      "record_id": 3537,
      "source_sc_utf16le_sha256": "567F2D3D1F8A2E2728F8E13EB2D03AAA76C2D19483BA2D2031E78732FC7105F1"
    },
    {
      "block_id": 6,
      "ko": "의",
      "literal_id": 0,
      "record_id": 3538,
      "source_sc_utf16le_sha256": "26F49E51C62FA11E4FD7D754851317555EF7091B2925FC9517397FEE5871CC3D"
    },
    {
      "block_id": 6,
      "ko": "가 공훈 1위라니……\n더없이 기쁘지만,\n부하들도 더욱 힘써 주었으면 좋겠군.",
      "literal_id": 1,
      "record_id": 3538,
      "source_sc_utf16le_sha256": "B4907373816C4EA36FFAC96F5BB555D4263E34E8E6649E292F7826A41AB28511"
    },
    {
      "block_id": 6,
      "ko": "신하의 도를 닦는 길에는 끝이 없습니다……\n본가의 앞날을 지켜보는 것이야말로\n",
      "literal_id": 0,
      "record_id": 3539,
      "source_sc_utf16le_sha256": "1888EBD326AF73D12E1F93CD8391355ADF551A0C4D36F0C75B31DEDE762CC9C9"
    },
    {
      "block_id": 6,
      "ko": "의 천명입니다.",
      "literal_id": 1,
      "record_id": 3539,
      "source_sc_utf16le_sha256": "3D3AA670612E24847473A2C279D98F465B44B561696D66DF02946A9B7A9DEBF9"
    },
    {
      "block_id": 6,
      "ko": "오, 공훈 1위라……\n직위",
      "literal_id": 0,
      "record_id": 3540,
      "source_sc_utf16le_sha256": "EB4D3CECBAB428088C2D0A8DC6427711242C33ECABA3D78891E47549F19648A4"
    },
    {
      "block_id": 6,
      "ko": "이 되면 할 일이 많으니,\n마땅히 열심히 해야지.",
      "literal_id": 1,
      "record_id": 3540,
      "source_sc_utf16le_sha256": "FCB896235A388BD994494136B101B5207E8609355BBC02DAE7B26A2D33510FD8"
    },
    {
      "block_id": 6,
      "ko": "공훈 1위라……\n뭐, 거드름 피우는 데 질려서\n제 직분의 일을 했을 뿐이오.",
      "literal_id": 0,
      "record_id": 3541,
      "source_sc_utf16le_sha256": "D3069F2CFA23BFC00448293C4664B969C4E93640128CD88FCFD252FEB39436F0"
    },
    {
      "block_id": 6,
      "ko": "좋아!",
      "literal_id": 0,
      "record_id": 3548,
      "source_sc_utf16le_sha256": "995E49CB9AAF78FFE2401375FEF56C92CC440E8AE63911933B33DBCB4901956D"
    },
    {
      "block_id": 6,
      "ko": "의 체면은 지켰군.\n……",
      "literal_id": 1,
      "record_id": 3548,
      "source_sc_utf16le_sha256": "27C452D22BA388759F80BBDCAB4F75827416DC438860C59AD39D8FFA34ECD67E"
    },
    {
      "block_id": 6,
      "ko": "라고 하면 나이 든 것 같아\n썩 기분 좋지는 않지만……",
      "literal_id": 2,
      "record_id": 3548,
      "source_sc_utf16le_sha256": "972AD0F21BCC646AD43189F4F3E7FED04A92CEB534F61A2C0FD75F4E43CAEF90"
    },
    {
      "block_id": 6,
      "ko": "공훈 1위라니……\n최고의 영예라 할 만하군.\n항상 이 마음을 잊지 말아야지!",
      "literal_id": 0,
      "record_id": 3549,
      "source_sc_utf16le_sha256": "BFA4FA95C680815C52AAEA0823EEF4B001A4661BD0016F9535D27ABAB94E326D"
    },
    {
      "block_id": 6,
      "ko": "참으로 경사로군요.\n앞으로도 본가를 잘 부탁드립니다.",
      "literal_id": 0,
      "record_id": 3558,
      "source_sc_utf16le_sha256": "DEF42165C3DE84576B16635F7CD9C7FCFB00918A6684D478CD68C43D424420C1"
    },
    {
      "block_id": 6,
      "ko": "앞으로는 두 분이 힘을 합쳐\n본가를 지켜 주십시오.",
      "literal_id": 0,
      "record_id": 3559,
      "source_sc_utf16le_sha256": "01128098FA18CE9DCAD7F6DFE9C46858EC25E84F44C98FA841251F6D2F0556EC"
    },
    {
      "block_id": 6,
      "ko": "경사로다, 경사로다.\n앞으로도 잘 부탁한다.",
      "literal_id": 0,
      "record_id": 3560,
      "source_sc_utf16le_sha256": "972977903193F64F018D474760CA2B75FBC54A8BAAC80700A6394FF596B76F5B"
    },
    {
      "block_id": 6,
