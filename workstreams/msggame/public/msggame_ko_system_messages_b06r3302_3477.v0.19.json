      "source_sc_utf16le_sha256": "99E83FF607108EF2E2FC9258001A533D8EA59DC52B99A21CEB1238929D81B099"
    },
    {
      "block_id": 6,
      "ko": "님, 안심하십시오.\n저",
      "literal_id": 0,
      "record_id": 3412,
      "source_sc_utf16le_sha256": "8CA0073304978BB47FB43759CCC4CBC20570F90E4E10BD4F04BA98B53D0F34FF"
    },
    {
      "block_id": 6,
      "ko": "는 목숨을 걸고,\n지킬 가문:",
      "literal_id": 1,
      "record_id": 3412,
      "source_sc_utf16le_sha256": "9EB918A27CA5E0EC07885C9D79913E0FD0109FAC7EE2CE38B638001B0E1C240B"
    },
    {
      "block_id": 6,
      "ko": "을 지키겠습니다.",
      "literal_id": 2,
      "record_id": 3412,
      "source_sc_utf16le_sha256": "BDB50AA19BD35221D14F3342CA42CBD9A236D3CB16A53CBA1E71A032338BACDD"
    },
