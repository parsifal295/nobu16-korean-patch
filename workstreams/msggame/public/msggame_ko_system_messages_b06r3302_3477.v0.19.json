      "source_sc_utf16le_sha256": "DFA817BC5B2D41849D1D24B6560C3BD5F3F48C691516A9C43405DD30407698CA"
    },
    {
      "block_id": 6,
      "ko": "추방 대상:",
      "literal_id": 0,
      "record_id": 3362,
      "source_sc_utf16le_sha256": "1D25D8BE78E497214109FE8FE92323A0C99BB2C38F747A610FAC2C4F3AD46AEF"
    },
    {
      "block_id": 6,
      "ko": "을 내쫓으면,\n상대 세력:",
      "literal_id": 1,
