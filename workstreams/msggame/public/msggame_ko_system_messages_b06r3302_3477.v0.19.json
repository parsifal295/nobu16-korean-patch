    },
    {
      "block_id": 6,
      "ko": "는 목숨을 걸고,\n지킬 대상:",
      "literal_id": 2,
      "record_id": 3402,
      "source_sc_utf16le_sha256": "54D4FF5A045FB275AF1B6CF99C8FC149E0786113B0184345393879D7BB6D4E88"
    },
