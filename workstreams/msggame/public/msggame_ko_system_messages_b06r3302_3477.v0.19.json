      "source_sc_utf16le_sha256": "2B2DC67961754D032BA493ED28F16BA818D9CDAD6E6B3D373792091281C85E13"
    },
    {
      "block_id": 6,
      "ko": "와의 혼인 동맹이\n사라집니다……",
      "literal_id": 2,
      "record_id": 3362,
      "source_sc_utf16le_sha256": "C609C416261DE337161D6837E5B02A6BC49A6119B1601877A98B9DB8DEE88ACF"
    },
    {
      "block_id": 6,
      "ko": "추방 대상:",
      "literal_id": 0,
      "record_id": 3366,
      "source_sc_utf16le_sha256": "1D25D8BE78E497214109FE8FE92323A0C99BB2C38F747A610FAC2C4F3AD46AEF"
    },
    {
      "block_id": 6,
      "ko": "을 내쫓으면,\n상대 세력:",
      "literal_id": 1,
      "record_id": 3366,
      "source_sc_utf16le_sha256": "2B2DC67961754D032BA493ED28F16BA818D9CDAD6E6B3D373792091281C85E13"
    },
    {
      "block_id": 6,
      "ko": "와의 혼인 동맹이\n사라집니다……",
      "literal_id": 2,
      "record_id": 3366,
      "source_sc_utf16le_sha256": "C609C416261DE337161D6837E5B02A6BC49A6119B1601877A98B9DB8DEE88ACF"
    },
    {
      "block_id": 6,
      "ko": "군단을 이끌면서도 쓸모없다니……\n나 자신도 한심하군.",
      "literal_id": 0,
      "record_id": 3369,
      "source_sc_utf16le_sha256": "1BE0C5D776D2F85351F1E610F15E4717E2BC29380865E25FAE3311DCA9F4A0C6"
    },
    {
      "block_id": 6,
      "ko": "군단을 이끄는 이 몸마저\n쓸모없다는 겁니까!",
      "literal_id": 0,
      "record_id": 3370,
      "source_sc_utf16le_sha256": "802EF829149D25B5D4498CE383EE7A261D09DDADF9B81350E361A60414A19F06"
    },
    {
      "block_id": 6,
      "ko": "이래 봬도 군단을 이끄는 몸인데\n그래도 쓸모없단 말인가?",
      "literal_id": 0,
      "record_id": 3371,
      "source_sc_utf16le_sha256": "7E68CB0B5D28028CA60A8597A3859F82C8A703EC95CDE51224A83CAF33DFD734"
