      "source_sc_utf16le_sha256": "3BB54B6F88DDC5957A105A81EEB695E7EE192B610133A60463BB00F22669C401"
    },
    {
      "block_id": 6,
      "ko": "와의 혼인 동맹이 무너집니다!",
