      "source_sc_utf16le_sha256": "1C0545777BA97F062816373AF2FEF34572EBB6829580F0C8210778E1D1B9D6A3"
    },
    {
      "block_id": 6,
      "ko": "을 위해 최선을 다하겠습니다.",
      "literal_id": 2,
