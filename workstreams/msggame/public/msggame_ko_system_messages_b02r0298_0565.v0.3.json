      "literal_id": 0,
      "record_id": 540,
      "source_sc_utf16le_sha256": "A23F3FFF59A1CA31D010907A5E8D2473BB23590D6FC8618BB99808EE1E5FE448"
    },
    {
      "block_id": 2,
      "ko": "의 철포는\n무엇이든 꿰뚫는다!",
      "literal_id": 1,
      "record_id": 540,
      "source_sc_utf16le_sha256": "CA70F9470FA9DF7A0776907D64637E99B03E12B98D9D25CEBE1375515A71E81A"
    },
    {
      "block_id": 2,
      "ko": "또 하나의 성이 우리 손에 들어왔다……\n천하에 떨칠 가문:",
      "literal_id": 0,
      "record_id": 544,
      "source_sc_utf16le_sha256": "8EA7D604D6EAA71FE5AFEB41851D6ABD9E7FDB1265FE48F848CE80653C166F52"
    },
    {
      "block_id": 2,
      "ko": "의 위세를\n널리 알려라!",
      "literal_id": 1,
      "record_id": 544,
      "source_sc_utf16le_sha256": "6DB99BFB236291C4296EBA637791A5EC6831A6696309BCA3AD5022CD3E6E46F5"
    },
    {
      "block_id": 2,
      "ko": "주군께서 지원하러 오신다!\n모두 힘을 보태 주시오!",
      "literal_id": 0,
      "record_id": 545,
      "source_sc_utf16le_sha256": "5EA2F80D23E9C3DBCCAB612814CFDFFD9D6671D61BC5C845F7EC9DC9F71225CE"
    },
    {
      "block_id": 2,
      "ko": "천하에 보여 줄 때가 왔다!\n",
      "literal_id": 0,
      "record_id": 546,
      "source_sc_utf16le_sha256": "6E41177B93F96F7D56EF684D40A17BB21F568A032F9A65C9AD2BFDBB16DF4F9E"
    },
    {
      "block_id": 2,
      "ko": "이(가) 자랑하는 기마대의 위력을!",
      "literal_id": 1,
      "record_id": 546,
      "source_sc_utf16le_sha256": "C23736647EA2521DEFB9E1A8CB0884DC3B857EC3710EDDB9655E48085EBF7815"
    },
    {
      "block_id": 2,
      "ko": "이 난세를 함께 헤쳐 갈 자:",
      "literal_id": 0,
      "record_id": 547,
      "source_sc_utf16le_sha256": "C4A952D4FB01D2A61526EB332CD06CB62B5C1B8244CEF817C21380BA9C073778"
    },
    {
      "block_id": 2,
      "ko": "\n다른 가문과 나란히 걸으리라.",
      "literal_id": 1,
      "record_id": 547,
      "source_sc_utf16le_sha256": "0D38BC09F1B86C6B6D364D0C1AFF9C871F00263B7D12CEA422BD9700ADEEB7E1"
    },
    {
      "block_id": 2,
      "ko": "문무를 겸비한 내 재능을,\n이곳에서 펼쳐 보이겠다.",
      "literal_id": 0,
      "record_id": 549,
      "source_sc_utf16le_sha256": "7AD4A50170C3E5E9F061631141AB01E71D90ED6293EEF0340A858387FFD93EC5"
    },
    {
      "block_id": 2,
      "ko": "내 지혜로,\n보좌할 대상:",
      "literal_id": 0,
      "record_id": 550,
      "source_sc_utf16le_sha256": "5ED20B4D279F2FA2BC83C06B865E78ADA9C1A5A006D6DDCD1C73851C49BB4B53"
    },
    {
      "block_id": 2,
      "ko": "을(를) 떠받치는 기둥이 되겠습니다.",
      "literal_id": 1,
      "record_id": 550,
      "source_sc_utf16le_sha256": "99E83FF607108EF2E2FC9258001A533D8EA59DC52B99A21CEB1238929D81B099"
    },
    {
      "block_id": 2,
      "ko": "이 땅을 풍요롭게 만들기 위해,\n온 힘을 다하겠다.",
      "literal_id": 0,
      "record_id": 551,
      "source_sc_utf16le_sha256": "E0C0260E083CB64C1A95DADF779EDE54752F0863CEC9910AD6A13DE253EFCC00"
    },
    {
      "block_id": 2,
      "ko": "내 창에 상처 입은 자:",
      "literal_id": 0,
      "record_id": 553,
      "source_sc_utf16le_sha256": "E2BFC85E81FC9A3ECAAB3DAD7FC675B53CEEDD6C87716883FDEF869F138E60A6"
    },
    {
      "block_id": 2,
      "ko": ",\n그것을 영광으로 여겨라……",
      "literal_id": 1,
      "record_id": 553,
      "source_sc_utf16le_sha256": "BB2AA1CFF61B5C39ACB4D8E1DBC7C420C8F103F66D52C945888623A6899440EF"
    },
    {
      "block_id": 2,
      "ko": "우리 부대가 자랑하는 기마와 철포의 위력을\n마음껏 맛보게 해 주마……",
      "literal_id": 0,
      "record_id": 554,
      "source_sc_utf16le_sha256": "D7FDB8EA5E7C9A4BC24686BC960DE0AD230DFD57C2998393D9DAF223D5D494F0"
    },
    {
      "block_id": 2,
      "ko": "악귀",
      "literal_id": 0,
      "record_id": 555,
      "source_sc_utf16le_sha256": "D8B18A67608FCF236006922A7D08A814BF3B996667689C687A973CE57818B60D"
    },
    {
      "block_id": 2,
      "ko": ",\n이 정도 열세는 아무것도 아니다!",
      "literal_id": 1,
      "record_id": 555,
      "source_sc_utf16le_sha256": "463B57F17368377328363C42194CE83F2EAAAEADF8DB923CC00417135EAAB508"
    },
    {
      "block_id": 2,
      "ko": "울어라, 톤보키리!\n이 열세야말로 내 무용을 떨칠 무대다!",
      "literal_id": 0,
      "record_id": 556,
      "source_sc_utf16le_sha256": "A23A26B840E95E3175A4CF9788821470E0E0066A798F071DDE26A2A016CE7405"
    },
    {
      "block_id": 2,
      "ko": "상대는 이름난 맹장:",
      "literal_id": 0,
      "record_id": 557,
      "source_sc_utf16le_sha256": "23C3187F2E0BC51FA7ADF75C9036405659CFD4571226669B13BE55BD1E3622AB"
    },
    {
      "block_id": 2,
      "ko": ",\n내 적수로 부족함이 없다!",
      "literal_id": 1,
      "record_id": 557,
      "source_sc_utf16le_sha256": "A3D04BAE233B7A9111F67A0F19D7E1CDD773C15DFEAE5103B1023492ACBF6E75"
    },
    {
      "block_id": 2,
      "ko": "상대는 이름난 맹장:",
      "literal_id": 0,
      "record_id": 558,
      "source_sc_utf16le_sha256": "23C3187F2E0BC51FA7ADF75C9036405659CFD4571226669B13BE55BD1E3622AB"
    },
    {
      "block_id": 2,
      "ko": "\n지략을 다해 승기를 잡자.",
      "literal_id": 1,
      "record_id": 558,
      "source_sc_utf16le_sha256": "573583281F13BE3FCD8A7A6A9602D910B951DB71C857B1A78E1401EFDFC1A7E4"
    },
    {
      "block_id": 2,
      "ko": "충의를 결코 잊지 않겠다:",
      "literal_id": 0,
      "record_id": 559,
      "source_sc_utf16le_sha256": "C2348B0022A0E8C8F3483E6681FFF4CDAE4FE76B7F85CFDD55CE02D65137FAA2"
    },
    {
      "block_id": 2,
      "ko": "……\n부디 편히 잠들어라.",
      "literal_id": 1,
      "record_id": 559,
      "source_sc_utf16le_sha256": "6933D4965ABD2A9B99AE28A456991881502B64314820252B2979F59197D6469E"
    },
    {
      "block_id": 2,
      "ko": "뇌신이여……\n이 열세를 헤쳐 갈 가호를 주소서!",
      "literal_id": 0,
      "record_id": 560,
      "source_sc_utf16le_sha256": "A556306AA4B60F984011BA9C9E8F801CD3D18F95F78CC9CA344155C2E8E8EF84"
    },
    {
      "block_id": 2,
      "ko": "이 정도는 열세도 아니다.\n십문자창으로 뒤집을 자:",
      "literal_id": 0,
      "record_id": 561,
      "source_sc_utf16le_sha256": "20FF4650754517D8F2DFE67397DD50D53E74F8E856E816BE5F421AE68FD78E5C"
    },
    {
      "block_id": 2,
      "ko": "이(가) 전세를 뒤집는다!",
      "literal_id": 1,
      "record_id": 561,
      "source_sc_utf16le_sha256": "FAD23ABCC6B3BFA0AD28756C1A1C331BB9039743EE869EAB71E5768DBBAAB7E7"
    },
    {
      "block_id": 2,
      "ko": "적의 수가 더 많다고!\n하, 창의 마타자 솜씨를 보일 때로군!",
      "literal_id": 0,
      "record_id": 562,
      "source_sc_utf16le_sha256": "0B8FAE449F07B43BDC932116AA137B94DDD00C7DCEB85F8A2563C0C42805813A"
    },
    {
      "block_id": 2,
      "ko": "잡병들은 길을 비켜라!\n전장을 누빌 악귀:",
      "literal_id": 0,
      "record_id": 563,
      "source_sc_utf16le_sha256": "9E0D60AE4A604A4885701620178323859CAC95EB0959F1584DD3BA847AA1B7D0"
    },
    {
      "block_id": 2,
      "ko": ", 지금 전장을 누빈다!",
      "literal_id": 1,
      "record_id": 563,
      "source_sc_utf16le_sha256": "6FBF21E3B6392B57B8467072A3EE5F5FF786B082DBF1C557EA828F13B5F0898E"
    },
    {
      "block_id": 2,
      "ko": "병력의 많고 적음은 사소한 일.\n계책이 많으면 이기고, 적으면 질 뿐이다.",
      "literal_id": 0,
      "record_id": 564,
      "source_sc_utf16le_sha256": "48E3FE3E5A6D671DED6738D5DBE703F0DCDCB52F47FFA1A7FDD11C1D17E72ED5"
    },
    {
      "block_id": 2,
      "ko": "열세인가……\n내 계책으로 무너뜨리겠다.",
      "literal_id": 0,
      "record_id": 565,
      "source_sc_utf16le_sha256": "F895AB9B2D9800D4AFA472A7165D66658AB84A6C6CC16D4945E9EECCE5F343C9"
    }
  ],
