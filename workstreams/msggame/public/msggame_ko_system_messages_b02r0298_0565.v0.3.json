{
  "base_language": "SC",
  "defaults": {
    "status": "translated"
  },
  "distribution_policy": {
    "contains_commercial_source_text": false,
    "contains_complete_game_resource": false
  },
  "entries": [
    {
      "block_id": 2,
      "ko": "성을 지키지 못하다니 불찰이다!\n이제 적병에게 한 방 먹여 주겠다!",
      "literal_id": 0,
      "record_id": 298,
      "source_sc_utf16le_sha256": "DFC9D1B0793DD78C19B9AFD7FC26BEE6D5FE74951D0B226E8B9074F0174BC7DF"
    },
    {
      "block_id": 2,
      "ko": "적의 모략을 막을 자:",
      "literal_id": 0,
      "record_id": 300,
      "source_sc_utf16le_sha256": "DE8909FC33CE98E773ED9C68680A7018D1287A657807CD19935305DAEB2833E1"
    },
    {
      "block_id": 2,
      "ko": "한조",
      "literal_id": 1,
      "record_id": 300,
      "source_sc_utf16le_sha256": "1C260BD6E54395B1802CF2500C55B74E55B412CE2B47646878DEC9F00964B494"
    },
    {
      "block_id": 2,
      "ko": "\n모두 막아 내니 걱정할 것 없다……",
      "literal_id": 2,
      "record_id": 300,
      "source_sc_utf16le_sha256": "A8004CDC4F09A1D47D7EB99C346B57E23B7ED671504F652D1BFDE1DAE42DAB2A"
    },
    {
      "block_id": 2,
      "ko": "모두 활을 거두라!\n적대 대상:",
      "literal_id": 0,
      "record_id": 310,
      "source_sc_utf16le_sha256": "30D123638D46231EE6C7DA39D40736D0C24A8B0A2E545953688D655065219CD0"
    },
    {
      "block_id": 2,
      "ko": "의 적은 곧 모든 무사의 적이다!",
      "literal_id": 1,
      "record_id": 310,
      "source_sc_utf16le_sha256": "4D360D2FAFEC6BB549EA1D9EA78A02AB15ED88F2696E82D59D8B73DD7CA3404C"
    },
    {
      "block_id": 2,
      "ko": "공격자:",
      "literal_id": 0,
      "record_id": 314,
      "source_sc_utf16le_sha256": "B58A3E1A85EE12811D0516081FB2005420CD0E10DD040381C2016535DC658AF6"
    },
    {
      "block_id": 2,
      "ko": "\n창에 맞은 자:",
      "literal_id": 1,
      "record_id": 314,
      "source_sc_utf16le_sha256": "34C401CCF90DCD5C3A49362DACD1DAD78CD853E8935467CFC9A8F1502A368FD4"
    },
    {
      "block_id": 2,
      "ko": "!",
      "literal_id": 2,
      "record_id": 314,
      "source_sc_utf16le_sha256": "4B3A43F592F577FCFCB5B0E1F42BEC5182C9EDC414E1F667528F56E7CF0BE11D"
    },
    {
      "block_id": 2,
      "ko": "주군을 돕는 것이 진정한 부장의 임무다.\n이곳은 담당자:",
      "literal_id": 0,
      "record_id": 315,
      "source_sc_utf16le_sha256": "8E70C8F1C0B86E8AB185D7810075624E20B41BA5C84516EE2509D1AEE437B871"
    },
    {
      "block_id": 2,
      "ko": "에게 맡겨라!",
      "literal_id": 1,
      "record_id": 315,
      "source_sc_utf16le_sha256": "81B71A6B5420A29B9B2B5DC2D11A12EB581EB95807008C3631A825105CCAF684"
    },
    {
      "block_id": 2,
      "ko": "내가 바로 미노의 야차다!\n이런 공세쯤은 아무것도 아니다!",
      "literal_id": 0,
      "record_id": 319,
      "source_sc_utf16le_sha256": "4DB4EEA3928BD7CD42A1880DFDA38E9D0C1E9C197AB53B32D0885C640052F8CA"
    },
    {
      "block_id": 2,
      "ko": "담당자:",
      "literal_id": 0,
      "record_id": 320,
      "source_sc_utf16le_sha256": "B58A3E1A85EE12811D0516081FB2005420CD0E10DD040381C2016535DC658AF6"
    },
    {
      "block_id": 2,
      "ko": "은(는) 농사에 제법 일가견이 있다!\n내 지식으로 이 영지를 풍요롭게 하겠다.",
      "literal_id": 1,
      "record_id": 320,
      "source_sc_utf16le_sha256": "63D41FF14F36E3225FD35589C090F451951BFC8832078034A2671AE194384848"
    },
    {
      "block_id": 2,
      "ko": "명인이라 불리는 건축 솜씨를\n마음껏 발휘하겠다!\n반드시 훌륭한 성하마을을 세우겠다.",
      "literal_id": 0,
      "record_id": 321,
      "source_sc_utf16le_sha256": "4B50128C65F20758F323545479FD414872C508D474123E5CFD6B3E3F540BFE67"
    },
    {
      "block_id": 2,
      "ko": "건축의 명인이라 불리는 내가\n보좌할 대상:",
      "literal_id": 0,
      "record_id": 322,
      "source_sc_utf16le_sha256": "E77F4452E8F52B958569C9A5069853D167915C66C4C9F55A8221578AB31CA342"
    },
    {
      "block_id": 2,
      "ko": "을(를) 도와주겠다!\n반드시 훌륭한 성하마을을 세우겠다.",
      "literal_id": 1,
      "record_id": 322,
      "source_sc_utf16le_sha256": "5416A9F13741BC9E9E2EF14594BA7105FA488C20DAEFAA836C5131886FAF9673"
    },
    {
      "block_id": 2,
      "ko": "모두, 일제히 겨눠라!\n",
      "literal_id": 0,
      "record_id": 324,
      "source_sc_utf16le_sha256": "897A3D9AE2B3BADC3441134493E76EEEEA8DC76A63E9993F9E3DEF2E6365C12F"
    },
    {
      "block_id": 2,
      "ko": "사이카",
      "literal_id": 1,
      "record_id": 324,
      "source_sc_utf16le_sha256": "CC0ABA87F8ACD961082629E3063A2054F6FB4FC6070A502B6E70680E3BD102B7"
    },
    {
      "block_id": 2,
      "ko": "의 철포는 무엇이든 꿰뚫는다!",
      "literal_id": 2,
      "record_id": 324,
      "source_sc_utf16le_sha256": "D27D7CB879C0B5C9E1F6E6D232DE1524981140A77E62A4CCEDA944D5C2CD50F9"
    },
    {
      "block_id": 2,
      "ko": "계략이라면 내게 맡겨라!\n당장 첩자를 보내 지휘하여,\n반드시 이 계책을 성공시키겠다.",
      "literal_id": 0,
      "record_id": 325,
      "source_sc_utf16le_sha256": "BDBB8D1CE6C567E7D8BCD05589BE6C158372F2290D97B28965BF4ED06D878B50"
    },
    {
      "block_id": 2,
      "ko": "계략이라면 내게 맡겨라!\n반드시",
      "literal_id": 0,
      "record_id": 326,
      "source_sc_utf16le_sha256": "8B71AAEF99A740D54C72857119F2D79E76BDF58B4CC761ADAA7380C7D43D8B01"
    },
    {
      "block_id": 2,
      "ko": "의 계책을 성공시키겠다.",
      "literal_id": 1,
      "record_id": 326,
      "source_sc_utf16le_sha256": "5D329EB4B73DA4CA217C651D6F1B7DE90F203E14073F796044C3AA38B0357B85"
    },
    {
      "block_id": 2,
      "ko": "누군가 이곳에서 계략을 꾸민다면,\n내가 반드시 막아 내겠다.",
      "literal_id": 0,
      "record_id": 327,
      "source_sc_utf16le_sha256": "FC9D8459F9CFE139D5F0F8CB058C2D2FEEC0425A87E61F02348437C4E302CAFF"
    },
    {
      "block_id": 2,
      "ko": "누군가 이곳에서 계략을 꾸민다면,\n내가 반드시 막아 내겠다.",
      "literal_id": 0,
      "record_id": 328,
      "source_sc_utf16le_sha256": "FC9D8459F9CFE139D5F0F8CB058C2D2FEEC0425A87E61F02348437C4E302CAFF"
    },
    {
      "block_id": 2,
      "ko": "적성을 제압했다!\n이 승전보를 천하에 퍼뜨려,\n천하의 부왕이 지닌 위세를 보여라!",
      "literal_id": 0,
      "record_id": 329,
      "source_sc_utf16le_sha256": "7D11DB3F8B8E0BDE6E6032865C0E184ED2D07EAE2E212E557F9BE829FF771296"
    },
    {
      "block_id": 2,
      "ko": "주군도 무척 든든하시겠지……\n뜻을 함께할 자:",
      "literal_id": 0,
      "record_id": 330,
      "source_sc_utf16le_sha256": "EBF2558ECB9D0AD4D896F15517C7182474A2FD6EFADCDC0F45EE0E3D6BDC71A6"
    },
    {
      "block_id": 2,
      "ko": "이(가) 있으니!",
      "literal_id": 1,
      "record_id": 330,
      "source_sc_utf16le_sha256": "8148BA16AEDD35D7F68C6A496C036D432BA8F94D5C4077D1A4F33755A9133219"
    },
    {
      "block_id": 2,
      "ko": "정찰 담당:",
      "literal_id": 0,
      "record_id": 331,
      "source_sc_utf16le_sha256": "17FD536141E7C94F15D29FC9F9FEC2919AA96AC571DCCFE253A8C6E658C4088E"
    },
    {
      "block_id": 2,
      "ko": "\n협공을 눈치채지 못할 줄 알았나?",
      "literal_id": 1,
      "record_id": 331,
      "source_sc_utf16le_sha256": "1ECEF69C645077F8656E85C15446F516D7D0792331E0ED3A75696EC84217775F"
    },
    {
      "block_id": 2,
      "ko": "천하에 보여 줄 때가 왔다!\n",
      "literal_id": 0,
      "record_id": 332,
      "source_sc_utf16le_sha256": "6E41177B93F96F7D56EF684D40A17BB21F568A032F9A65C9AD2BFDBB16DF4F9E"
    },
    {
      "block_id": 2,
      "ko": "이(가) 자랑하는 기마대의 위력을!",
      "literal_id": 1,
      "record_id": 332,
      "source_sc_utf16le_sha256": "C23736647EA2521DEFB9E1A8CB0884DC3B857EC3710EDDB9655E48085EBF7815"
    },
    {
      "block_id": 2,
      "ko": "이 성을 죽을 자리로 삼았다!\n목숨을 걸고 끝까지 지키겠다!",
      "literal_id": 0,
      "record_id": 333,
      "source_sc_utf16le_sha256": "10F1A08C4DCB1E72B581CE719C3D1F0128E917DB43E6A9C574EF4F96D58F07FE"
    },
    {
      "block_id": 2,
      "ko": "신뢰를 얻는 것이 처세의 길.\n분쟁이 끊이지 않는 세상이기에\n",
      "literal_id": 0,
      "record_id": 334,
      "source_sc_utf16le_sha256": "DABBE5AB21AB1F67C1D33E0D42AEB7A399C33BF192CD1D23664258EEF2862B9C"
    },
    {
      "block_id": 2,
      "ko": "은(는) 인연을 무엇보다 중히 여긴다!",
      "literal_id": 1,
      "record_id": 334,
      "source_sc_utf16le_sha256": "C9B840AEE51CFFA824F45E1335F35745783BC2CE120F95251917F20897399CC7"
    },
    {
      "block_id": 2,
      "ko": "고금의 학문을 집대성한 문재와,\n온갖 무예를 익힌 무재를,\n이곳에서 펼쳐 보이겠다.",
      "literal_id": 0,
      "record_id": 338,
      "source_sc_utf16le_sha256": "AF20394D8207F1C7106BB27CF169FDC80C717BAF780039849A5D4D8775D39B82"
    },
    {
      "block_id": 2,
      "ko": "용기병이여, 날아올라라!\n천하를 향해 마음껏 달려라!",
      "literal_id": 0,
      "record_id": 339,
      "source_sc_utf16le_sha256": "1C3FFDBE65398B31B3AE345FAF435C34D34BAFDD98E4582EC500651F3218A660"
    },
    {
      "block_id": 2,
      "ko": "모든 일을 내게 맡겨 주십시오.\n오른눈이 될 자:",
      "literal_id": 0,
      "record_id": 341,
      "source_sc_utf16le_sha256": "4EF6656AAA1467E1E8F64571307CC44F2E8B502A6C4CC61A354E5A91CC940325"
    },
    {
      "block_id": 2,
      "ko": "이(가) 주군의 오른눈이 되겠습니다!",
      "literal_id": 1,
      "record_id": 341,
      "source_sc_utf16le_sha256": "78551978A8EC9615C5FC6DE657B49B73D87FC6B3AA0ABEA09663AA77F9B8CA6D"
    },
    {
      "block_id": 2,
      "ko": "내가 만민을 위하면 만민도 나를 위한다.\n이것이 영지를 풍요롭게 하는 비결이다……",
      "literal_id": 0,
      "record_id": 342,
      "source_sc_utf16le_sha256": "C29FB8F9D575B133E655B961E2ADC953B2E8A7DEDF96A746C2A919BCE84DADD5"
    },
    {
      "block_id": 2,
      "ko": "타로타치여, 나의 벗이여!\n이 역경을 이겨 낼 힘을 다오!",
      "literal_id": 0,
      "record_id": 350,
      "source_sc_utf16le_sha256": "435EF1E950476C39912F965C9FF2B3B107DBD4CB4A0D076F26F285094D399399"
    },
    {
      "block_id": 2,
      "ko": "용기병이여, 날아올라라!\n천하를 향해 마음껏 달려라!",
      "literal_id": 0,
      "record_id": 353,
      "source_sc_utf16le_sha256": "1C3FFDBE65398B31B3AE345FAF435C34D34BAFDD98E4582EC500651F3218A660"
    },
    {
      "block_id": 2,
      "ko": "절대 꺾이지 않는다!\n절대 포기하지 않는다!",
      "literal_id": 0,
      "record_id": 408,
      "source_sc_utf16le_sha256": "DED4A064D46D50708AA569C1A4FA3215B16CD09BB868BE2649CC74EF5BFA6E36"
    },
    {
      "block_id": 2,
      "ko": "지금이 승부처다!\n모두, 절대 포기하지 마라!",
      "literal_id": 0,
      "record_id": 409,
      "source_sc_utf16le_sha256": "D157D2A9C98A19D47550CB6E335AA9BD88493521ED2852567C29AB9EEEC947EC"
    },
    {
      "block_id": 2,
      "ko": "자, 자! 내가 바로 미나모토노 쿠로 요시쓰네다!\n재주 있는 자여, 한판 겨뤄 보자!",
      "literal_id": 0,
      "record_id": 410,
      "source_sc_utf16le_sha256": "6EE97CCA72959D89C06149B7C749614667A08864FE0DF0815EFEF6405D24F951"
    },
    {
      "block_id": 2,
      "ko": "상대는",
      "literal_id": 0,
      "record_id": 411,
      "source_sc_utf16le_sha256": "1B18CF7ACF96307A4244496BD40D01127A16F49BC71410450CA6DCEC04615CF1"
    },
    {
      "block_id": 2,
      "ko": "!\n한판 겨뤄 보자!",
      "literal_id": 1,
      "record_id": 411,
      "source_sc_utf16le_sha256": "9BFDAA44FDD6ACB136B962C19BE22412B66649817C5ADC40E582E5D71DC60E80"
    },
    {
      "block_id": 2,
      "ko": "지금이 성을 공격할 때다!\n정예병으로 단숨에 제압하겠다!",
      "literal_id": 0,
      "record_id": 412,
      "source_sc_utf16le_sha256": "2B47B237218AF19A8F1487A2B494F63965D96056D81841A95C57AAB8DE11EDB2"
    },
    {
      "block_id": 2,
      "ko": "지금이 성을 공격할 절호의 기회다!\n단숨에 섬멸하자!",
      "literal_id": 0,
      "record_id": 413,
      "source_sc_utf16le_sha256": "0C45A38B046F00ADFE9DCF97C144C2BFA3F3963BD6CF0AE75CFCB5A5CAA9D4F8"
    },
    {
      "block_id": 2,
      "ko": "하늘이여, 지켜보라!\n백성을 위해 이 몸을 바치겠다!",
      "literal_id": 0,
      "record_id": 414,
      "source_sc_utf16le_sha256": "3086E7A31F08C61D7F3363957747A4DDFB49DC7C805ADCB5AA5B89545BFFD426"
    },
    {
      "block_id": 2,
      "ko": "하늘이여, 지켜보라!\n이 목숨을 백성에게 바치겠다!",
      "literal_id": 0,
      "record_id": 415,
      "source_sc_utf16le_sha256": "B54B52D6EB1AD964B0A0B41B72795A1215D80953D1C14B50F6813F868F416240"
    },
    {
      "block_id": 2,
      "ko": "사나운 적에게는 매처럼 덮쳐라!\n이것이 용병의 극의다!",
      "literal_id": 0,
      "record_id": 416,
      "source_sc_utf16le_sha256": "E7E9BFE54C6314AF8CDD84A61CB2DFBD29B72D1949DC49901A4A85AED97BB1B8"
    },
    {
      "block_id": 2,
      "ko": "사나운 적에게는 매처럼 덮쳐라!\n이것이 바로 용병의 극의다!",
      "literal_id": 0,
      "record_id": 417,
      "source_sc_utf16le_sha256": "5D5DC6BD20CFEFC39322CDC9C395D5DA53075577303B090EA5801835C89A757A"
    },
    {
      "block_id": 2,
      "ko": "천연이심류의 검술을,\n여기서 조금 보여 주마!",
      "literal_id": 0,
      "record_id": 418,
      "source_sc_utf16le_sha256": "3910B6CD3F89924BA509E2721EB20F710D19D782893F1BEFF0F0B7F240C5626E"
    },
    {
      "block_id": 2,
      "ko": "내 검술의 한 자락을\n여기서 보여 주마!",
      "literal_id": 0,
      "record_id": 419,
      "source_sc_utf16le_sha256": "B002A4845D98E127ADB51FA662857FD639666E6B02381A18EE1AA851945BB812"
    },
    {
      "block_id": 2,
      "ko": "내 야망의 막이 이제 오른다.\n전국에 새바람을 일으킬 자:",
      "literal_id": 0,
      "record_id": 434,
      "source_sc_utf16le_sha256": "DF4169FDFE06B07F8E083653CA3BAA2D03B5794624F639C72CB00D8391A06E61"
    },
    {
      "block_id": 2,
      "ko": "이(가) 바로 나다!",
      "literal_id": 1,
      "record_id": 434,
      "source_sc_utf16le_sha256": "8E606F544F0E02B6CC820CC94EA82CEBF2B0F4FEAA3998643688CBE86B57C925"
    },
    {
      "block_id": 2,
      "ko": "미하타와 다테나시의 가호 아래!\n천하에 떨칠 가문:",
      "literal_id": 0,
      "record_id": 435,
      "source_sc_utf16le_sha256": "2CF12EF4296CF9D81643EEA67E5837C21F2DE6927EC636E2E51715A2249011CE"
    },
    {
      "block_id": 2,
      "ko": "의 위세를 보여 주자!",
      "literal_id": 1,
      "record_id": 435,
      "source_sc_utf16le_sha256": "4AD205DBB661E0FEE19EB26667DD6800C080D7C804AED57D64F9FFC5CB012257"
    },
    {
      "block_id": 2,
      "ko": "적의 총대장을 찾았다!\n비사문천이여, 우리에게 힘을 주소서!",
      "literal_id": 0,
      "record_id": 436,
      "source_sc_utf16le_sha256": "13D2FB42B783694FB2C5C907CCBE869B3E0D8F3EAF1F14C1DA1A80B087EED72E"
    },
    {
      "block_id": 2,
      "ko": "이 목숨은 아깝지 않다……\n노리는 것은 오직 적의 총대장뿐!",
      "literal_id": 0,
      "record_id": 437,
      "source_sc_utf16le_sha256": "14136715355D850A49F14B18A5EFE3D81D66E7559B43EC500AC2E8256A4688A6"
    },
    {
      "block_id": 2,
      "ko": "똑똑히 보아라……\n독안룡이 하늘로 오르는 모습을!",
      "literal_id": 0,
      "record_id": 438,
      "source_sc_utf16le_sha256": "E3EC5C8E3CB907FC12354B96412C2C8BC03DD91692F5860D69CFA30609A11974"
    },
    {
      "block_id": 2,
      "ko": "남편을 돕는 것이 아내의 도리!\n적이라면 아버지라도 용서하지 않겠다!",
      "literal_id": 0,
      "record_id": 439,
      "source_sc_utf16le_sha256": "DE85955114A20EEA0C422C93433262B24BC035D5B4C36665F67EDD5A8C0150A1"
    },
    {
      "block_id": 2,
      "ko": "내가 당주가 된 이상,\n이 전국에 새바람을 일으키겠다!",
      "literal_id": 0,
      "record_id": 440,
      "source_sc_utf16le_sha256": "2C721375838B242DA3C980AEB43EF0969DE7C00750547B01CC09745DADE8F8FB"
    },
    {
      "block_id": 2,
      "ko": "내가 바로 새 당주다!\n모두 내게 충성을 다하라!",
