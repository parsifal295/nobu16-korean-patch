      "source_sc_utf16le_sha256": "9400D8336D4F8E5963BDDEB69D05763147171BB72FADA61C4A3D74A80A520E06"
    },
    {
      "block_id": 2,
      "ko": "적의 총대장을 찾았다!\n모두 나를 따르라!",
      "literal_id": 0,
