      "source_sc_utf16le_sha256": "E7343E0DCF23BF8A7CEC48090A9D9FB41EC587E51514413E30C8E4FCB24AC433"
    },
    {
      "id": 17964,
      "ko": "도고니",
      "source_sc_utf16le_sha256": "991EFC399344C5287358A1141CDD1069EE4EBC36B33B60353CE54A5F54B03F2E"
    },
    {
      "id": 17965,
      "ko": "도고산",
      "source_sc_utf16le_sha256": "C97EEB1A7D9501F67BE8F792048AB3E6085CFB3042F1638C244B00E147FC23B2"
    },
    {
      "id": 17966,
      "ko": "쇼엔이치",
      "source_sc_utf16le_sha256": "DD116009DC7E83D179B22857F6943C7CD71E9B245E3ABE4F0B7A34C12DF1CFEA"
    },
    {
      "id": 17967,
      "ko": "쇼엔니",
      "source_sc_utf16le_sha256": "74C2CDE1A943BA67818DBCC0B32E361943220638FE1B547B00DFAB904C7713C2"
    },
    {
      "id": 17968,
      "ko": "쇼엔산",
      "source_sc_utf16le_sha256": "8AE6CCADAD92E373D7F3DD82B41F8E3C9A34E0C4E137154C91B5DEEDEF5B19A9"
    },
    {
      "id": 17969,
      "ko": "대호족일",
      "source_sc_utf16le_sha256": "CDF9C5EB88426F1E2DD10C0C6373823CBEE790713D90809A88AA35683D60D239"
    },
    {
      "id": 17970,
      "ko": "대호족이",
      "source_sc_utf16le_sha256": "AAB2A898CD1C2D6AC56B40B0D5F2DC759ED20F1764F0CFCD2256787B935965C1"
    },
    {
      "id": 17971,
      "ko": "대호족삼",
      "source_sc_utf16le_sha256": "C10061DD7851BCCAAA34BE4B53F824C02D9B660CF57070B7D150A480B01B33B4"
    },
    {
      "id": 17972,
      "ko": "소손이치",
      "source_sc_utf16le_sha256": "7AF28909FB2F1E2FBAE64DFF6EDE7198096220CFC61719CEF1468F82046F343B"
    },
    {
      "id": 17973,
      "ko": "소손니",
      "source_sc_utf16le_sha256": "9025E57C2BE188AD1BC48B8AC5E4FDBD974D280A2C74B21A450903A3C8867BC4"
    },
    {
      "id": 17974,
      "ko": "소손산",
      "source_sc_utf16le_sha256": "1EC249A6290D83F0277F8BA364B0FEDD63A3A22FBAB1ECEC6A9CDA9E8B2EE7AD"
    },
    {
      "id": 17975,
      "ko": "묘슈이치",
      "source_sc_utf16le_sha256": "E772D9264E4CC4FB8806AEDBD0C17670DD9AA265F269647558ED8DE8093F4F59"
    },
    {
      "id": 17976,
      "ko": "묘슈니",
      "source_sc_utf16le_sha256": "5676A8AD2ED0528E1F4DF3DB65D899006F45EE54CF52A4E21AA8E92462EAEC59"
    },
    {
      "id": 17977,
      "ko": "묘슈산",
      "source_sc_utf16le_sha256": "BEE18EFFE1DA15CF6831695DDDB75A8C3E1991CF6084576AB55376159E289CD6"
    },
    {
      "id": 17978,
      "ko": "쇼야이치",
      "source_sc_utf16le_sha256": "3832ECDA42C6B51282F50847D4F74C87F875FD1AF33DB23153A44207B76DF329"
    },
    {
      "id": 17979,
      "ko": "쇼야니",
      "source_sc_utf16le_sha256": "8CA233EC7861F706F5745C0239FA07C3BD6F5C7D8B8DC77AAFA6ACBE509BB8AC"
    },
    {
      "id": 17980,
      "ko": "쇼야산",
      "source_sc_utf16le_sha256": "BF956F6F888A75225EBA401AC8FFBEBAC1095179D29A95133FFD0178EEEFD384"
    },
    {
      "id": 17986,
      "ko": "정면으로 맞서는 적 따위 있을 리 만무하다.",
      "source_sc_utf16le_sha256": "21D66533770C3AA956CCAB0BFF6C2DF2978FC89811838633CE9FB5CDDE67B101"
    },
    {
      "id": 17987,
      "ko": "이마가와군 선봉대는 잇달아 성을 함락시켰다.",
      "source_sc_utf16le_sha256": "FBD8430A3467FF7E6BF40833BFCF2BBD185432A99C4A24C876C0559D20262D10"
    },
    {
      "id": 17992,
      "ko": "거센 비는 온갖 소리를 지워 없애고,",
      "source_sc_utf16le_sha256": "6B46C5C5297A4F0E298BDA9DFDAD5E7637A0F2356A0D36E6A7D4CED727FBAD65"
    },
    {
      "id": 17994,
      "ko": "더위를 쫓는 한 잔을 다 들이켠 요시모토는",
      "source_sc_utf16le_sha256": "031FA33D2171E38B826439DAEF2E640084707AFAD9B73EEE9C4E4DB524B954AD"
    },
    {
      "id": 18001,
      "ko": "자신이 베였다는 것조차 알지 못했을지도 모른다.",
      "source_sc_utf16le_sha256": "A6505134F23D5A49441049041E9A602598A25E033DF6AA0614E98FADB67D9500"
    },
    {
      "id": 18038,
      "ko": "노부나가의 유해는 끝내 발견되지 않았다.",
      "source_sc_utf16le_sha256": "537C8CDB271C9F8D61CF3CD1719D0F2A9E0B5FB1C813EF6C7380C567A42B6BC1"
    },
    {
      "id": 18039,
      "ko": "귀에 들러붙어 사라지지 않는, 죽은 주군의 너털웃음…",
      "source_sc_utf16le_sha256": "9B4683F7B2527D3CD51569218279DE1DF4AAE7F6961276BA351574A6EE81354C"
    },
    {
      "id": 18040,
      "ko": "자신의 속마음을 꿰뚫어 본 듯한 그 목소리는",
      "source_sc_utf16le_sha256": "5B2B51C152B5456195EFAC5720EB5E9C657CA6BE963A8DD285044A5E60C6969A"
    },
    {
      "id": 18047,
      "ko": "잘하면 「멍청이」라 소문난 노부나가를\n그 칼로 처단하라는\n뜻도 담은 것이었다.",
      "source_sc_utf16le_sha256": "6D9AD456CFF478F43BA29D06AE1902807F8D75090D3317E828010684390584C9"
    },
    {
      "id": 18051,
      "ko": "남편이 될 그 남성을\n한번 보고 충격을 받는다.",
      "source_sc_utf16le_sha256": "7974C2A9292657B64B83A5D6DA2DA084B3E0FB209447C508DE5BE02317B9E055"
    },
    {
      "id": 18055,
      "ko": "그 곁에서 지켜보고 싶다는 충동을 억누를 수 없게 되었다.",
      "source_sc_utf16le_sha256": "4A37F44218C3B2FAEA25A8BC3B79E3F3B30ED8092B886B2BE7FE07AF4F738FC8"
    },
    {
      "id": 18057,
      "ko": "천하로 웅비해 나아가는 노부나가의 최대 이해자가 된다.",
      "source_sc_utf16le_sha256": "8CC0210A79045A900F0AB61F3B1CB22C2B7A2901A42730F0CC090F48466F7D16"
    },
    {
      "id": 18062,
      "ko": "도쿠가와로 이반한 오쿠다이라 가문에\n본보기로 따끔하게 벌해야 한다.",
      "source_sc_utf16le_sha256": "107C95011A903CB3D17CE2251B0B42E9F92B00A95BC797E45E7E31EA046EA945"
    },
    {
      "id": 18063,
      "ko": "그렇지 않으면 다른 호족들까지 다케다를 저버리고 말 것이다.",
      "source_sc_utf16le_sha256": "0F8FDAFCA70FD85EFFEFC03A889D50078B9A097EA2FC110486FDEAF15E6B5D12"
    },
    {
      "id": 18068,
      "ko": "설욕을 기하는 이에야스는\n나가시노 구원을 위해 맹우의 내원을 청한다.",
      "source_sc_utf16le_sha256": "6651AA5A58C67DB7EFBDFF62D503578519FCDD403F60EA0458ABEEEC558F115D"
    },
    {
      "id": 18076,
      "ko": "다케다군 앞에 나타난 그것은 마치 성과도 같은 견고한 보루였다.",
      "source_sc_utf16le_sha256": "028B0EFB15A39532B60FC68490CFAAA8D8A4B55E3718C08827A96B57669C09BD"
    },
    {
      "id": 18089,
      "ko": "\n다케다군은 별동대를\n우에스기 세력이 농성하는 사이조산에 파견한다.",
      "source_sc_utf16le_sha256": "1F69E4964BBEEE7AA1353F6CBD2D0C80675BD4CD01A02470D94029477E724ACE"
    },
    {
      "id": 18091,
      "ko": "…\n이름하여 「딱따구리 전법」",
      "source_sc_utf16le_sha256": "BF9EABA6ED70F8586075953D854F188421D3E0210DEC72850DA0752FF4B734B5"
    },
    {
      "id": 18093,
      "ko": "그렇다면 딱따구리가 실패했는가…\n초조해하는 신겐의 눈에",
      "source_sc_utf16le_sha256": "1D23D65FCB47E6072D799ABB1B57FA0585DB6505B050E47D6796E74BF3BB542C"
    },
    {
      "id": 18096,
      "ko": "한편 마사토라는 한밤중에 적의 우회를 간파하고 있었다.",
      "source_sc_utf16le_sha256": "E616E71354A6C92247399D03FE98186B7D98A2FDF1C45F74D2804BB90C705D3F"
    },
    {
      "id": 18102,
      "ko": "\n호위의 창 울타리를 헤치고\n마사토라는 말 위에서 태도를 내리친다.",
      "source_sc_utf16le_sha256": "DBD87603FB50B483A5ECC1DEF3FECC843A0EA8C3A2151ACD9A5A98FB9251FFF6"
    },
    {
      "id": 19643,
      "ko": "호족을 자세력에 포섭한다",
      "source_sc_utf16le_sha256": "9151FEA58A3E838A2000CCBF0B2C92DAA64772EEBFA4C7BE597C60A075359F31"
    },
    {
      "id": 19660,
      "ko": "무장의\n충성을 낮춤",
      "source_sc_utf16le_sha256": "49F00962F16AC7D9EED317189AF18912D96327569346BA1656182BA3F72692E1"
    },
    {
      "id": 20936,
      "ko": "적 병력이 크게 감소 / 적에게 혼란 부여",
      "source_sc_utf16le_sha256": "A4B94ECEE27984429F94555B229F70109D3AC29F2197A412227C708D156E2763"
    },
    {
      "id": 20953,
      "ko": "아군 강제 이동 / 병력 감소",
      "source_sc_utf16le_sha256": "903DEC10DD9BB298640E45B5D4C17F026D919E21E849A257F91CD873F745DDDC"
    },
    {
      "id": 20957,
      "ko": "복수 경로 봉쇄 / 적 병력 감소",
      "source_sc_utf16le_sha256": "94B567B4533ACD899BB6B10694EA6021438923DBD81C30B785F98C5DC462CE5D"
    },
    {
      "id": 21036,
      "ko": "적 병력이 크게 감소 / 적에게 혼란 부여",
      "source_sc_utf16le_sha256": "A4B94ECEE27984429F94555B229F70109D3AC29F2197A412227C708D156E2763"
    },
    {
      "id": 21053,
      "ko": "아군 강제 이동 / 병력 피해",
      "source_sc_utf16le_sha256": "BB012405A237E4AD19392B834A8171784F269ABFF6F9CDAE9C3D6FAEA6725657"
    },
    {
      "id": 21057,
      "ko": "복수 경로 봉쇄 / 병력 피해",
      "source_sc_utf16le_sha256": "5A01541FF84B6944BD8F8A30AAA5339F1E8741400F4108192171AE1C703F8659"
    },
    {
      "id": 22503,
      "ko": "남만 상인과의 최대 거래량%+d％",
      "source_sc_utf16le_sha256": "7BAED3E2E955D12AAB4DA48A7ABF444692E6A3A32DAA9456FA5CC85CA02631A2"
    },
    {
      "id": 22510,
      "ko": "거점이 있는 군의 병력 %+d％",
      "source_sc_utf16le_sha256": "B5B4F7D03D58705FE03F8859B31E9B722B4BF9FB19A1115B3EAD908C031FB35A"
    },
    {
      "id": 22511,
      "ko": "거점이 없는 군의 병력 %+d％",
      "source_sc_utf16le_sha256": "094DADD99C9CFBD43DB8F4359457C914914228208DB3739FF89CF84C293796FE"
    },
    {
      "id": 22513,
      "ko": "군의 지배율 상승 속도%+d％",
      "source_sc_utf16le_sha256": "FF746170089430464580C4BEA7AF74C52B22FD463498F2635C5063E87D5F5C9D"
    },
    {
      "id": 22514,
      "ko": "군 점령 시의 초기 지배율%+d",
      "source_sc_utf16le_sha256": "E6DA00DA9B559D6479C87FEFCDAAF6A2483DB77B4705DC929B2818E6BC18F884"
    },
    {
      "id": 22517,
      "ko": "군의 상태 이상 회복 효율%+d％",
      "source_sc_utf16le_sha256": "8476C167431B4B76CFE5BED597495E420A54CF49328A699D7349284DAA541043"
    },
    {
      "id": 22526,
      "ko": "호족 종속도 증가량 %+d％",
      "source_sc_utf16le_sha256": "ED2AA1E91BD838593DAE75AF3DF14E1C1AC69CEC4B6B5470311D0DC615758F41"
    },
    {
      "id": 22531,
      "ko": "군이 임전 상태로 이행하는 데 걸리는 일수%+d",
      "source_sc_utf16le_sha256": "07873B8DA0A0FD3B15D2DF00028063ADAA495A2E68532496A431B805518B9883"
    },
    {
      "id": 22536,
      "ko": "금산정, 은산정의 금전 수입%+d％",
      "source_sc_utf16le_sha256": "2B21489CC0E812CE947AAF8D84916C481553BB3844C00D39284D3C9EBA76A9E0"
    },
    {
      "id": 22537,
      "ko": "휘하 무장의 지휘 가능 병력+%d",
      "source_sc_utf16le_sha256": "BAB6D13C458B984ED09275DC909460A758B52FD4380B21205A1FF2A90DB7C4AD"
    },
    {
      "id": 22546,
      "ko": "대장간정의 효과량%+d％",
      "source_sc_utf16le_sha256": "B6369A657B228C25A5E83DBD2EABBA48F141202C5A9A080AE8F49767E0583626"
    },
    {
      "id": 22555,
      "ko": "철포 공격 발생률%+d％",
      "source_sc_utf16le_sha256": "E50816B13D71C016ED71BD34DB9254A0F6D09695E7F79EC2A9A2C46619799602"
    },
    {
      "id": 22558,
      "ko": "주의가 중도인 무장의 충성%+d",
      "source_sc_utf16le_sha256": "1DB3CEB929B3B8BD74A7452AF33244116D6BCD35FE4B91D780F9934B2DF0B444"
    },
    {
      "id": 22617,
      "ko": "성하시설\u001bC3%s\u001bCZ·\u001bC3%s\u001bCZ의 비용%+d",
      "source_sc_utf16le_sha256": "74ADCE82A7D4CE5D3A0D0C3C22611A734D47A2C6DC73ADFDDC9EC9F7E10EAED2"
    },
    {
      "id": 23988,
      "ko": "특수 영향력+%d 상업+%d",
      "source_sc_utf16le_sha256": "912369129A7F357A0746FFE6F0FFAA06EF8F12413FD9DA7A49FFB952E226F0D0"
    },
    {
      "id": 23990,
      "ko": "병력 회복+%d％",
      "source_sc_utf16le_sha256": "0490E4F36F5B4C3A638EB790223F31A9D640F6B20F61E3C493C33FD9249B2A1B"
    },
    {
      "id": 23992,
      "ko": "제압 시간+%d％ 반격 발생 시 데미지가 발생",
      "source_sc_utf16le_sha256": "2063076550174900873B237FCAABDC9898913CE955327CB4CA1BF0504AF44137"
    },
    {
      "id": 23995,
      "ko": "영주의 획득 훈공 +%d％",
      "source_sc_utf16le_sha256": "B433986C23A439EC2BEC98F95C34C521B6AD25C667675E262F268E0CB72AEF8A"
    },
    {
      "id": 24378,
      "ko": "·외교에서 매우 약한 입장으로 몰린다\n·매우 규모가 작은 정책만 채택할 수 있다\n·효과가 강한 성하 시설은 조성할 수 없다",
      "source_sc_utf16le_sha256": "E8DEFA30C187E5FA9C840978832871626CB0E640B965620A5EB88A86674F2C53"
    },
    {
      "id": 24379,
      "ko": "·외교에서 약한 입장으로 몰린다\n·규모가 작은 정책만 채택할 수 있다\n·효과가 강한 성하 시설은 조성할 수 없다",
      "source_sc_utf16le_sha256": "ED737E412B0A3264369331E6C68695D7EA84E6D8B28ACD258D4E3E49AB9E4AB9"
    },
    {
      "id": 24380,
      "ko": "·외교에서 다소 약한 입장으로 몰린다\n·규모가 다소 작은 정책만 채택할 수 있다\n·효과가 강한 성하 시설은 조성할 수 없다",
      "source_sc_utf16le_sha256": "5ECC3FBCE19AE8CE674A36A3F3463DAA6058C72C0E608BE5BCEDBC21CD84E006"
    },
    {
      "id": 24381,
      "ko": "·외교에서 표준적인 입장으로 교섭할 수 있다\n·통상 규모의 정책을 채택할 수 있다\n·효과가 강한 성하 시설은 조성할 수 없다",
      "source_sc_utf16le_sha256": "B4B5CD3323F8EA6A80BE1C24983DB7F3C03D91E1052058A1B1063DB402715EC4"
    },
    {
      "id": 24382,
      "ko": "·일부 다이묘가 공격해 들어오기를 주저한다\n·외교에서 다소 강한 입장으로 교섭할 수 있다\n·일부, 대규모 정책을 채택할 수 있다\n·일부, 효과가 강한 성하 시설을 조성할 수 있다",
      "source_sc_utf16le_sha256": "65E3EF9F4A4B2714114DC48F1BB13DAE7C7D297B25DBF8BAE3EF4EEB6D3AD140"
    },
    {
      "id": 24383,
      "ko": "·많은 다이묘가 공격해 들어오기를 주저한다\n·외교에서 상당히 강한 입장으로 교섭할 수 있다\n·대규모 정책을 채택할 수 있다\n·효과가 강한 성하 시설을 조성할 수 있다",
